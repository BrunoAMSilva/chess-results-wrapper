---
import Layout from "../../layouts/TVLayout.astro";
import PresenterPairingCard from "../../components/PresenterPairingCard.astro";
import StandingRow from "../../components/StandingRow.astro";
import TabsControl from "../../components/TabsControl.astro";
import SegmentedControl from "../../components/SegmentedControl.astro";
import PresenterQrCode from "../../components/PresenterQrCode.astro";
import { scrapePairings, scrapeStandings } from "../../lib/scraper";
import { useTranslations } from "../../i18n/ui";
import { DEFAULT_TOURNAMENT, ROWS_PER_PAGE, PRESENTER_PAIRINGS_PER_PAGE, CAROUSEL_INTERVAL } from "../../lib/constants";
import { paginateArray } from "../../lib/utils";
import { getIntParam } from "../../lib/request-params";
import { resolvePageLang } from "../../lib/page-lang";

const tid = Astro.url.searchParams.get("tid") || DEFAULT_TOURNAMENT;
const round = getIntParam(Astro.url.searchParams.get("round"), 1, 1, 64);
const lang = resolvePageLang(Astro.url, Astro.cookies);
const rowsPerPage = getIntParam(Astro.url.searchParams.get("rows"), PRESENTER_PAIRINGS_PER_PAGE, 1, 50);
const sponsorImage = Astro.url.searchParams.get("sponsor")?.trim() || "";
const sponsorAlt = Astro.url.searchParams.get("sponsorAlt")?.trim() || "Sponsor";
const hideNonPaired = Astro.url.searchParams.get("hideNonPaired") === "1";

const sponsorSwitchParams = new URLSearchParams();
if (sponsorImage) sponsorSwitchParams.set("sponsor", sponsorImage);
if (sponsorAlt && sponsorAlt !== "Sponsor") sponsorSwitchParams.set("sponsorAlt", sponsorAlt);
const sponsorSwitchSuffix = sponsorSwitchParams.toString()
  ? `&${sponsorSwitchParams.toString()}`
  : "";

const presenterExtras = new URLSearchParams();
if (Astro.url.searchParams.get("rows")) presenterExtras.set("rows", String(rowsPerPage));
if (sponsorImage) presenterExtras.set("sponsor", sponsorImage);
if (sponsorAlt && sponsorAlt !== "Sponsor") presenterExtras.set("sponsorAlt", sponsorAlt);
if (hideNonPaired) presenterExtras.set("hideNonPaired", "1");
const presenterExtraQuery = presenterExtras.toString();
const presenterExtraSuffix = presenterExtraQuery ? `&${presenterExtraQuery}` : "";

const t = useTranslations(lang);

let data;
let error: string | null = null;
let playerList: import("../../lib/scraper").Standing[] = [];

try {
  data = await scrapePairings(tid, round, lang);
} catch (e) {
  error = e instanceof Error ? e.message : t('error.load');
}

const allPairings = data?.pairings || [];

function isByePairing(p: import("../../lib/types").Pairing): boolean {
  if (p.black) return false;
  const label = (p.unpairedLabel || "").toLowerCase();
  const normalizedResult = p.result.replace(/\s+/g, "").toLowerCase();
  return normalizedResult === "1" || label.includes("bye") || label.includes("spielfrei");
}

const visiblePairings = hideNonPaired
  ? allPairings.filter((p) => p.black !== null || isByePairing(p))
  : allPairings;

// When no pairings, fetch player list from standings
let womenPlayerList: import("../../lib/scraper").Standing[] = [];
if (allPairings.length === 0 && !error) {
  try {
    const standingsData = await scrapeStandings(tid, lang);
    playerList = standingsData.standings;
    womenPlayerList = standingsData.womenStandings;
  } catch (_) { /* ignore - show empty state */ }
}

const activePairings = visiblePairings.filter((p) => p.black !== null);
const totalPlayers = activePairings.length * 2 + visiblePairings.filter((p) => !p.black).length;
const rounds = data ? Array.from({ length: data.info.totalRounds }, (_, i) => i + 1) : [];

// Group pairings into pages
const pages = paginateArray(visiblePairings, rowsPerPage);
const totalPages = pages.length;

// Group player list into pages (for fallback when no pairings — use standings row count)
const standingsRowsPerPage = getIntParam(Astro.url.searchParams.get("rows"), ROWS_PER_PAGE, 1, 50);
const playerPages = paginateArray(playerList, standingsRowsPerPage);
const totalPlayerPages = playerPages.length;

const hasWomenPlayers = womenPlayerList.length > 0;
const womenPlayerPages = paginateArray(womenPlayerList, standingsRowsPerPage);
const totalWomenPlayerPages = womenPlayerPages.length;

// Disable auto-refresh for tournaments whose last round date is in the past
function isTournamentLive(dateStr?: string): boolean {
  if (!dateStr) return true;
  const tournamentDate = new Date(dateStr.replace(/\//g, '-'));
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  return tournamentDate >= today;
}
const autoRefresh = isTournamentLive(data?.info.date);
---

<Layout title={data?.info.name || t('site.title')} lang={lang} autoRefresh={autoRefresh}>
  <div class="container">
    <header class="header">
      <div class="header-left">
        <div class="title-row">
          <img class="icon-logo" src="/logo.svg" alt="" />
          <h1 class="title">{data?.info.name || t('site.title')}</h1>
        </div>
      </div>

      <div class="header-right-group">
        {data && (
          <div class="toolbar-stats">
            <span class="stat-pill">
              <span class="stat-group">
                <span class="stat-value">{activePairings.length}</span>
                <span class="stat-label">{t('header.matches')}</span>
              </span>
              <span class="stat-divider"></span>
              <span class="stat-group">
                <span class="stat-value">{totalPlayers}</span>
                <span class="stat-label">{t('header.players')}</span>
              </span>
              <span class="stat-divider"></span>
              <span class="stat-group">
                <span class="stat-label">{t('header.round')}</span>
                <span class="stat-value">{round} <span class="round-total">/ {data.info.totalRounds}</span></span>
              </span>
            </span>
            
            <div class="round-nav">
              <a href={`/present?tid=${tid}&round=${round - 1}&lang=${lang}${presenterExtraSuffix}`} class:list={["nav-btn", { disabled: round <= 1 }]} aria-label={t('header.prevRound')}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
              </a>
              <a href={`/present?tid=${tid}&round=${round + 1}&lang=${lang}${presenterExtraSuffix}`} class:list={["nav-btn", { disabled: round >= data.info.totalRounds }]} aria-label={t('header.nextRound')}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
              </a>
            </div>
          </div>
        )}
      </div>
    </header>

    {error && (
      <div class="error-card">
        <p>{error}</p>
        <p class="error-hint">{t('error.hint')}</p>
      </div>
    )}

    <div class="present-grid">
      <div class="main-column">

    {data && visiblePairings.length === 0 && playerList.length > 0 && (
      <section class="matches-section">
        {hasWomenPlayers && (
          <TabsControl
            name="standings"
            tabs={[
              { value: "open", label: t('standings.open') },
              { value: "women", label: t('standings.women') },
            ]}
            active="open"
          />
        )}
        <div id="openStandings" data-carousel-group>
          <div class="column-headers">
            <span class="col-label col-rank">{t('standings.rank')}</span>
            <span class="col-label col-name">{t('standings.name')}</span>
            <span class="col-label col-stats pr-8 text-right">{t('standings.pts')} / TB</span>
          </div>
          <div class="carousel" id="carousel" data-total-pages={totalPlayerPages} data-interval={CAROUSEL_INTERVAL}>
            {playerPages.map((page, pageIdx) => (
              <div class:list={["carousel-page", { active: pageIdx === 0 }]} data-page={pageIdx}>
                {page.map((standing, i) => (
                  <StandingRow standing={standing} index={i} lang={lang} />
                ))}
              </div>
            ))}
          </div>
          {totalPlayerPages > 1 && (
            <div class="carousel-footer">
              <div class="page-dots" id="pageDots">
                {playerPages.map((_, i) => (
                  <button
                    class:list={["page-dot", { active: i === 0 }]}
                    data-dot={i}
                    aria-label={`Page ${i + 1}`}
                  />
                ))}
              </div>
              <div class="progress-bar" id="progressBar">
                <div class="progress-fill" id="progressFill"></div>
              </div>
            </div>
          )}
        </div>
        {hasWomenPlayers && (
          <div id="womenStandings" class="hidden" data-carousel-group>
            <div class="column-headers">
              <span class="col-label col-rank">{t('standings.rank')}</span>
              <span class="col-label col-name">{t('standings.name')}</span>
              <span class="col-label col-stats pr-8 text-right">{t('standings.pts')} / TB</span>
            </div>
            <div class="carousel" id="womenCarousel" data-total-pages={totalWomenPlayerPages} data-interval={CAROUSEL_INTERVAL}>
              {womenPlayerPages.map((page, pageIdx) => (
                <div class:list={["carousel-page", { active: pageIdx === 0 }]} data-page={pageIdx}>
                  {page.map((standing, i) => (
                    <StandingRow standing={standing} index={i} lang={lang} />
                  ))}
                </div>
              ))}
            </div>
            {totalWomenPlayerPages > 1 && (
              <div class="carousel-footer">
                <div class="page-dots" id="womenPageDots">
                  {womenPlayerPages.map((_, i) => (
                    <button
                      class:list={["page-dot", { active: i === 0 }]}
                      data-dot={i}
                      aria-label={`Page ${i + 1}`}
                    />
                  ))}
                </div>
                <div class="progress-bar" id="womenProgressBar">
                  <div class="progress-fill" id="womenProgressFill"></div>
                </div>
              </div>
            )}
          </div>
        )}
      </section>
    )}

    {data && visiblePairings.length === 0 && playerList.length === 0 && (
      <div class="empty-state">
        <svg class="empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 8v4M12 16h.01"/>
        </svg>
        <p>{t('empty.pairings')}</p>
      </div>
    )}

    {data && visiblePairings.length > 0 && (
      <section class="matches-section">
        <div class="column-headers">
          <span class="col-label col-table">{t('table.table')}</span>
          <span class="col-label col-players">{t('header.players')}</span>
          <span class="col-label col-score">{t('table.score')}</span>
        </div>
        <div class="carousel" id="carousel" data-total-pages={totalPages} data-interval={CAROUSEL_INTERVAL}>
          {pages.map((page, pageIdx) => (
            <div class:list={["carousel-page", { active: pageIdx === 0 }]} data-page={pageIdx}>
              {page.map((pairing, i) => (
                <PresenterPairingCard pairing={pairing} index={i} lang={lang} />
              ))}
            </div>
          ))}
        </div>
        {totalPages > 1 && (
          <div class="carousel-footer">
            <div class="page-dots" id="pageDots">
              {pages.map((_, i) => (
                <button
                  class:list={["page-dot", { active: i === 0 }]}
                  data-dot={i}
                  aria-label={`Page ${i + 1}`}
                />
              ))}
            </div>
            <div class="progress-bar" id="progressBar">
              <div class="progress-fill" id="progressFill"></div>
            </div>
          </div>
        )}
      </section>
    )}
      </div>

      <aside class="side-column">
        {sponsorImage && (
          <section class="sponsor-card" aria-label={t('sponsor.title')}>
            <h2 class="sponsor-title">{t('sponsor.title')}</h2>
            <img class="sponsor-image" src={sponsorImage} alt={sponsorAlt} loading="eager" />
          </section>
        )}

        <PresenterQrCode
          targetUrl={`${Astro.url.origin}/?tid=${tid}`}
          label={t('scan.label')}
          hint={t('scan.hint')}
          size="large"
        />
      </aside>
    </div>
  </div>

  <div class="config-panel" id="configPanel">
    <button class="config-toggle" id="configToggle" aria-label={t('config.title')}>
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
      </svg>
    </button>
    <div class="config-body" id="configBody">
      <div class="view-switch-panel">
        <SegmentedControl
          name="view-switch"
          segments={[
            { value: "pairings", label: t('nav.pairings') },
            { value: "standings", label: t('nav.standings'), href: `/present/standings?tid=${tid}&lang=${lang}${sponsorSwitchSuffix}` },
          ]}
          active="pairings"
        />
      </div>
      <label class="config-label">
        {t('config.tid')}
        <input type="text" id="inputTid" value={tid} class="config-input" />
      </label>
      <label class="config-label">
        {t('config.lang')}
        <select id="inputLang" class="config-input">
          <option value="1" selected={lang === 1}>English</option>
          <option value="10" selected={lang === 10}>Português</option>
          <option value="2" selected={lang === 2}>Español</option>
          <option value="0" selected={lang === 0}>Deutsch</option>
          <option value="20" selected={lang === 20}>Français</option>
        </select>
      </label>
      <label class="config-label">
        {t('config.round')}
        <select id="inputRound" class="config-input">
          {rounds.map((r) => (
            <option value={r} selected={r === round}>{r}</option>
          ))}
        </select>
      </label>
      <label class="config-label">
        {t('config.sponsorImage')}
        <input type="url" id="inputSponsor" value={sponsorImage} class="config-input" placeholder="https://..." />
      </label>
      <label class="config-checkbox">
        <input type="checkbox" id="inputHideNonPaired" checked={hideNonPaired} />
        <span>{t('config.hideNonPaired')}</span>
      </label>
      <button id="configGo" class="config-btn">{t('config.update')}</button>
    </div>
  </div>
</Layout>

<script>
  // Config panel
  const toggle = document.getElementById("configToggle")!;
  const body = document.getElementById("configBody")!;
  const goBtn = document.getElementById("configGo")!;

  toggle.addEventListener("click", () => body.classList.toggle("open"));

  goBtn.addEventListener("click", () => {
    const tid = (document.getElementById("inputTid") as HTMLInputElement).value.trim();
    const lang = (document.getElementById("inputLang") as HTMLSelectElement).value;
    const round = (document.getElementById("inputRound") as HTMLSelectElement).value;
    const sponsor = (document.getElementById("inputSponsor") as HTMLInputElement).value.trim();
    const hideNonPaired = (document.getElementById("inputHideNonPaired") as HTMLInputElement).checked;
    if (!tid) return;
    const params = new URLSearchParams({ tid, lang, round });
    if (sponsor) params.set("sponsor", sponsor);
    if (hideNonPaired) params.set("hideNonPaired", "1");
    window.location.href = `/present?${params.toString()}`;
  });
</script>

<script>
  import "../../scripts/carousel";
</script>

<style>
  .present-grid {
    flex: 1;
    min-height: 0;
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(22rem, 1fr);
    gap: var(--space-5);
  }

  .main-column {
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  .side-column {
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .header-right-group {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-shrink: 0;
  }

  .toolbar-stats {
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }

  .round-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: var(--seg-bg);
    border-radius: var(--radius-sm);
    padding: 2px;
  }

  .nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: var(--text);
    border-radius: 4px;
    transition: background var(--duration-fast) var(--ease-in-out);
    opacity: 0.8;
  }

  .nav-btn:hover:not(.disabled) {
    background: var(--surface-hover);
    opacity: 1;
  }

  .nav-btn.disabled {
    opacity: 0.3;
    pointer-events: none;
  }

  .stat-pill {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding: 0;
    background: transparent;
    border: none;
  }

  .stat-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    padding: 0;
    color: var(--text);
    border-right: 1px solid var(--border-strong);
    padding-right: var(--space-6);
  }

  .stat-group:last-of-type {
    border-right: none;
    padding-right: 0;
  }

  .stat-divider {
    display: none;
  }

  .stat-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    color: var(--text-dim);
    letter-spacing: var(--tracking-wide);
  }

  .stat-value {
    font-size: var(--text-xl);
    font-weight: var(--weight-extrabold);
    color: var(--text);
    line-height: var(--leading-none);
  }

  .round-total {
    font-size: var(--text-base);
    opacity: 0.5;
  }

  .column-headers {
    display: grid;
    grid-template-columns: 7.5rem 1fr 7rem;
    align-items: center;
    padding: 0;
    background: var(--bg-subtle);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .col-table {
    text-align: center;
    padding: var(--space-3) 0;
  }

  .col-players {
    text-align: left;
    padding: var(--space-3) var(--space-6) var(--space-3) var(--space-4);
  }

  .col-score {
    text-align: center;
    padding: var(--space-3) 0;
  }

  .matches-section {
    height: 100%;
  }

  .carousel-page {
    gap: var(--space-2);
    padding: var(--space-2);
  }

  .sponsor-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-height: 0;
    flex: 1;
  }

  .sponsor-title {
    margin: 0;
    font-size: var(--text-base);
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .sponsor-image {
    flex: 1;
    width: 100%;
    min-height: 0;
    height: 100%;
    max-height: none;
    object-fit: contain;
    border-radius: var(--radius-md);
    background: var(--neutral-50);
    padding: var(--space-3);
  }

  .sponsor-placeholder {
    flex: 1;
    min-height: 0;
    border: 1px dashed var(--border-strong);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    text-align: center;
    padding: var(--space-4);
    font-size: var(--text-sm);
  }

  .hidden {
    display: none !important;
  }

  .config-checkbox {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text);
    font-size: var(--text-sm);
    margin-top: var(--space-1);
  }

  .config-checkbox input {
    accent-color: var(--accent-text);
  }
</style>
