---
import Layout from "../../layouts/TVLayout.astro";
import Icon from "../../components/app/Icon.astro";
import PresenterPairingCard from "../../components/presenter/PresenterPairingCard.astro";
import StandingRow from "../../components/standings/StandingRow.astro";
import ErrorCard from "../../components/app/ErrorCard.astro";
import EmptyState from "../../components/app/EmptyState.astro";
import MetricTile from "../../components/app/MetricTile.astro";
import CheckboxField from "../../components/controls/CheckboxField.astro";
import FormField from "../../components/controls/FormField.astro";
import SelectInput from "../../components/controls/SelectInput.astro";
import TabsControl from "../../components/controls/TabsControl.astro";
import TextInput from "../../components/controls/TextInput.astro";
import PresenterConfigPanel from "../../components/presenter/PresenterConfigPanel.astro";
import PresenterSidebar from "../../components/presenter/PresenterSidebar.astro";
import { scrapePairings, scrapeStandings } from "../../lib/scraper";
import { useTranslations } from "../../i18n/ui";
import { DEFAULT_TOURNAMENT, PRESENTER_PAIRINGS_PER_PAGE, CAROUSEL_INTERVAL, LANGUAGE_OPTIONS } from "../../lib/constants";
import { paginateArray } from "../../lib/utils";
import { getIntParam } from "../../lib/request-params";
import { resolvePageLang } from "../../lib/page-lang";

const tid = Astro.url.searchParams.get("tid") || DEFAULT_TOURNAMENT;
const round = getIntParam(Astro.url.searchParams.get("round"), 1, 1, 64);
const lang = resolvePageLang(Astro.url, Astro.cookies);
const rowsPerPage = getIntParam(Astro.url.searchParams.get("rows"), PRESENTER_PAIRINGS_PER_PAGE, 1, 50);
const sponsorImage = Astro.url.searchParams.get("sponsor")?.trim() || "";
const sponsorAlt = Astro.url.searchParams.get("sponsorAlt")?.trim() || "Sponsor";
const hideNonPaired = Astro.url.searchParams.get("hideNonPaired") === "1";

const sponsorSwitchParams = new URLSearchParams();
if (sponsorImage) sponsorSwitchParams.set("sponsor", sponsorImage);
if (sponsorAlt && sponsorAlt !== "Sponsor") sponsorSwitchParams.set("sponsorAlt", sponsorAlt);
const sponsorSwitchSuffix = sponsorSwitchParams.toString()
  ? `&${sponsorSwitchParams.toString()}`
  : "";

const presenterExtras = new URLSearchParams();
if (Astro.url.searchParams.get("rows")) presenterExtras.set("rows", String(rowsPerPage));
if (sponsorImage) presenterExtras.set("sponsor", sponsorImage);
if (sponsorAlt && sponsorAlt !== "Sponsor") presenterExtras.set("sponsorAlt", sponsorAlt);
if (hideNonPaired) presenterExtras.set("hideNonPaired", "1");
const presenterExtraQuery = presenterExtras.toString();
const presenterExtraSuffix = presenterExtraQuery ? `&${presenterExtraQuery}` : "";

const configHiddenFields: Array<{ name: string; value: string }> = [];
if (Astro.url.searchParams.get("rows")) configHiddenFields.push({ name: "rows", value: String(rowsPerPage) });
if (sponsorAlt && sponsorAlt !== "Sponsor") configHiddenFields.push({ name: "sponsorAlt", value: sponsorAlt });

const t = useTranslations(lang);

let data;
let error: string | null = null;
let playerList: import("../../lib/scraper").Standing[] = [];

try {
  data = await scrapePairings(tid, round);
} catch (e) {
  error = e instanceof Error ? e.message : t('error.load');
}

const allPairings = data?.pairings || [];

function isByePairing(p: import("../../lib/types").Pairing): boolean {
  if (p.black) return false;
  const label = (p.unpairedLabel || "").toLowerCase();
  const normalizedResult = p.result.replace(/\s+/g, "").toLowerCase();
  return normalizedResult === "1" || label.includes("bye") || label.includes("spielfrei");
}

const visiblePairings = hideNonPaired
  ? allPairings.filter((p) => p.black !== null || isByePairing(p))
  : allPairings;

// When no pairings, fetch player list from standings
let womenPlayerList: import("../../lib/scraper").Standing[] = [];
if (allPairings.length === 0 && !error) {
  try {
    const standingsData = await scrapeStandings(tid);
    playerList = standingsData.standings;
    womenPlayerList = standingsData.womenStandings;
  } catch (_) { /* ignore - show empty state */ }
}

const activePairings = visiblePairings.filter((p) => p.black !== null);
const totalPlayers = activePairings.length * 2 + visiblePairings.filter((p) => !p.black).length;
const rounds = data ? Array.from({ length: data.info.totalRounds }, (_, i) => i + 1) : [];
const totalRounds = data?.info.totalRounds ?? 1;
const previousRound = Math.max(1, round - 1);
const nextRound = Math.min(totalRounds, round + 1);
const hasPreviousRound = round > 1;
const hasNextRound = round < totalRounds;
const sectionTitle = data?.info.currentLabel || data?.info.name || t('site.title');
const tournamentEyebrow = data?.info.currentLabel ? data.info.name : undefined;

// Group pairings into pages
const pages = paginateArray(visiblePairings, rowsPerPage);
const totalPages = pages.length;

// Group player list into pages (for fallback when no pairings)
const playerPages = paginateArray(playerList, rowsPerPage);
const totalPlayerPages = playerPages.length;

const hasWomenPlayers = womenPlayerList.length > 0;
const womenPlayerPages = paginateArray(womenPlayerList, rowsPerPage);
const totalWomenPlayerPages = womenPlayerPages.length;

// Disable auto-refresh for tournaments whose last round date is in the past
function isTournamentLive(dateStr?: string): boolean {
  if (!dateStr) return true;
  const tournamentDate = new Date(dateStr.replace(/\//g, '-'));
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  return tournamentDate >= today;
}
const autoRefresh = isTournamentLive(data?.info.date);
---

<Layout title={sectionTitle} eyebrow={tournamentEyebrow} lang={lang} autoRefresh={autoRefresh}>
  <div class="container">
    <header class="header">
      <div class="header-left">
        <div class="title-row">
          <img class="icon-logo" src="/logo.svg" alt="" />
          <div class="title-stack">
            {tournamentEyebrow && <p class="eyebrow">{tournamentEyebrow}</p>}
            <h1 class="title">{sectionTitle}</h1>
          </div>
        </div>
      </div>

      <div class="header-right-group">
        {data && (
          <div class="toolbar-stats">
            <span class="stat-pill">
              <MetricTile class="stat-group" label={t('header.matches')} variant="plain" value={activePairings.length} />
              <span class="stat-divider"></span>
              <MetricTile class="stat-group" label={t('header.players')} variant="plain" value={totalPlayers} />
              <span class="stat-divider"></span>
              <MetricTile class="stat-group" label={t('header.round')} variant="plain">
                <Fragment slot="value">{round} <span class="round-total">/ {data.info.totalRounds}</span></Fragment>
              </MetricTile>
            </span>
            
            <div class="round-nav">
              {hasPreviousRound ? (
                <a href={`/present?tid=${tid}&round=${previousRound}&lang=${lang}${presenterExtraSuffix}`} class="nav-btn" aria-label={t('header.prevRound')}>
                  <Icon name="chevron-left" size={20} />
                </a>
              ) : (
                <span class:list={["nav-btn", "disabled"]} aria-hidden="true">
                  <Icon name="chevron-left" size={20} />
                </span>
              )}
              {hasNextRound ? (
                <a href={`/present?tid=${tid}&round=${nextRound}&lang=${lang}${presenterExtraSuffix}`} class="nav-btn" aria-label={t('header.nextRound')}>
                  <Icon name="chevron-right" size={20} />
                </a>
              ) : (
                <span class:list={["nav-btn", "disabled"]} aria-hidden="true">
                  <Icon name="chevron-right" size={20} />
                </span>
              )}
            </div>
          </div>
        )}
      </div>
    </header>

    {error && <ErrorCard hint={t('error.hint')}><p>{error}</p></ErrorCard>}

    <div class="present-grid">
      <div class="main-column">

    {data && visiblePairings.length === 0 && playerList.length > 0 && (
      <section class="matches-section">
        {hasWomenPlayers && (
          <TabsControl
            name="standings"
            tabs={[
              { value: "open", label: t('standings.open') },
              { value: "women", label: t('standings.women') },
            ]}
            active="open"
          />
        )}
        <div id="openStandings" data-carousel-group>
          <div class="column-headers">
            <span class="col-label col-rank">{t('standings.rank')}</span>
            <span class="col-label col-name">{t('standings.name')}</span>
            <span class="col-label col-stats pr-8 text-right">{t('standings.pts')} / TB</span>
          </div>
          <div class="carousel" id="carousel" data-total-pages={totalPlayerPages} data-interval={CAROUSEL_INTERVAL}>
            {playerPages.map((page, pageIdx) => (
              <div class:list={["carousel-page", { active: pageIdx === 0 }]} data-page={pageIdx}>
                {page.map((standing, i) => (
                  <StandingRow standing={standing} index={i} lang={lang} />
                ))}
              </div>
            ))}
          </div>
          {totalPlayerPages > 1 && (
            <div class="carousel-footer">
              <div class="page-dots" id="pageDots">
                {playerPages.map((_, i) => (
                  <button
                    class:list={["page-dot", { active: i === 0 }]}
                    data-dot={i}
                    aria-label={`Page ${i + 1}`}
                  />
                ))}
              </div>
              <div class="progress-bar" id="progressBar">
                <div class="progress-fill" id="progressFill"></div>
              </div>
            </div>
          )}
        </div>
        {hasWomenPlayers && (
          <div id="womenStandings" class="hidden" data-carousel-group>
            <div class="column-headers">
              <span class="col-label col-rank">{t('standings.rank')}</span>
              <span class="col-label col-name">{t('standings.name')}</span>
              <span class="col-label col-stats pr-8 text-right">{t('standings.pts')} / TB</span>
            </div>
            <div class="carousel" id="womenCarousel" data-total-pages={totalWomenPlayerPages} data-interval={CAROUSEL_INTERVAL}>
              {womenPlayerPages.map((page, pageIdx) => (
                <div class:list={["carousel-page", { active: pageIdx === 0 }]} data-page={pageIdx}>
                  {page.map((standing, i) => (
                    <StandingRow standing={standing} index={i} lang={lang} />
                  ))}
                </div>
              ))}
            </div>
            {totalWomenPlayerPages > 1 && (
              <div class="carousel-footer">
                <div class="page-dots" id="womenPageDots">
                  {womenPlayerPages.map((_, i) => (
                    <button
                      class:list={["page-dot", { active: i === 0 }]}
                      data-dot={i}
                      aria-label={`Page ${i + 1}`}
                    />
                  ))}
                </div>
                <div class="progress-bar" id="womenProgressBar">
                  <div class="progress-fill" id="womenProgressFill"></div>
                </div>
              </div>
            )}
          </div>
        )}
      </section>
    )}

    {data && visiblePairings.length === 0 && playerList.length === 0 && (
      <EmptyState message={t('empty.pairings')}>
        <Icon slot="icon" name="info" size={24} />
      </EmptyState>
    )}

    {data && visiblePairings.length > 0 && (
      <section class="matches-section">
        <div
          class="carousel pairings-carousel"
          id="carousel"
          data-total-pages={totalPages}
          data-interval={CAROUSEL_INTERVAL}
          data-dynamic-pagination="pairings"
        >
          {pages.map((page, pageIdx) => (
            <div class:list={["carousel-page", "pairings-page", { active: pageIdx === 0 }]} data-page={pageIdx}>
              {page.map((pairing, i) => (
                <div class="pairings-item" data-carousel-item>
                  <PresenterPairingCard pairing={pairing} index={i} lang={lang} />
                </div>
              ))}
            </div>
          ))}
        </div>
        <div class:list={["carousel-footer", { hidden: totalPages <= 1 }]}>
          <div class="page-dots" id="pageDots">
            {pages.map((_, i) => (
              <button
                class:list={["page-dot", { active: i === 0 }]}
                data-dot={i}
                aria-label={`Page ${i + 1}`}
              />
            ))}
          </div>
          <div class="progress-bar" id="progressBar">
            <div class="progress-fill" id="progressFill"></div>
          </div>
        </div>
      </section>
    )}
      </div>

      <PresenterSidebar
        sponsorImage={sponsorImage}
        sponsorAlt={sponsorAlt}
        sponsorTitle={t('sponsor.title')}
        qrTargetPath={`/pairings?tid=${tid}&lang=${lang}`}
        qrLabel={t('scan.label')}
        qrHint={t('scan.hint')}
      />
    </div>
  </div>

  <PresenterConfigPanel
    idPrefix="present-pairings"
    title={t('config.title')}
    action="/present"
    submitLabel={t('config.update')}
    segments={[
      { value: "pairings", label: t('nav.pairings') },
      { value: "standings", label: t('nav.standings'), href: `/present/standings?tid=${tid}&lang=${lang}${sponsorSwitchSuffix}` },
    ]}
    activeSegment="pairings"
    hiddenFields={configHiddenFields}
  >
      <FormField label={t('config.tid')} forId="inputTid">
        <TextInput id="inputTid" name="tid" value={tid} />
      </FormField>
      <FormField label={t('config.lang')} forId="inputLang">
        <SelectInput id="inputLang" name="lang">
          {LANGUAGE_OPTIONS.map((option) => (
            <option value={String(option.value)} selected={lang === option.value}>{option.label}</option>
          ))}
        </SelectInput>
      </FormField>
      <FormField label={t('config.round')} forId="inputRound">
        <SelectInput id="inputRound" name="round">
          {rounds.map((r) => (
            <option value={r} selected={r === round}>{r}</option>
          ))}
        </SelectInput>
      </FormField>
      <FormField label={t('config.sponsorImage')} forId="inputSponsor">
        <TextInput id="inputSponsor" name="sponsor" type="url" value={sponsorImage} placeholder="https://..." />
      </FormField>
      <CheckboxField id="inputHideNonPaired" name="hideNonPaired" label={t('config.hideNonPaired')} checked={hideNonPaired} />
  </PresenterConfigPanel>
</Layout>

<script>
  import "../../scripts/carousel";
</script>

<style>
  .present-grid {
    flex: 1;
    min-height: 0;
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(22rem, 1fr);
    gap: var(--space-5);
  }

  .main-column {
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  .header-right-group {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-shrink: 0;
  }

  .toolbar-stats {
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }

  .round-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: var(--seg-bg);
    border-radius: var(--radius-sm);
    padding: 2px;
  }

  .nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: var(--text);
    border-radius: 4px;
    transition: background var(--duration-fast) var(--ease-in-out);
    opacity: 0.8;
  }

  .nav-btn:hover:not(.disabled) {
    background: var(--surface-hover);
    opacity: 1;
  }

  .nav-btn.disabled {
    opacity: 0.3;
    pointer-events: none;
  }

  .stat-pill {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding: 0;
    background: transparent;
    border: none;
  }

  :global(.stat-group) {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    padding: 0;
    color: var(--text);
    padding-right: var(--space-6);
  }

  :global(.stat-group:last-of-type) {
    border-right: none;
    padding-right: 0;
  }

  .stat-divider {
    display: none;
  }

  .round-total {
    font-size: var(--text-base);
    opacity: 0.5;
  }

  .column-headers {
    display: grid;
    grid-template-columns: 7.5rem 1fr 7rem;
    align-items: center;
    padding: 0;
    background: var(--bg-subtle);
    flex-shrink: 0;
  }

  .col-table {
    text-align: center;
    padding: var(--space-3) 0;
  }

  .col-players {
    text-align: left;
    padding: var(--space-3) var(--space-6) var(--space-3) var(--space-4);
  }

  .col-score {
    text-align: center;
    padding: var(--space-3) 0;
  }

  .matches-section {
    height: 100%;
  }

  :global(.pairings-carousel) {
    --pairings-card-min-width: var(--size-presenter-pairing-card-min-width);
  }

  :global(.pairings-carousel .carousel-page) {
    gap: var(--space-8);
    padding: var(--space-2);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(var(--pairings-card-min-width), 1fr));
    align-content: start;
    grid-auto-rows: max-content;
  }

  :global(.pairings-item) {
    min-width: 0;
  }

  .sponsor-placeholder {
    flex: 1;
    min-height: 0;
    border: 1px dashed var(--border-strong);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    text-align: center;
    padding: var(--space-4);
    font-size: var(--text-sm);
  }

  .hidden {
    display: none !important;
  }

</style>
