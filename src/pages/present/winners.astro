---
import WinnersCarousel from "../../components/presenter/WinnersCarousel.astro";
import ErrorCard from "../../components/app/ErrorCard.astro";
import BaseHead from "../../components/app/BaseHead.astro";
import { scrapeStandings } from "../../lib/scraper";
import { getTournamentConfig } from "../../lib/db";
import { useTranslations, languages } from "../../i18n/ui";
import { extractPageParams, resolveTournamentDisplay, resolveSponsorConfig } from "../../lib/page-context";
import { WINNERS_PRESENTATION_START_RANK_DEFAULT } from "../../lib/constants";
import "../../styles/global.css";

const { tid, lang } = extractPageParams(Astro.url, Astro.cookies);

const startRankParam = Astro.url.searchParams.get("startRank");
let startRank = startRankParam ? parseInt(startRankParam) : null;

if (!startRank || startRank < 1) {
  const configRank = getTournamentConfig(tid, "winners_presentation_start_rank");
  startRank = configRank ? parseInt(configRank) : WINNERS_PRESENTATION_START_RANK_DEFAULT;
}

const t = useTranslations(lang);
const langCode = languages[lang as keyof typeof languages] || 'en';

let data;
let error: string | null = null;

try {
  data = await scrapeStandings(tid);
} catch (e) {
  error = e instanceof Error ? e.message : t('error.load');
}

const allStandings = data?.standings || [];
// Filter to top N, then reverse so we go from lowest (e.g. 3rd) down to 1st
const filteredStandings = allStandings
  .filter((s) => s.rank >= 1 && s.rank <= startRank!)
  .sort((a, b) => b.rank - a.rank); // 3, 2, 1

const { sectionTitle, eyebrow: tournamentEyebrow } = resolveTournamentDisplay(
  data?.info,
  t('site.title')
);

const { sponsorImage, sponsorAlt } = resolveSponsorConfig(Astro.url, tid);
---

<!doctype html>
<html lang={langCode}>
  <head>
    <BaseHead title={`${sectionTitle} | ViteChess`} />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; overflow: hidden; background: var(--bg); color: var(--text); }
    </style>
  </head>
  <body>
    {error ? (
      <div style="display:flex;align-items:center;justify-content:center;height:100vh;">
        <ErrorCard hint={t('error.hint')}><p>{error}</p></ErrorCard>
      </div>
    ) : filteredStandings.length === 0 ? (
      <div style="display:flex;align-items:center;justify-content:center;height:100vh;color:var(--text-dim);">
        <p>No standings data available.</p>
      </div>
    ) : (
      <WinnersCarousel
        standings={filteredStandings}
        tournamentId={tid}
        lang={lang}
        tournamentName={sectionTitle}
        sponsorImage={sponsorImage}
        sponsorAlt={sponsorAlt}
      />
    )}
    <script>
      import { getFirebaseAnalytics } from "../../lib/firebase-client";
      getFirebaseAnalytics();
    </script>
  </body>
</html>
