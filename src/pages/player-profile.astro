---
import MobileLayout from "../layouts/ResponsiveLayout.astro";
import EmptyState from "../components/app/EmptyState.astro";
import PlayerIdentityActions from "../components/player/PlayerIdentityActions.astro";
import PlayerName from "../components/player/PlayerName.astro";
import PlayerTournamentHistoryRow from "../components/player/PlayerTournamentHistoryRow.astro";
import { useTranslations } from "../i18n/ui";
import { findPlayerByIdentity, getPlayerById, getPlayerResultRows, getPlayerTournamentHistory } from "../lib/db";
import { scrapeStandings } from "../lib/scraper";
import { resolvePageLang } from "../lib/page-lang";
import { reverseName, federationFlag } from "../lib/utils";
import type { DbPlayer, DbPlayerTournamentHistory } from "../lib/types";

const idParam = Astro.url.searchParams.get("id") || "";
const nameParam = Astro.url.searchParams.get("name") || "";
const fedParam = Astro.url.searchParams.get("fed") || "";
const lang = resolvePageLang(Astro.url, Astro.cookies);

const t = useTranslations(lang);

let error: string | null = null;
let player: DbPlayer | undefined;
let history: DbPlayerTournamentHistory[] = [];
const resultStatsByTournament = new Map<string, { wins: number; draws: number; losses: number }>();

const playerId = Number.parseInt(idParam, 10);
if (Number.isFinite(playerId) && playerId > 0) {
  player = getPlayerById(playerId);
}

if (!player && nameParam.trim()) {
  player = findPlayerByIdentity(nameParam, fedParam);
}

if (!player) {
  error = t("player.profile.notFound");
} else {
  let resolvedPlayer = player;
  history = getPlayerTournamentHistory(resolvedPlayer.id!);

  const needsEnrichment = !resolvedPlayer.federation || !resolvedPlayer.sex || resolvedPlayer.rating === null || !resolvedPlayer.club;
  if (needsEnrichment && history.length > 0) {
    // Re-scrape known tournaments to backfill local DB metadata if needed.
    const enrichTargets = history.slice(0, 5);
    await Promise.allSettled(
      enrichTargets.map((entry) =>
        scrapeStandings(entry.tournament_id),
      ),
    );
    resolvedPlayer = getPlayerById(resolvedPlayer.id!) || resolvedPlayer;
    history = getPlayerTournamentHistory(resolvedPlayer.id!);
  }

  const rows = getPlayerResultRows(resolvedPlayer.id!);
  for (const row of rows) {
    const current = resultStatsByTournament.get(row.tournament_id) || { wins: 0, draws: 0, losses: 0 };
    const normalized = row.result.replace(/\s+/g, "").toLowerCase();
    const isWhite = row.white_player_id === resolvedPlayer.id;

    if (normalized.includes("1-0") || normalized.includes("1:0")) {
      if (isWhite) current.wins += 1;
      else current.losses += 1;
    } else if (normalized.includes("0-1") || normalized.includes("0:1")) {
      if (isWhite) current.losses += 1;
      else current.wins += 1;
    } else if (normalized.includes("1/2") || normalized.includes("0.5") || normalized.includes("\u00bd")) {
      current.draws += 1;
    }

    resultStatsByTournament.set(row.tournament_id, current);
  }

  player = resolvedPlayer;
}

const profileTitle = player ? reverseName(player.name) : t("player.profile.title");
const rankedEntries = history.filter((entry) => typeof entry.rank === "number");
const totalWins = Array.from(resultStatsByTournament.values()).reduce((sum, item) => sum + item.wins, 0);
const totalDraws = Array.from(resultStatsByTournament.values()).reduce((sum, item) => sum + item.draws, 0);
const totalLosses = Array.from(resultStatsByTournament.values()).reduce((sum, item) => sum + item.losses, 0);
const bestRank = rankedEntries.length
  ? String(Math.min(...rankedEntries.map((entry) => Number(entry.rank))))
  : "-";
const averageRank = rankedEntries.length
  ? (rankedEntries.reduce((sum, entry) => sum + Number(entry.rank), 0) / rankedEntries.length).toFixed(1)
  : "-";
const latestSeen = history.length > 0 ? history[0].updated_at : "-";
---

<MobileLayout title={profileTitle} lang={lang}>
  {error && (
    <div class="error-msg">
      <p>{error}</p>
    </div>
  )}

  {player && (
    <section class="hero-section">
      <div class="hero-image-container">
        <img class="hero-image" alt="Player Identity Avatar" src={player.photo_url ?? "/images/avatar-placeholder.png"} />
        <div class="hero-image-gradient">
          <span class="hero-tag">
            {player.federation
              ? <>{federationFlag(player.federation)} {player.federation}</>
              : t("player.profile.identity")}
          </span>
        </div>
      </div>

      <div class="hero-content">
        <h2 class="hero-name">
          <PlayerName name={player.name} title={player.title} />
        </h2>

        <div class="bento-grid">
          <div class="bento-card">
            <span class="bento-label">{t("player.profile.total")}</span>
            <span class="bento-val">{history.length}</span>
          </div>
          <div class="bento-card">
            <span class="bento-label">{t("player.profile.bestRank")} / {t("player.profile.avgRank")}</span>
            <span class="bento-val">{bestRank}<span class="bento-val-sub">~{averageRank}</span></span>
          </div>
          <div class="bento-card bento-card--wide">
            <span class="bento-label">{t("player.profile.record")} (W-D-L)</span>
            <span class="bento-val bento-val--record">{totalWins}<span class="bento-val-sep">-</span>{totalDraws}<span class="bento-val-sep">-</span>{totalLosses}</span>
          </div>
        </div>
      </div>
    </section>
  )}

  {player && (
    <section class="identity-section">
      <div class="section-header">
        <h3 class="section-title">{t("player.profile.identity")}</h3>
        <div class="section-dots">
          <span class="dot dot-primary"></span>
          <span class="dot dot-highest"></span>
          <span class="dot dot-highest"></span>
        </div>
      </div>

      <dl class="identity-grid">
        <div class="identity-item">
          <dt>{t("player.profile.fideId")}</dt>
          <dd>{player.fide_id || "-"}</dd>
        </div>
        <div class="identity-item">
          <dt>{t("player.profile.federation")}</dt>
          <dd>{player.federation ? <span title={player.federation}>{federationFlag(player.federation)} {player.federation}</span> : "-"}</dd>
        </div>
        <div class="identity-item">
          <dt>{t("player.profile.sex")}</dt>
          <dd>{player.sex || "-"}</dd>
        </div>
        <div class="identity-item">
          <dt>{t("player.profile.rating")}</dt>
          <dd>{player.rating ?? "-"}</dd>
        </div>
        <div class="identity-item">
          <dt>{t("player.profile.club")}</dt>
          <dd>{player.club || "-"}</dd>
        </div>
        <div class="identity-item">
          <dt>{t("player.profile.lastSeen")}</dt>
          <dd>{latestSeen || "-"}</dd>
        </div>
      </dl>
    </section>
  )}

  {player && (
    <div class="identity-actions-bar">
      <PlayerIdentityActions playerName={player.name} federation={player.federation} lang={lang} />
    </div>
  )}

  {player && (
    <section class="history-section">
      <div class="section-header">
        <h3 class="section-title">{t("player.profile.tournaments")}</h3>
        <div class="section-dots">
          <span class="dot dot-primary"></span>
          <span class="dot dot-highest"></span>
          <span class="dot dot-highest"></span>
        </div>
      </div>

      {history.length > 0 ? (
        <div class="history-list">
          {history.map((entry) => (
            <PlayerTournamentHistoryRow
              entry={entry}
              playerName={player!.name}
              lang={lang}
              wins={resultStatsByTournament.get(entry.tournament_id)?.wins || 0}
              draws={resultStatsByTournament.get(entry.tournament_id)?.draws || 0}
              losses={resultStatsByTournament.get(entry.tournament_id)?.losses || 0}
            />
          ))}
        </div>
      ) : (
        <EmptyState message={t("player.profile.noHistory")} variant="surface" compact />
      )}
    </section>
  )}
</MobileLayout>

<style is:global>
  /* Hero Layout */
  .hero-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 768px) {
    .hero-section {
      grid-template-columns: repeat(12, minmax(0, 1fr));
    }
  }

  /* Image Container */
  .hero-image-container {
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--surface-container-high);
    position: relative;
  }

  @media (min-width: 768px) {
    .hero-image-container {
      grid-column: span 4 / span 4;
    }
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-image-gradient {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-4);
    background: linear-gradient(to top, var(--bg) 0%, transparent 100%);
  }

  .hero-tag {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    background: var(--primary-container);
    color: var(--on-primary-fixed);
    font-size: 10px;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
  }

  /* Content */
  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  @media (min-width: 768px) {
    .hero-content {
      grid-column: span 8 / span 8;
    }
  }

  .hero-name {
    font-family: var(--font-display);
    font-weight: var(--weight-extrabold);
    font-size: var(--text-4xl);
    color: var(--text);
    margin-bottom: var(--space-4);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-none);
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  @media (min-width: 768px) {
    .hero-name {
      font-size: var(--text-6xl);
    }
  }

  /* Bento Grid */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .bento-card {
    background: var(--surface-container-low);
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-left: 4px solid var(--primary-container);
  }

  .bento-card--wide {
    grid-column: span 2;
  }

  .bento-label {
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
  }

  .bento-val {
    font-family: var(--font-display);
    font-weight: var(--weight-extrabold);
    font-size: var(--text-5xl);
    color: var(--text);
    margin-top: var(--space-2);
  }

  .bento-val--record {
    font-size: var(--text-4xl);
  }

  .bento-val-sub {
    font-size: var(--text-lg);
    opacity: 0.5;
    margin-left: var(--space-2);
  }

  .bento-val-sep {
    font-size: var(--text-2xl);
    opacity: 0.35;
    margin: 0 var(--space-1);
  }

  /* Identity Actions Bar */
  .identity-actions-bar {
    margin-bottom: var(--space-8);
  }

  /* Section header with dots */
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-6);
  }

  .section-title {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--text-2xl);
    color: var(--text);
    margin: 0;
  }

  .section-dots {
    display: flex;
    gap: var(--space-2);
  }

  .dot {
    height: 8px;
    width: 8px;
    border-radius: var(--radius-full);
  }

  .dot-primary {
    background: var(--primary-container);
  }

  .dot-highest {
    background: var(--surface-container-highest);
  }

  /* Identity Grid */
  .identity-section {
    margin-bottom: var(--space-10);
  }

  .identity-grid {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
  }

  @media (min-width: 640px) {
    .identity-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .identity-item {
    background: var(--surface-container-low);
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-xl);
    border-left: 4px solid var(--surface-container-highest);
  }

  .identity-item dt {
    margin: 0;
    font-size: var(--text-xs);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    font-family: var(--font-sans);
  }

  .identity-item dd {
    margin: var(--space-1) 0 0;
    font-size: var(--text-base);
    color: var(--text);
    font-weight: var(--weight-semibold);
    word-break: break-word;
  }

  /* History Section */
  .history-section {
    display: flex;
    flex-direction: column;
    padding-bottom: var(--space-8);
  }

  .history-list {
    display: flex;
    flex-direction: column;
  }
</style>
