---
import MobileLayout from "../layouts/MobileLayout.astro";
import { useTranslations } from "../i18n/ui";
import { DEFAULT_TOURNAMENT } from "../lib/constants";

const tid = Astro.url.searchParams.get("tid") || DEFAULT_TOURNAMENT;
const lang = parseInt(Astro.url.searchParams.get("lang") || "1");

const t = useTranslations(lang);
---

<MobileLayout title={t('site.title')} lang={lang}>
  <div class="options-grid">
    <div class="options-card">
      <div class="card-header">
        <div class="icon-wrapper">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>
        </div>
        <div>
          <h2>Settings</h2>
          <p class="card-desc">Configure tournament source and display language</p>
        </div>
      </div>
      
      <div class="form-grid">
        <div class="option-group">
          <label class="option-label" for="inputTid">{t('config.tid')}</label>
          <input type="text" id="inputTid" value={tid} class="option-input" placeholder="Tournament ID" />
        </div>

        <div class="option-group">
          <label class="option-label" for="inputLang">{t('config.lang')}</label>
          <div class="select-wrapper">
            <select id="inputLang" class="option-input">
              <option value="1" selected={lang === 1}>English</option>
              <option value="10" selected={lang === 10}>Português</option>
              <option value="2" selected={lang === 2}>Español</option>
              <option value="0" selected={lang === 0}>Deutsch</option>
              <option value="20" selected={lang === 20}>Français</option>
            </select>
          </div>
        </div>
      </div>

      <div class="actions-row">
        <button id="saveBtn" class="save-btn">
          <span>{t('config.update')}</span>
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M12 5l7 7-7 7"></path></svg>
        </button>
      </div>
    </div>

    <div class="options-card secondary-card">
      <div class="card-header">
        <div class="icon-wrapper accent">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="15" rx="2" ry="2"></rect><polyline points="17 2 12 7 7 2"></polyline></svg>
        </div>
        <div>
          <h2>Presenter Mode</h2>
          <p class="card-desc">Open the auto-scrolling TV view</p>
        </div>
      </div>
      <p class="help-text">Ideal for big screens at the venue. Automatically cycles through pairings and standings.</p>
      <a href={`/present?tid=${tid}&lang=${lang}`} class="presenter-btn">
        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
        Launch Setup
      </a>
    </div>
  </div>
</MobileLayout>

<style>
  .options-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
    max-width: 800px;
    animation: fadeInUp 0.4s ease out;
  }

  @media (min-width: 800px) {
    .options-grid {
      grid-template-columns: 1fr 340px;
    }
  }

  .options-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 8px 30px rgba(0,0,0,0.2);
  }

  .secondary-card {
    background: linear-gradient(180deg, var(--surface) 0%, rgba(26,26,36,0.5) 100%);
    border-color: rgba(124, 106, 239, 0.2);
    display: flex;
    flex-direction: column;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 2rem;
  }

  .icon-wrapper {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
  }

  .icon-wrapper.accent {
    background: rgba(124, 106, 239, 0.15);
    color: var(--accent);
  }

  h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
  }

  .card-desc {
    color: var(--text-dim);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .form-grid {
    display: grid;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .option-group {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .option-label {
    font-size: 0.9rem;
    color: var(--text-dim);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .option-input {
    padding: 1rem;
 border-radius: 10px;
    border: 1px solid var(--border);
    background: rgba(0,0,0,0.2);
    color: var(--text);
    font-size: 1.1rem;
    transition: all 0.2s;
    width: 100%;
    appearance: none;
    font-family: inherit;
  }
  
  .select-wrapper {
    position: relative;
  }
  
  .select-wrapper::after {
    content: "▼";
    position: absolute;
    right: 1.2rem;
  top: 50%;
    transform: translateY(-50%);
    font-size: 0.8rem;
    color: var(--text-dim);
    pointer-events: none;
  }

  .option-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(124, 106, 239, 0.2);
  }

  .actions-row {
    display: flex;
    justify-content: flex-end;
    border-top: 1px solid var(--border-light);
    padding-top: 1.5rem;
  }

  .save-btn {
    padding: 0.9rem 1.8rem;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 30px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    transition: all 0.2s;
    box-shadow: 0 4px 15px rgba(124, 106, 239, 0.4);
  }
  
  .save-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(124, 106, 239, 0.6);
  }

  .help-text {
    flex: 1;
    color: var(--text-dim);
    line-height: 1.6;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .presenter-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    padding: 1rem;
    background: rgba(255,255,255,0.05);
    color: var(--text);
    text-decoration: none;
    border: 1px solid var(--border-light);
    border-radius: 12px;
    font-weight: 600;
    transition: all 0.2s;
  }

  .presenter-btn:hover {
    background: rgba(124, 106, 239, 0.15);
    border-color: var(--accent);
    color: #fff;
    transform: translateY(-2px);
  }
</style>

<script>
  const saveBtn = document.getElementById('saveBtn');
  const inputTid = document.getElementById('inputTid') as HTMLInputElement;
  const inputLang = document.getElementById('inputLang') as HTMLSelectElement;
	  if (saveBtn) {
    saveBtn.addEventListener('click', () => {
      const url = new URL(window.location.href);
      url.searchParams.set('tid', inputTid.value);
      url.searchParams.set('lang', inputLang.value);
      window.location.href = url.toString();
    });
  }
</script>
