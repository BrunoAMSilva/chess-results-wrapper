---
import MobileLayout from "../layouts/MobileLayout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { useTranslations } from "../i18n/ui";
import { DEFAULT_TOURNAMENT } from "../lib/constants";

const tid = Astro.url.searchParams.get("tid") || DEFAULT_TOURNAMENT;
const lang = parseInt(Astro.url.searchParams.get("lang") || "1");

const t = useTranslations(lang);
---

<MobileLayout title={t('site.title')} lang={lang}>
  <div class="options-grid">
    <div class="options-card">
      <div class="card-header">
        <div class="icon-wrapper">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>
        </div>
        <div>
          <h2>Settings</h2>
          <p class="card-desc">Configure tournament source and display language</p>
        </div>
      </div>
      
      <div class="form-grid">
        <div class="option-group">
          <label class="option-label" for="inputTid">{t('config.tid')}</label>
          <input type="text" id="inputTid" value={tid} class="option-input" placeholder="Tournament ID" />
        </div>

        <div class="option-group">
          <label class="option-label" for="inputLang">{t('config.lang')}</label>
          <div class="select-wrapper">
            <select id="inputLang" class="option-input">
              <option value="1" selected={lang === 1}>English</option>
              <option value="10" selected={lang === 10}>Português</option>
              <option value="2" selected={lang === 2}>Español</option>
              <option value="0" selected={lang === 0}>Deutsch</option>
              <option value="20" selected={lang === 20}>Français</option>
            </select>
          </div>
        </div>

        <div class="option-group">
          <label class="option-label">Appearance</label>
          <ThemeToggle />
        </div>
      </div>

      <div class="actions-row">
        <button id="saveBtn" class="save-btn">
          <span>{t('config.update')}</span>
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M12 5l7 7-7 7"></path></svg>
        </button>
      </div>
    </div>

    <div class="options-card secondary-card">
      <div class="card-header">
        <div class="icon-wrapper accent">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="15" rx="2" ry="2"></rect><polyline points="17 2 12 7 7 2"></polyline></svg>
        </div>
        <div>
          <h2>Presenter Mode</h2>
          <p class="card-desc">Open the auto-scrolling TV view</p>
        </div>
      </div>
      <p class="help-text">Ideal for big screens at the venue. Automatically cycles through pairings and standings.</p>
      <a href={`/present?tid=${tid}&lang=${lang}`} class="presenter-btn">
        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
        Launch Setup
      </a>
    </div>
  </div>
</MobileLayout>

<style>
  .options-grid {
    display: grid;
    gap: var(--space-8);
    grid-template-columns: 1fr;
    max-width: 800px;
    animation: fadeInUp var(--duration-slow) var(--ease-out) both;
  }

  @media (min-width: 800px) {
    .options-grid {
      grid-template-columns: 1fr 340px;
    }
  }

  .options-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    box-shadow: var(--shadow-elevated);
  }

  .secondary-card {
    background: linear-gradient(180deg, var(--surface) 0%, var(--bg-subtle) 100%);
    border-color: var(--accent-subtle);
    display: flex;
    flex-direction: column;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: var(--space-8);
  }

  .icon-wrapper {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: var(--seg-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
  }

  .icon-wrapper.accent {
    background: var(--accent-subtle);
    color: var(--accent-text);
  }

  h2 {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    margin-bottom: 0.2rem;
  }

  .card-desc {
    color: var(--text-dim);
    font-size: var(--text-sm);
    line-height: 1.4;
  }

  .form-grid {
    display: grid;
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .option-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .option-label {
    font-size: var(--text-sm);
    color: var(--text-dim);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .option-input {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--input-border);
    background: var(--input-bg);
    color: var(--text);
    font-size: var(--text-lg);
    transition: all var(--duration-fast) var(--ease-in-out);
    width: 100%;
    appearance: none;
    font-family: inherit;
  }
  
  .select-wrapper {
    position: relative;
  }
  
  .select-wrapper::after {
    content: "▼";
    position: absolute;
    right: 1.2rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.8rem;
    color: var(--text-dim);
    pointer-events: none;
  }

  .option-input:focus {
    outline: none;
    border-color: var(--input-focus);
    box-shadow: 0 0 0 3px var(--input-focus-ring);
  }

  .actions-row {
    display: flex;
    justify-content: flex-end;
    border-top: 1px solid var(--border-light);
    padding-top: var(--space-6);
  }

  .save-btn {
    padding: 0.9rem 1.8rem;
    background: var(--accent);
    color: var(--on-accent);
    border: none;
    border-radius: var(--radius-full);
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    transition: all var(--duration-fast) var(--ease-in-out);
    box-shadow: 0 4px 15px var(--accent-glow);
  }
  
  .save-btn:hover {
    transform: translateY(-2px);
    background: var(--accent-hover);
    box-shadow: 0 6px 20px var(--accent-glow);
  }

  .help-text {
    flex: 1;
    color: var(--text-dim);
    line-height: 1.6;
    margin-bottom: var(--space-8);
    font-size: var(--text-base);
  }

  .presenter-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--seg-bg);
    color: var(--text);
    text-decoration: none;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    font-weight: var(--weight-semibold);
    transition: all var(--duration-fast) var(--ease-in-out);
  }

  .presenter-btn:hover {
    background: var(--accent-subtle);
    border-color: var(--accent-text);
    color: var(--accent-text);
    transform: translateY(-2px);
  }
</style>

<script>
  function initOptions() {
    const saveBtn = document.getElementById('saveBtn');
    const inputTid = document.getElementById('inputTid') as HTMLInputElement;
    const inputLang = document.getElementById('inputLang') as HTMLSelectElement;
    if (saveBtn) {
      saveBtn.addEventListener('click', () => {
        const url = new URL(window.location.href);
        url.searchParams.set('tid', inputTid.value);
        url.searchParams.set('lang', inputLang.value);
        window.location.href = url.toString();
      });
    }
  }

  initOptions();
  document.addEventListener('astro:after-swap', initOptions);
</script>
