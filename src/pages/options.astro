---
import MobileLayout from "../layouts/ResponsiveLayout.astro";
import ThemeToggle from "../components/app/ThemeToggle.astro";
import ActionButton from "../components/controls/ActionButton.astro";
import FormField from "../components/controls/FormField.astro";
import SelectInput from "../components/controls/SelectInput.astro";
import TextInput from "../components/controls/TextInput.astro";
import { useTranslations } from "../i18n/ui";
import { DEFAULT_TOURNAMENT, LANGUAGE_OPTIONS } from "../lib/constants";
import { resolvePageLang } from "../lib/page-lang";

const tid = Astro.url.searchParams.get("tid") || DEFAULT_TOURNAMENT;
const lang = resolvePageLang(Astro.url, Astro.cookies);
const mode = Astro.url.searchParams.get("mode") || "";
const navMode = mode === "referee" ? "referee" as const : "default" as const;

const t = useTranslations(lang);
---

<MobileLayout title={t('config.title')} lang={lang} navMode={navMode}>
  <div class="options-grid">
    <div class="options-card">
      <div class="card-header">
        <div class="icon-wrapper">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>
        </div>
        <p class="card-desc">{t('config.subtitle')}</p>
      </div>

      <form class="form-grid" id="optionsForm" method="get">
        {mode && <input type="hidden" name="mode" value={mode} />}

        <FormField label={t('config.tid')} forId="inputTid">
          <TextInput id="inputTid" name="tid" value={tid} placeholder="Tournament ID" />
        </FormField>

        <FormField label={t('config.lang')} forId="inputLang">
          <SelectInput id="inputLang" name="lang">
            {LANGUAGE_OPTIONS.map((option) => (
              <option value={String(option.value)} selected={lang === option.value}>{option.label}</option>
            ))}
          </SelectInput>
        </FormField>

        <FormField label={t('config.appearance')}>
          <ThemeToggle />
        </FormField>

        <div class="actions-row">
          <ActionButton class="save-btn" pill type="submit">
            {t('config.update')}
            <svg slot="icon" viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M12 5l7 7-7 7"></path></svg>
          </ActionButton>
        </div>
      </form>
    </div>

    <div class="options-card secondary-card">
      <div class="card-header">
        <div class="icon-wrapper accent">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="15" rx="2" ry="2"></rect><polyline points="17 2 12 7 7 2"></polyline></svg>
        </div>
        <div>
          <h2>{t('presenter.title')}</h2>
          <p class="card-desc">{t('presenter.description')}</p>
        </div>
      </div>
      <p class="help-text">{t('presenter.help')}</p>
      <ActionButton href={`/present?tid=${tid}&lang=${lang}`} class="presenter-btn" variant="secondary">
        {t('presenter.launch')}
        <svg slot="icon" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
      </ActionButton>
    </div>
  </div>
</MobileLayout>

<style>
  .options-grid {
    display: grid;
    gap: var(--space-8);
    grid-template-columns: 1fr;
    max-width: 800px;
    animation: fadeInUp var(--duration-slow) var(--ease-out) both;
  }

  @media (min-width: 800px) {
    .options-grid {
      grid-template-columns: 1fr 340px;
    }
  }

  .options-card {
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    box-shadow: var(--shadow-elevated);
  }

  .secondary-card {
    background: linear-gradient(180deg, var(--surface) 0%, var(--bg-subtle) 100%);
    border-color: var(--accent-subtle);
    display: flex;
    flex-direction: column;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: var(--space-8);
  }

  .icon-wrapper {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: var(--seg-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
  }

  .icon-wrapper.accent {
    background: var(--accent-subtle);
    color: var(--accent-text);
  }

  h2 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    margin-bottom: 0.2rem;
  }

  .card-desc {
    color: var(--text-dim);
    font-size: var(--text-sm);
    line-height: 1.4;
  }

  .form-grid {
    display: grid;
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .actions-row {
    display: flex;
    justify-content: flex-end;
    padding-top: var(--space-6);
  }

  .help-text {
    flex: 1;
    color: var(--text-dim);
    line-height: 1.6;
    margin-bottom: var(--space-8);
    font-size: var(--text-base);
  }
</style>

<script>
  function initOptions() {
    const form = document.getElementById('optionsForm') as HTMLFormElement | null;
    const inputLang = document.getElementById('inputLang') as HTMLSelectElement | null;

    if (!form || !inputLang || form.dataset.bound === 'true') {
      return;
    }

    form.dataset.bound = 'true';
    form.addEventListener('submit', () => {
        document.cookie = `lang=${inputLang.value};path=/;max-age=${60*60*24*365};samesite=lax`;
    });
  }

  initOptions();
  document.addEventListener('astro:after-swap', initOptions);
</script>
