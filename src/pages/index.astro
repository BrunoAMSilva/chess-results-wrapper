---
import MobileLayout from "../layouts/MobileLayout.astro";
import MobileMatchCard from "../components/MobileMatchCard.astro";
import { scrapePairings } from "../lib/scraper";
import { useTranslations } from "../i18n/ui";
import { DEFAULT_TOURNAMENT } from "../lib/constants";

const tid = Astro.url.searchParams.get("tid") || DEFAULT_TOURNAMENT;
const round = parseInt(Astro.url.searchParams.get("round") || "1");
const lang = parseInt(Astro.url.searchParams.get("lang") || "1");

const t = useTranslations(lang);

let data;
let error: string | null = null;
let allPairings: import("../lib/scraper").Pairing[] = [];

try {
  data = await scrapePairings(tid, round, lang);
  allPairings = data.pairings || [];
} catch (e) {
  error = e instanceof Error ? e.message : t('error.load');
}

const rounds = data ? Array.from({ length: data.info.totalRounds }, (_, i) => i + 1) : [];
---

<MobileLayout title={data?.info.name || t('site.title')} >
  {error && (
    <div class="error-msg">
      <p>{error}</p>
    </div>
  )}

  {data && (
    <div class="mobile-controls">
      <div class="round-nav" id="roundNav">
        {rounds.map((r) => (
          <a
            href={`/?tid=${tid}&round=${r}&lang=${lang}`}
            class={`round-pill ${r === round ? 'active' : ''}`}
            data-round={r}
          >
            {t('header.round')} {r}
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="pairings-list animate-enter" style="animation-delay: 100ms">
    {allPairings.length > 0 ? (
      allPairings.map((pairing: any) => <MobileMatchCard match={pairing}  />)
    ) : (
      <div class="empty-state">
        <p>{t('empty.pairings')}</p>
      </div>
    )}
  </div>
</MobileLayout>

<style>
  .mobile-controls {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
    position: sticky;
    top: 0;
    z-index: 5;
    background: var(--bg);
    padding: 0.5rem 0;
  }
  .round-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 0.5rem 1rem;
    width: 100%;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .round-nav::-webkit-scrollbar {
    display: none;
  }
  .round-pill {
    scroll-snap-align: center;
    flex-shrink: 0;
    padding: 0.5rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    color: var(--text-dim);
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s;
  }
  .round-pill.active {
    background: #fff;
    color: var(--bg);
    border-color: #fff;
    box-shadow: 0 0 15px rgba(255, 255, 255, 0.2);
  }
  .pairings-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(max(25vw, 360px), 1fr));
    gap: 1rem;
    padding-bottom: 2rem;
  }
  .empty-state {
    text-align: center;
    color: var(--text-dim);
    margin-top: 2rem;
  }
</style>

<script>
  // Center active round pill on load
  document.addEventListener('DOMContentLoaded', () => {
    const activePill = document.querySelector('.round-pill.active');
    if (activePill) {
      activePill.scrollIntoView({ behavior: 'auto', block: 'nearest', inline: 'center' });
    }
  });
</script>
