---
import ThemeToggle from "../components/ThemeToggle.astro";
import RecentTournaments from "../components/RecentTournaments.astro";
import { useTranslations } from "../i18n/ui";
import "../styles/global.css";

const langParam = Astro.url.searchParams.get("lang");
const lang = parseInt(langParam || Astro.cookies.get('lang')?.value || "1");
const t = useTranslations(lang);
if (langParam) Astro.cookies.set('lang', langParam, { path: '/', maxAge: 60 * 60 * 24 * 365, sameSite: 'lax', httpOnly: false });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#fcd34d" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <title>{t('home.title')}</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script>
      (function() {
        const stored = (() => { try { return localStorage.getItem('theme'); } catch { return null; } })();
        if (stored === 'light' || stored === 'dark') {
          document.documentElement.setAttribute('data-theme', stored);
        }
      })();
    </script>

    <script src="../scripts/theme.ts"></script>
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>
  </head>
  <body>
    <div class="home-shell">
      <div class="ambient ambient-a"></div>
      <div class="ambient ambient-b"></div>

      <header class="home-topbar">
        <ThemeToggle />
      </header>

      <main class="home-main">
        <div class="home-content animate-enter">
          <div class="home-icon">
            <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M8 2h8l-1 7h3l-5 9v-5H9l-1-11z" fill="var(--accent)" stroke="var(--accent)" opacity="0.85"/>
            </svg>
          </div>
          <h1 class="home-heading">{t('home.heading')}</h1>
          <p class="home-subtitle">{t('home.subtitle')}</p>

          <form class="search-form" id="searchForm">
            <div class="input-wrapper">
              <svg class="input-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
              <input
                type="text"
                id="tournamentInput"
                class="search-input"
                placeholder={t('home.placeholder')}
                autocomplete="off"
                required
                role="combobox"
                aria-expanded="false"
                aria-controls="searchResults"
                aria-autocomplete="list"
                aria-activedescendant=""
              />
              <div class="search-results hidden" id="searchResults" role="listbox" aria-label="Search results">
                <p class="no-results hidden" id="noResults">{t('home.noResults')}</p>
              </div>
              <div class="sr-only" aria-live="polite" aria-atomic="true" id="searchAnnounce"></div>
            </div>
            <button type="submit" class="search-btn">
              {t('home.submit')}
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </button>
          </form>

          <p class="home-hint">{t('home.example')}</p>
          <p class="error-hint hidden" id="errorHint">{t('home.invalid')}</p>

          <RecentTournaments recentLabel={t('home.recent')} />
        </div>
      </main>
    </div>
  </body>
</html>

<style>
  .home-shell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100dvh;
    position: relative;
  }

  .ambient {
    position: fixed;
    pointer-events: none;
    border-radius: 999px;
    filter: blur(80px);
    opacity: 0.35;
    z-index: 0;
  }

  .ambient-a {
    width: 420px;
    height: 420px;
    left: -120px;
    top: -140px;
    background: var(--ambient-a);
  }

  .ambient-b {
    width: 380px;
    height: 380px;
    right: -80px;
    bottom: -140px;
    background: var(--ambient-b);
  }

  .home-topbar {
    position: fixed;
    top: 0;
    right: 0;
    padding: var(--space-4);
    z-index: 10;
  }

  .home-main {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: var(--space-4);
    z-index: 1;
  }

  .home-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 520px;
    width: 100%;
    gap: var(--space-3);
  }

  .home-icon {
    margin-bottom: var(--space-2);
    color: var(--accent);
  }

  .home-heading {
    font-size: var(--text-3xl);
    font-weight: var(--weight-extrabold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--text);
  }

  .home-subtitle {
    font-size: var(--text-base);
    color: var(--text-dim);
    line-height: var(--leading-normal);
    max-width: 420px;
  }

  .search-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    width: 100%;
    margin-top: var(--space-4);
  }

  .input-wrapper {
    position: relative;
    width: 100%;
  }

  .input-icon {
    position: absolute;
    left: var(--space-4);
    top: var(--space-4);
    color: var(--text-muted);
    pointer-events: none;
    z-index: 2;
  }

  .search-input {
    width: 100%;
    padding: var(--space-4) var(--space-4) var(--space-4) var(--space-12);
    font-size: var(--text-base);
    font-family: var(--font-sans);
    color: var(--text);
    background: var(--input-bg);
    border: 1px solid var(--input-border);
    border-radius: var(--radius-lg);
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-in-out),
                box-shadow var(--duration-fast) var(--ease-in-out);
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-input:focus {
    border-color: var(--input-focus);
    box-shadow: 0 0 0 3px var(--input-focus-ring);
  }

  .search-results {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: var(--space-2);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    z-index: 20;
    overflow: hidden;
    max-height: 360px;
    overflow-y: auto;
  }

  .search-results :global(.result-item) {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    text-decoration: none;
    color: var(--text);
    transition: background var(--duration-fast) var(--ease-in-out);
    border-bottom: 1px solid var(--border-light);
    cursor: pointer;
    text-align: left;
  }

  .search-results :global(.result-item:last-child) {
    border-bottom: none;
  }

  .search-results :global(.result-item:hover),
  .search-results :global(.result-item.active) {
    background: var(--surface-hover);
  }

  .search-results :global(.result-icon) {
    flex-shrink: 0;
    color: var(--accent);
  }

  .search-results :global(.result-info) {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .search-results :global(.result-name) {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .search-results :global(.result-meta) {
    font-size: var(--text-xs);
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .search-results :global(.event-pills) {
    display: flex;
    gap: var(--space-1);
    flex-wrap: wrap;
    margin-top: var(--space-1);
  }

  .search-results :global(.event-pill) {
    font-size: var(--text-xs);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    background: var(--surface-hover);
    color: var(--text-dim);
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease-in-out),
                color var(--duration-fast) var(--ease-in-out);
  }

  .search-results :global(.event-pill:hover) {
    background: var(--accent-subtle);
    color: var(--accent-text);
  }

  .search-results :global(.event-pill.current) {
    background: var(--accent-subtle);
    color: var(--accent-text);
    font-weight: var(--weight-semibold);
  }

  .no-results {
    padding: var(--space-4);
    text-align: center;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    width: 100%;
    padding: var(--space-4);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--on-accent);
    background: var(--accent);
    border: none;
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease-in-out),
                box-shadow var(--duration-fast) var(--ease-in-out);
  }

  .search-btn:hover {
    background: var(--accent-hover);
    box-shadow: 0 0 20px var(--accent-glow);
  }

  .home-hint {
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .error-hint {
    font-size: var(--text-sm);
    color: var(--red-400);
    font-weight: var(--weight-medium);
  }

  @media (min-width: 640px) {
    .search-form {
      flex-direction: row;
    }

    .search-btn {
      width: auto;
      white-space: nowrap;
      padding: var(--space-4) var(--space-6);
    }
  }
</style>

<script>
  function initHomepage() {
    const form = document.getElementById('searchForm') as HTMLFormElement | null;
    const input = document.getElementById('tournamentInput') as HTMLInputElement | null;
    const errorHint = document.getElementById('errorHint') as HTMLElement | null;
    const searchResults = document.getElementById('searchResults');
    const noResults = document.getElementById('noResults');
    const announceEl = document.getElementById('searchAnnounce');

    if (!form || !input || !errorHint || !searchResults || !noResults || !announceEl) return;

    let debounceTimer: ReturnType<typeof setTimeout>;
    let activeIndex = -1;
    let currentResults: { id: string; name: string }[] = [];

    // Alias to non-nullable after guard
    const resultsEl = searchResults;
    const noResultsEl = noResults;
    const inputEl = input;
    const announceRegion = announceEl;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const raw = input.value.trim();
      if (!raw) return;

      // If there's an active dropdown item, navigate to it
      if (activeIndex >= 0 && currentResults[activeIndex]) {
        navigateToTournament(currentResults[activeIndex].id);
        return;
      }

      const tid = extractTournamentId(raw);
      if (tid) {
        hideDropdown();
        errorHint.classList.add('hidden');
        navigateToTournament(tid);
      } else {
        errorHint.classList.remove('hidden');
      }
    });

    input.addEventListener('input', () => {
      errorHint.classList.add('hidden');
      const raw = input.value.trim();

      // If it looks like a numeric ID or URL, don't search
      if (!raw || /^\d+$/.test(raw) || raw.includes('chess-results.com')) {
        hideDropdown();
        return;
      }

      if (raw.length < 2) {
        hideDropdown();
        return;
      }

      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => searchTournaments(raw), 300);
    });

    input.addEventListener('keydown', (e) => {
      if (!currentResults.length) return;
      const items = resultsEl.querySelectorAll('.result-item');

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        activeIndex = Math.min(activeIndex + 1, items.length - 1);
        updateActiveItem(items);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        activeIndex = Math.max(activeIndex - 1, -1);
        updateActiveItem(items);
      } else if (e.key === 'Enter' && activeIndex >= 0) {
        e.preventDefault();
        navigateToTournament(currentResults[activeIndex].id);
      } else if (e.key === 'Escape') {
        hideDropdown();
      }
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (!resultsEl.contains(e.target as Node) && e.target !== input) {
        hideDropdown();
      }
    });

    // Re-trigger search if input already has a value (e.g. back navigation)
    const existing = input.value.trim();
    if (existing && existing.length >= 2 && !/^\d+$/.test(existing) && !existing.includes('chess-results.com')) {
      searchTournaments(existing);
    }

    async function searchTournaments(query: string) {
      try {
        const res = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
        if (!res.ok) return;
        const data = await res.json();
        renderResults(data);
      } catch {
        hideDropdown();
      }
    }

    function renderResults(results: { id: string; name: string; total_rounds: number; date: string; location: string; event_label: string; linked_tournaments: string }[]) {
      currentResults = results;
      activeIndex = -1;

      // Remove old items (keep noResults element)
      resultsEl.querySelectorAll('.result-item').forEach(el => el.remove());

      if (results.length === 0) {
        noResultsEl.classList.remove('hidden');
        resultsEl.classList.remove('hidden');
        inputEl.setAttribute('aria-expanded', 'true');
        announceRegion.textContent = 'No results found.';
        return;
      }

      noResultsEl.classList.add('hidden');
      for (const [index, t] of results.entries()) {
        const item = document.createElement('a');
        item.className = 'result-item';
        item.id = `result-item-${index}`;
        item.setAttribute('role', 'option');
        item.setAttribute('aria-selected', 'false');
        item.href = `/pairings?tid=${encodeURIComponent(t.id)}`;

        const meta = [t.date, t.location, `${t.total_rounds} rounds`]
          .filter(Boolean)
          .join(' · ');

        let linkedHtml = '';
        const linked: { id: string; name: string }[] = (() => {
          try { return JSON.parse(t.linked_tournaments || '[]'); } catch { return []; }
        })();
        if (linked.length > 0) {
          const pills = linked
            .sort((a, b) => a.name.localeCompare(b.name))
            .map((lt) =>
              `<span class="event-pill" data-tid="${escapeHtml(lt.id)}">${escapeHtml(lt.name)}</span>`
            ).join('');
          linkedHtml = `<span class="event-pills">${pills}</span>`;
        }

        item.innerHTML = `
          <svg class="result-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 6v6l4 2"></path>
          </svg>
          <span class="result-info">
            <span class="result-name">${escapeHtml(t.name)}</span>
            ${linkedHtml}
            <span class="result-meta">${escapeHtml(meta)}</span>
          </span>
        `;

        // Handle clicks on event pills to navigate to that specific tournament
        item.querySelectorAll('.event-pill').forEach((pill) => {
          pill.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            const pillTid = (pill as HTMLElement).dataset.tid;
            if (pillTid) navigateToTournament(pillTid);
          });
        });

        item.addEventListener('click', (e) => {
          e.preventDefault();
          navigateToTournament(t.id);
        });

        resultsEl.appendChild(item);
      }

      resultsEl.classList.remove('hidden');
      inputEl.setAttribute('aria-expanded', 'true');
      announceRegion.textContent = `${results.length} result${results.length === 1 ? '' : 's'} available.`;
    }

    function updateActiveItem(items: NodeListOf<Element>) {
      items.forEach((el, i) => {
        const isActive = i === activeIndex;
        el.classList.toggle('active', isActive);
        el.setAttribute('aria-selected', String(isActive));
      });
      inputEl.setAttribute('aria-activedescendant', activeIndex >= 0 ? `result-item-${activeIndex}` : '');
    }

    function hideDropdown() {
      resultsEl.classList.add('hidden');
      inputEl.setAttribute('aria-expanded', 'false');
      inputEl.setAttribute('aria-activedescendant', '');
      currentResults = [];
      activeIndex = -1;
    }

    function navigateToTournament(tid: string) {
      // Save to recent tournaments
      const match = currentResults.find(r => r.id === tid);
      const entry = match as { id: string; name: string; date?: string } | undefined;
      saveRecentTournament(tid, entry?.name, (entry as any)?.date);

      const langMatch = document.cookie.match(/(?:^|;\s*)lang=([^;]*)/);
      const savedLang = langMatch ? langMatch[1] : null;
      const params = new URLSearchParams({ tid });
      if (savedLang) params.set('lang', savedLang);
      window.location.href = `/pairings?${params.toString()}`;
    }
  }

  function extractTournamentId(input: string): string | null {
    if (/^\d+$/.test(input)) return input;
    const urlMatch = input.match(/chess-results\.com\/tnr(\d+)\.aspx/i);
    if (urlMatch) return urlMatch[1];
    return null;
  }

  function saveRecentTournament(tid: string, name?: string, date?: string) {
    try {
      const key = 'recentTournaments';
      const stored = localStorage.getItem(key);
      let recent: { id: string; name: string; date: string }[] = stored ? JSON.parse(stored) : [];
      recent = recent.filter(r => r.id !== tid);
      recent.unshift({ id: tid, name: name || `Tournament ${tid}`, date: date || '' });
      recent = recent.slice(0, 5);
      localStorage.setItem(key, JSON.stringify(recent));
    } catch { /* localStorage unavailable */ }
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  document.addEventListener('DOMContentLoaded', initHomepage);
  document.addEventListener('astro:after-swap', initHomepage);
</script>
