---
import RecentTournaments from "../components/tournaments/RecentTournaments.astro";
import TournamentCard from "../components/tournaments/TournamentCard.astro";
import TournamentSearchForm from "../components/tournaments/TournamentSearchForm.astro";
import { languages, useTranslations } from "../i18n/ui";
import { resolvePageLang } from "../lib/page-lang";
import { countTournaments, listTournaments } from "../lib/db";
import "../styles/global.css";

const lang = resolvePageLang(Astro.url, Astro.cookies);
const t = useTranslations(lang);
const langCode = languages[lang as keyof typeof languages] || "en";
const discoverExpanded = Astro.url.searchParams.get("discover") === "all";
const discoverLimit = discoverExpanded ? 24 : 3;
const discoverOffset = 0;
const discoverRows = listTournaments(discoverLimit, discoverOffset);
const discoverTotal = countTournaments();
const discoverHasMore = discoverTotal > discoverRows.length;
const discoverBase = `/?lang=${lang}`;
const discoverMoreHref = `${discoverBase}&discover=all`;
const discoverLessHref = `${discoverBase}`;
const shouldRegisterServiceWorker = import.meta.env.PROD;
---

<!doctype html>
<html lang={langCode}>
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#fcd34d" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{t("home.title")}</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script is:inline define:vars={{ shouldRegisterServiceWorker }}>
      const devServiceWorkerResetKey = 'dev-service-worker-reset';

      if ("serviceWorker" in navigator && !shouldRegisterServiceWorker) {
        const hadController = Boolean(navigator.serviceWorker.controller);
        const alreadyReset = sessionStorage.getItem(devServiceWorkerResetKey) === '1';

        Promise.all([
          navigator.serviceWorker.getRegistrations().then((registrations) => {
            registrations.forEach((registration) => {
              registration.unregister();
            });
          }),
          "caches" in window
            ? caches.keys().then((keys) => {
                keys.forEach((key) => caches.delete(key));
              })
            : Promise.resolve(),
        ]).finally(() => {
          if (hadController && !alreadyReset) {
            sessionStorage.setItem(devServiceWorkerResetKey, '1');
            location.reload();
            return;
          }

          sessionStorage.removeItem(devServiceWorkerResetKey);
        });
      }
    </script>
    <script>
      (function () {
        const stored = (() => {
          try {
            return localStorage.getItem("theme");
          } catch {
            return null;
          }
        })();
        if (stored === "light" || stored === "dark") {
          document.documentElement.setAttribute("data-theme", stored);
        }
      })();
    </script>

    <script src="../scripts/theme.ts"></script>
    <script is:inline define:vars={{ shouldRegisterServiceWorker }}>
      if ("serviceWorker" in navigator) {
        if (shouldRegisterServiceWorker) {
          navigator.serviceWorker.register("/sw.js");
        }
      }
    </script>
  </head>
  <body>
    <div class="home-shell">
      <a class="skip-link" href="#maincontent">{t("a11y.skipToMain")}</a>
      <header class="home-header">
        <div class="home-icon">
          <img src="logo.svg" alt="" width="128" height="128" />
        </div>
        <h1 class="home-heading">{t("home.heading")}</h1>
        <p class="home-subtitle">{t("home.subtitle")}</p>
      </header>
      <main id="maincontent" class="home-main" tabindex="-1">
        <div class="home-content animate-enter">
          <TournamentSearchForm
            label={t("nav.search")}
            placeholder={t("home.placeholder")}
            submitLabel={t("home.submit")}
            hint={t("home.example")}
            invalidMessage={t("home.invalid")}
            loadingMessage={t("home.loading")}
            noResultsMessage={t("home.noResults")}
            lang={String(lang)}
          />

          <RecentTournaments recentLabel={t("home.recent")} />

          <section class="discover-section">
            <h2 class="discover-title">{t("discover.title")}</h2>
            {
              discoverRows.length > 0 ? (
                <div class="discover-list">
                  {discoverRows.map((item) => (
                    <TournamentCard
                      name={item.name}
                      href={`/standings?tid=${item.id}&lang=${lang}`}
                      date={item.date || undefined}
                      location={item.location || undefined}
                      type={item.type}
                      playerCount={item.player_count}
                    />
                  ))}
                </div>
              ) : (
                <div class="discover-empty">{t("discover.noResults")}</div>
              )
            }

            {
              (discoverHasMore || discoverExpanded) && (
                <div class="discover-more-row">
                  {discoverExpanded ? (
                    <a class="discover-more-link" href={discoverLessHref}>
                      {t("discover.viewLess")}
                    </a>
                  ) : (
                    <a class="discover-more-link" href={discoverMoreHref}>
                      {t("discover.viewMore")}
                    </a>
                  )}
                </div>
              )
            }
          </section>
        </div>
      </main>
    </div>
  </body>
</html>

<style>
  .home-shell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    min-height: 100vh;
    position: relative;
    padding: var(--space-8) var(--space-4);
  }

  .home-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding-block: var(--space-12);
    text-align: center;
  }

  .home-main {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    width: 100%;
    padding: 0;
    z-index: 1;
  }

  .home-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 520px;
    width: 100%;
    gap: var(--space-2);
  }

  .home-icon {
    margin-bottom: var(--space-1);
    color: var(--accent);
  }

  .home-heading {
    font-size: var(--text-3xl);
    font-weight: var(--weight-extrabold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--text);
    text-align: center;
  }

  .home-subtitle {
    font-size: var(--text-base);
    color: var(--text-dim);
    line-height: var(--leading-normal);
    max-width: 460px;
    text-align: center;
  }

  .discover-section {
    width: 100%;
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    text-align: left;
  }

  .discover-title {
    font-size: var(--text-xl);
    color: var(--text);
    font-weight: var(--weight-semibold);
    text-align: left;
    margin-bottom: var(--space-3);
  }

  .discover-form {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .discover-input {
    flex: 1;
    border-radius: var(--radius-md);
    border: 1px solid var(--outline-variant);
    background: var(--input-bg);
    color: var(--text);
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
  }

  .discover-btn {
    border-radius: var(--radius-md);
    background: var(--surface);
    color: var(--text);
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    cursor: pointer;
  }

  .discover-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .discover-list :global(.tournament-card) {
    min-width: 0;
    align-self: stretch;
  }

  .discover-empty {
    color: var(--text-dim);
    text-align: center;
    padding: var(--space-6);
  }

  .discover-more-row {
    display: flex;
    justify-content: center;
  }

  .discover-more-link {
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-4);
    color: var(--text);
    background: var(--surface);
    text-decoration: none;
    font-size: var(--text-sm);
  }
</style>
