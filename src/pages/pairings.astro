---
import ResponsiveLayout from "../layouts/ResponsiveLayout.astro";
import ResponsiveMatchCard from "../components/ResponsiveMatchCard.astro";
import TeamMatchGroup from "../components/TeamMatchGroup.astro";
import RoundSelector from "../components/RoundSelector.astro";
import TournamentSelector from "../components/TournamentSelector.astro";
import { scrapePairings } from "../lib/scraper";
import { useTranslations } from "../i18n/ui";
import { DEFAULT_TOURNAMENT } from "../lib/constants";
import { getIntParam } from "../lib/request-params";
import { resolvePageLang } from "../lib/page-lang";
import type { Pairing, TeamPairing } from "../lib/types";

const tid = Astro.url.searchParams.get("tid") || DEFAULT_TOURNAMENT;
const round = getIntParam(Astro.url.searchParams.get("round"), 1, 1, 64);
const lang = resolvePageLang(Astro.url, Astro.cookies);

const t = useTranslations(lang);

let data;
let error: string | null = null;
let allPairings: Pairing[] = [];
let teamPairings: TeamPairing[] | undefined;

try {
  data = await scrapePairings(tid, round, lang);
  allPairings = data.pairings || [];
  teamPairings = data.teamPairings;
} catch (e) {
  error = e instanceof Error ? e.message : t('error.load');
}

const isTeamView = teamPairings && teamPairings.length > 0;
const rounds = data ? Array.from({ length: data.info.totalRounds }, (_, i) => i + 1) : [];
const linkedTournaments = data?.info.linkedTournaments;
---

<ResponsiveLayout title={data?.info.name || t('site.title')} lang={lang}>
  {error && (
    <div class="error-msg">
      <p>{error}</p>
    </div>
  )}

<div class="controls">
  {linkedTournaments && linkedTournaments.length > 0 && (
    <TournamentSelector
      class="tournament-controls"
      currentId={tid}
      currentLabel={data!.info.currentLabel || data!.info.name}
      linkedTournaments={linkedTournaments}
      lang={lang}
    />
  )}

  {data && (
      <RoundSelector
        rounds={rounds}
        activeRound={round}
        baseUrl={`/pairings?tid=${tid}&lang=${lang}`}
        label={t('header.round')}
      />
  )}</div>

  <div class:list={["pairings-list", "animate-enter", "delay-2"]}>
    {isTeamView ? (
      teamPairings!.map((teamMatch) => (
        <TeamMatchGroup teamMatch={teamMatch} tid={tid} lang={lang} />
      ))
    ) : allPairings.length > 0 ? (
      allPairings.map((pairing) => <ResponsiveMatchCard match={pairing} tid={tid} lang={lang} />)
    ) : (
      <div class="empty-state">
        <p>{t('empty.pairings')}</p>
      </div>
    )}
  </div>
</ResponsiveLayout>

<style>
  .mobile-controls {
    position: sticky;
    top: 0;
    z-index: 5;
    background: var(--bg);
    padding: var(--space-2) 0;
    margin-bottom: var(--space-4);
  }

  .controls {
    display: flex;
    flex-direction: row;
    gap: var(--space-4);
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    min-width: 0;
  }

  :global(.tournament-controls) {
    margin-block-end: var(--space-4);
    flex: 1 1 auto;
    min-width: 0;
  }
  .pairings-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    padding-bottom: var(--space-8);
  }

  .delay-2 {
    animation-delay: 80ms;
  }

  @media (min-width: 768px) {
    .pairings-list {
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    }
  }
  .empty-state {
    text-align: center;
    color: var(--text-dim);
    margin-top: var(--space-8);
  }
</style>

<script is:inline define:vars={{ tid, tournamentName: data?.info.name || '', tournamentDate: data?.info.date || '' }}>
  (function() {
    try {
      if (!tid || !tournamentName) return;
      var key = 'recentTournaments';
      var stored = localStorage.getItem(key);
      var recent = stored ? JSON.parse(stored) : [];
      recent = recent.filter(function(r) { return r.id !== tid; });
      recent.unshift({ id: tid, name: tournamentName, date: tournamentDate });
      recent = recent.slice(0, 5);
      localStorage.setItem(key, JSON.stringify(recent));
    } catch(e) { /* localStorage unavailable */ }
  })();
</script>


