---
import ResponsiveLayout from "../layouts/ResponsiveLayout.astro";
import EmptyState from "../components/app/EmptyState.astro";
import ResponsiveMatchCard from "../components/pairings/ResponsiveMatchCard.astro";
import TeamMatchGroup from "../components/pairings/TeamMatchGroup.astro";
import StandingRow from "../components/standings/StandingRow.astro";
import RoundSelector from "../components/controls/RoundSelector.astro";
import TournamentSelector from "../components/tournaments/TournamentSelector.astro";
import TrackRecentTournament from "../components/tournaments/TrackRecentTournament.astro";
import { scrapePairings, scrapeStandings } from "../lib/scraper";
import { useTranslations } from "../i18n/ui";
import {
  extractPageParams,
  resolveTournamentDisplay,
  resolveTournamentName,
  loadPlayerTitleMap,
} from "../lib/page-context";
import { isRealPairing } from "../lib/pairing-utils";
import type { Pairing, TeamPairing } from "../lib/types";
import type { Standing } from "../lib/scraper";

const { tid, lang, round } = extractPageParams(Astro.url, Astro.cookies);

const t = useTranslations(lang);

let data;
let error: string | null = null;
let allPairings: Pairing[] = [];
let teamPairings: TeamPairing[] | undefined;

try {
  data = await scrapePairings(tid, round);
  allPairings = (data.pairings || []).filter(isRealPairing);
  teamPairings = data.teamPairings;
} catch (e) {
  error = e instanceof Error ? e.message : t('error.load');
}

let playerList: Standing[] = [];
const isTeamView = teamPairings && teamPairings.length > 0;
if (!isTeamView && allPairings.length === 0 && !error) {
  try {
    const standingsData = await scrapeStandings(tid);
    playerList = standingsData.standings;
  } catch (_) { /* ignore - show empty state */ }
}

const tournamentName = resolveTournamentName(data, tid);
const titleMap = loadPlayerTitleMap(tid);

const rounds = data ? Array.from({ length: data.info.totalRounds }, (_, i) => i + 1) : [];
const linkedTournaments = data?.info.linkedTournaments;
const { sectionTitle, eyebrow: tournamentEyebrow } = resolveTournamentDisplay(data?.info, t('site.title'));
const recentPlayerCount = !isTeamView
  ? new Set(
      allPairings
        .flatMap((pairing) => [pairing.white.name, pairing.black?.name])
        .filter((name): name is string => typeof name === 'string' && name.length > 0)
        .filter((name) => !/^(bye|livre)$/i.test(name))
    ).size
  : 0;
---

<ResponsiveLayout title={sectionTitle} eyebrow={tournamentEyebrow} lang={lang}>
  {error && (
    <div class="error-msg">
      <p>{error}</p>
    </div>
  )}

<div class="controls">
  {linkedTournaments && linkedTournaments.length > 0 && (
    <TournamentSelector
      class="tournament-controls"
      currentId={tid}
      currentLabel={data!.info.currentLabel || data!.info.name}
      linkedTournaments={linkedTournaments}
      lang={lang}
    />
  )}

  {data && (
      <RoundSelector
        rounds={rounds}
        activeRound={round}
        baseUrl={`/pairings?tid=${tid}&lang=${lang}`}
        label={t('header.round')}
      />
  )}</div>

  <div class:list={["pairings-list", "animate-enter", "delay-2"]}>
    {isTeamView ? (
      teamPairings!.map((teamMatch) => (
        <TeamMatchGroup teamMatch={teamMatch} tid={tid} lang={lang} titleMap={titleMap} />
      ))
    ) : allPairings.length > 0 ? (
      allPairings.map((pairing) => <ResponsiveMatchCard match={pairing} tid={tid} lang={lang} titleMap={titleMap} />)
    ) : playerList.length > 0 ? (
      <div class="standings-list">
        {playerList.map((standing, i) => (
          <StandingRow standing={standing} index={i} lang={lang} tid={tid} hideStats />
        ))}
      </div>
    ) : (
      <EmptyState message={t('empty.pairings')} compact />
    )}
  </div>
</ResponsiveLayout>

<style>
  .mobile-controls {
    position: sticky;
    top: 0;
    z-index: 5;
    background: var(--bg);
    padding: var(--space-2) 0;
    margin-bottom: var(--space-4);
  }

  .controls {
    display: flex;
    flex-direction: row;
    gap: var(--space-4);
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    min-width: 0;
  }

  :global(.tournament-controls) {
    margin-block-end: var(--space-4);
    flex: 1 1 auto;
    min-width: 0;
  }
  .pairings-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    padding-bottom: var(--space-8);
  }

  .standings-list {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border-radius: var(--radius-md);
    overflow: hidden;
    grid-column: 1 / -1;
  }

  .delay-2 {
    animation-delay: 80ms;
  }

  @media (min-width: 768px) {
    .pairings-list {
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    }
  }
</style>

<TrackRecentTournament
  tid={tid}
  name={tournamentName}
  type={data?.info.type || ''}
  date={data?.info.date || ''}
  location={data?.info.location || ''}
  playerCount={recentPlayerCount}
/>
