---
import MobileLayout from "../layouts/MobileLayout.astro";
import StandingRow from "../components/StandingRow.astro";
import SegmentedControl from "../components/SegmentedControl.astro";
import { scrapeStandings } from "../lib/scraper";
import { useTranslations } from "../i18n/ui";
import { DEFAULT_TOURNAMENT } from "../lib/constants";

const tid = Astro.url.searchParams.get("tid") || DEFAULT_TOURNAMENT;
const lang = parseInt(Astro.url.searchParams.get("lang") || "1");

const t = useTranslations(lang);

let data;
let error: string | null = null;

try {
  data = await scrapeStandings(tid, lang);
} catch (e) {
  error = e instanceof Error ? e.message : t('error.load');
}

const allStandings = data?.standings || [];
const womenStandings = data?.womenStandings || [];
const hasWomen = womenStandings.length > 0;
---

<MobileLayout title={data?.info.name || t('site.title')} lang={lang}>
  {error && (
    <div class="error-msg">
      <p>{error}</p>
    </div>
  )}

  {hasWomen && (
    <div class="standings-seg-wrapper">
      <SegmentedControl
        name="standings"
        segments={[
          { value: "open", label: t('standings.open') },
          { value: "women", label: t('standings.women') },
        ]}
        active="open"
      />
    </div>
  )}

  <div class="standings-list" id="openStandingsList">
    {allStandings.length > 0 ? (
      allStandings.map((standing: any, i: number) => (
        <StandingRow standing={standing} index={i} lang={lang} />
      ))
    ) : (
      !error && <div class="empty-state"><p>No standings available</p></div>
    )}
  </div>

  {hasWomen && (
    <div class="standings-list hidden" id="womenStandingsList">
      {womenStandings.map((standing: any, i: number) => (
        <StandingRow standing={standing} index={i} lang={lang} />
      ))}
    </div>
  )}
</MobileLayout>

<style>
  .standings-seg-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-4);
    position: sticky;
    top: 55px;
    z-index: 5;
    padding: var(--space-1) 0;
  }

  .standings-seg-wrapper :global(.seg-control) {
    width: 100%;
    max-width: 360px;
  }

  .standings-list {
    display: flex;
    flex-direction: column;
    padding-bottom: var(--space-8);
    background: var(--surface);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .standings-list.hidden {
    display: none;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-8);
    color: var(--text-dim);
  }
</style>

<script>
  function initStandingsTabs() {
    const wrapper = document.querySelector('[data-seg-control="standings"]');
    if (!wrapper) return;

    const openList = document.getElementById('openStandingsList');
    const womenList = document.getElementById('womenStandingsList');

    wrapper.addEventListener('segmented-change', ((e: CustomEvent) => {
      if (e.detail.value === 'open') {
        openList?.classList.remove('hidden');
        womenList?.classList.add('hidden');
      } else {
        openList?.classList.add('hidden');
        womenList?.classList.remove('hidden');
      }
    }) as EventListener);
  }

  initStandingsTabs();
  document.addEventListener('astro:after-swap', initStandingsTabs);
</script>