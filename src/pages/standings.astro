---
import MobileLayout from "../layouts/ResponsiveLayout.astro";
import StandingRow from "../components/StandingRow.astro";
import TeamStandingRow from "../components/TeamStandingRow.astro";
import SegmentedControl from "../components/SegmentedControl.astro";
import TournamentSelector from "../components/TournamentSelector.astro";
import { scrapeStandings } from "../lib/scraper";
import { useTranslations } from "../i18n/ui";
import { DEFAULT_TOURNAMENT } from "../lib/constants";
import { resolvePageLang } from "../lib/page-lang";

const tid = Astro.url.searchParams.get("tid") || DEFAULT_TOURNAMENT;
const lang = resolvePageLang(Astro.url, Astro.cookies);

const t = useTranslations(lang);

let data;
let error: string | null = null;

try {
  data = await scrapeStandings(tid, lang);
} catch (e) {
  error = e instanceof Error ? e.message : t("error.load");
}

const allStandings = data?.standings || [];
const womenStandings = data?.womenStandings || [];
const teamStandings = data?.teamStandings || [];
const hasWomen = womenStandings.length > 0;
const hasTeams = teamStandings.length > 0;
const linkedTournaments = data?.info.linkedTournaments;

// Build segments for the segmented control
const segments: { value: string; label: string }[] = [];
if (hasTeams) {
  segments.push({ value: "teams", label: t("standings.teams") });
  segments.push({ value: "open", label: t("standings.players") });
} else {
  segments.push({ value: "open", label: t("standings.open") });
}
if (hasWomen) {
  segments.push({ value: "women", label: t("standings.women") });
}
const defaultActive = hasTeams ? "teams" : "open";
---

<MobileLayout title={data?.info.name || t("site.title")} lang={lang}>
  {
    error && (
      <div class="error-msg">
        <p>{error}</p>
      </div>
    )
  }

  <div class="standings-seg-wrapper">
    {
      linkedTournaments && linkedTournaments.length > 0 && (
        <TournamentSelector
          currentId={tid}
          currentLabel={data!.info.currentLabel || data!.info.name}
          linkedTournaments={linkedTournaments}
          lang={lang}
        />
      )
    }
    {
      segments.length > 1 && (
        <SegmentedControl
          name="standings"
          segments={segments}
          active={defaultActive}
        />
      )
    }
  </div>

  {
    hasTeams && (
      <div class="standings-list" id="teamStandingsList">
        {teamStandings.map((team, i) => (
          <TeamStandingRow team={team} index={i} lang={lang} />
        ))}
      </div>
    )
  }

  <div class:list={["standings-list", { hidden: hasTeams }]} id="openStandingsList">
    {
      allStandings.length > 0
        ? allStandings.map((standing, i: number) => (
            <StandingRow standing={standing} index={i} lang={lang} tid={tid} />
          ))
        : !error && (
            <div class="empty-state">
              <p>{t('empty.standings')}</p>
            </div>
          )
    }
  </div>

  {
    hasWomen && (
      <div class="standings-list hidden" id="womenStandingsList">
        {womenStandings.map((standing, i: number) => (
          <StandingRow standing={standing} index={i} lang={lang} tid={tid} />
        ))}
      </div>
    )
  }
</MobileLayout>

<style>
  .standings-seg-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
    z-index: 5;
    padding-block-end: var(--space-4);
    min-width: 0;
  }

  .standings-seg-wrapper :global(.tournament-selector-wrapper) {
    flex: 1 1 auto;
    min-width: 0;
  }

  .standings-seg-wrapper :global(.seg-control) {
    width: 100%;
    max-width: 360px;
  }

  .standings-list {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .standings-list.hidden {
    display: none;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-8);
    color: var(--text-dim);
  }
</style>

<script>
  function initStandingsTabs() {
    const wrapper = document.querySelector('[data-seg-control="standings"]');
    if (!wrapper) return;

    const teamList = document.getElementById("teamStandingsList");
    const openList = document.getElementById("openStandingsList");
    const womenList = document.getElementById("womenStandingsList");

    wrapper.addEventListener("segmented-change", ((e: CustomEvent) => {
      const val = e.detail.value;
      teamList?.classList.toggle("hidden", val !== "teams");
      openList?.classList.toggle("hidden", val !== "open");
      womenList?.classList.toggle("hidden", val !== "women");
    }) as EventListener);
  }

  initStandingsTabs();
  document.addEventListener("astro:after-swap", initStandingsTabs);
</script>

<script
  is:inline
  define:vars={{
    tid,
    tournamentName: data?.info.name || "",
    tournamentDate: data?.info.date || "",
  }}
>
  (function () {
    try {
      if (!tid || !tournamentName) return;
      var key = "recentTournaments";
      var stored = localStorage.getItem(key);
      var recent = stored ? JSON.parse(stored) : [];
      recent = recent.filter(function (r) {
        return r.id !== tid;
      });
      recent.unshift({ id: tid, name: tournamentName, date: tournamentDate });
      recent = recent.slice(0, 5);
      localStorage.setItem(key, JSON.stringify(recent));
    } catch (e) {
      /* localStorage unavailable */
    }
  })();
</script>
