---
import MobileLayout from "../layouts/MobileLayout.astro";
import StandingRow from "../components/StandingRow.astro";
import { scrapeStandings } from "../lib/scraper";
import { useTranslations } from "../i18n/ui";
import { DEFAULT_TOURNAMENT } from "../lib/constants";

const tid = Astro.url.searchParams.get("tid") || DEFAULT_TOURNAMENT;
const lang = parseInt(Astro.url.searchParams.get("lang") || "1");

const t = useTranslations(lang);

let data;
let error: string | null = null;

try {
  data = await scrapeStandings(tid, lang);
} catch (e) {
  error = e instanceof Error ? e.message : t('error.load');
}

const allStandings = data?.standings || [];
const womenStandings = data?.womenStandings || [];
const hasWomen = womenStandings.length > 0;
---

<MobileLayout title={data?.info.name || t('site.title')} lang={lang}>
  {error && (
    <div class="error-msg">
      <p>{error}</p>
    </div>
  )}

  {hasWomen && (
    <div class="standings-mobile-tabs" id="mobileStandingsTabs">
      <button class="mobile-tab active" data-tab="open">{t('standings.open')}</button>
      <button class="mobile-tab" data-tab="women">{t('standings.women')}</button>
    </div>
  )}

  <div class="standings-list" id="openStandingsList">
    {allStandings.length > 0 ? (
      allStandings.map((standing: any, i: number) => (
        <StandingRow standing={standing} index={i} lang={lang} />
      ))
    ) : (
      !error && <div class="empty-state"><p>No standings available</p></div>
    )}
  </div>

  {hasWomen && (
    <div class="standings-list hidden" id="womenStandingsList">
      {womenStandings.map((standing: any, i: number) => (
        <StandingRow standing={standing} index={i} lang={lang} />
      ))}
    </div>
  )}
</MobileLayout>

<style>
  .standings-mobile-tabs {
    display: flex;
    background: var(--surface);
    border-radius: 8px;
    padding: 0.25rem;
    margin-bottom: 1rem;
    position: sticky;
    top: 55px;
    z-index: 5;
  }
  .mobile-tab {
    flex: 1;
    text-align: center;
    padding: 0.5rem;
    border-radius: 6px;
    border: none;
    background: none;
    color: var(--text-dim);
    font-weight: 600;
    cursor: pointer;
  }
  .mobile-tab.active {
  background: rgba(255, 255, 255, 0.1);
  color: var(--text);
  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.15);
}
  .standings-list {
    display: flex;
    flex-direction: column;
    padding-bottom: 2rem;
    background: var(--surface);
    border-radius: 8px;
    overflow: hidden;
  }
  .standings-list.hidden {
    display: none;
  }
  .standings-header {
    display: none;
  }
  .empty-state {
    text-align: center;
    padding: 2rem;
    color: var(--text-dim);
  }
</style>

<script>
  const tabs = document.querySelectorAll('.mobile-tab');
  const openList = document.getElementById('openStandingsList');
  const womenList = document.getElementById('womenStandingsList');

  tabs.forEach(tab => {
    tab.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      tabs.forEach(t => t.classList.remove('active'));
      target.classList.add('active');

      if (target.dataset.tab === 'open') {
        openList?.classList.remove('hidden');
        womenList?.classList.add('hidden');
      } else {
        openList?.classList.add('hidden');
        womenList?.classList.remove('hidden');
      }
    });
  });
</script>