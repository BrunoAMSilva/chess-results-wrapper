---
import ResponsiveLayout from "../../layouts/ResponsiveLayout.astro";
import { resolvePageLang } from "../../lib/page-lang";
import { DEFAULT_TOURNAMENT } from "../../lib/constants";

const lang = resolvePageLang(Astro.url, Astro.cookies);
const user = Astro.locals.user;
---

<ResponsiveLayout title="Admin" lang={lang} navMode="none">
  <div class="admin-shell">
    <header class="admin-header">
      <p class="admin-eyebrow">Control Panel</p>
      <h1 class="admin-title">Admin</h1>
      {user && <p class="admin-user">{user.email}</p>}
    </header>

    <div class="tool-grid">
      <a href="/admin/player-photos" class="tool-card">
        <div class="tool-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
            <circle cx="12" cy="13" r="4"/>
          </svg>
        </div>
        <div class="tool-body">
          <h2 class="tool-name">Player Photos</h2>
          <p class="tool-desc">Upload or remove a player photo by FIDE ID or national ID.</p>
        </div>
        <svg class="tool-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>

      <a href="/admin/rescrape" class="tool-card">
        <div class="tool-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <polyline points="23 4 23 10 17 10"/>
            <polyline points="1 20 1 14 7 14"/>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
          </svg>
        </div>
        <div class="tool-body">
          <h2 class="tool-name">Refresh Tournament</h2>
          <p class="tool-desc">Re-scrape a tournament's starting rank list to fill in missing FIDE IDs, ratings, and birth years.</p>
        </div>
        <svg class="tool-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>

      <form action="/present/winners" method="get" class="tool-card tool-card--form">
        <div class="tool-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M6 9H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V11a2 2 0 0 0-2-2h-2"/>
            <path d="M6 5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2"/>
            <path d="M12 8v4"/>
            <path d="M9 11l3-3 3 3"/>
          </svg>
        </div>
        <div class="tool-body">
          <h2 class="tool-name">Winners Presentation</h2>
          <p class="tool-desc">Display tournament winners one at a time with animated cards. Perfect for live ceremonies.</p>
          <div class="tool-form-row">
            <label class="tool-label" for="winners-tid">Tournament ID</label>
            <input
              class="tool-input"
              type="text"
              id="winners-tid"
              name="tid"
              value={DEFAULT_TOURNAMENT}
              placeholder="e.g. 1356759"
              required
            />
            <label class="tool-label" for="winners-rank">From rank</label>
            <input
              class="tool-input tool-input--narrow"
              type="number"
              id="winners-rank"
              name="startRank"
              value="3"
              min="1"
            />
            <input type="hidden" name="lang" value="1" />
            <button type="submit" class="tool-btn">Launch</button>
          </div>
        </div>
      </form>
    </div>
  </div>
</ResponsiveLayout>

<style>
  .admin-shell {
    max-width: 600px;
    margin: var(--space-12) auto;
    padding: 0 var(--space-4);
  }

  .admin-header {
    margin-bottom: var(--space-10);
  }

  .admin-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--accent-text);
    margin: 0 0 var(--space-2);
  }

  .admin-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--weight-extrabold);
    color: var(--text);
    margin: 0 0 var(--space-2);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
  }

  .admin-user {
    font-size: var(--text-sm);
    color: var(--text-dim);
    margin: 0;
  }

  .tool-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .tool-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5);
    border-radius: var(--radius-xl);
    background: var(--surface-container-low);
    text-decoration: none;
    color: inherit;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .tool-card:hover {
    background: var(--surface-container-high);
  }

  .tool-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-lg);
    background: var(--accent-subtle);
    color: var(--accent-text);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tool-body {
    flex: 1;
    min-width: 0;
  }

  .tool-name {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    margin: 0 0 var(--space-1);
    color: var(--text);
  }

  .tool-desc {
    font-size: var(--text-sm);
    color: var(--text-dim);
    margin: 0;
    line-height: var(--leading-normal);
  }

  .tool-arrow {
    flex-shrink: 0;
    color: var(--text-muted);
  }

  /* ── Form variant of tool card ── */
  .tool-card--form {
    cursor: default;
  }

  .tool-card--form:hover {
    background: var(--surface-container-low);
  }

  .tool-form-row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }

  .tool-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    white-space: nowrap;
  }

  .tool-input {
    flex: 1;
    min-width: 0;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text);
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .tool-input:focus {
    border-color: var(--accent);
  }

  .tool-input--narrow {
    flex: 0 0 3.5rem;
    text-align: center;
  }

  .tool-btn {
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    border: none;
    background: var(--accent);
    color: var(--on-accent);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    cursor: pointer;
    white-space: nowrap;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .tool-btn:hover {
    background: var(--accent-hover);
  }
</style>
