---
import ResponsiveLayout from "../../layouts/ResponsiveLayout.astro";
import FormField from "../../components/controls/FormField.astro";
import TextInput from "../../components/controls/TextInput.astro";
import ActionButton from "../../components/controls/ActionButton.astro";
import { resolvePageLang } from "../../lib/page-lang";

const lang = resolvePageLang(Astro.url, Astro.cookies);
const prefillTid = Astro.url.searchParams.get("tid") ?? "";
---

<ResponsiveLayout title="Admin – Refresh Tournament" lang={lang} navMode="none">
  <div class="admin-shell">
    <header class="admin-header">
      <a href="/admin" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        Admin
      </a>
      <p class="admin-eyebrow">Tournament Management</p>
      <h1 class="admin-title">Refresh Tournament</h1>
      <p class="admin-desc">
        Fetches the starting rank list (<code>art=0</code>) and player cards (<code>art=9</code>)
        from chess-results.com to fill in missing FIDE IDs, national IDs, ratings, and birth years.
        Safe to run at any time — only updates players, never overwrites standings.
      </p>
    </header>

    <form id="rescrape-form" class="rescrape-form" novalidate>
      <FormField label="Tournament ID" forId="tid">
        <TextInput
          id="tid"
          name="tid"
          placeholder="e.g. 1356759"
          value={prefillTid}
          autocomplete="off"
          inputmode="numeric"
          required
        />
      </FormField>

      <div id="status-msg" class="status-msg" role="status" aria-live="polite"></div>

      <div class="form-actions">
        <ActionButton id="submit-btn" type="submit">Refresh players</ActionButton>
      </div>
    </form>

    <p class="admin-hint">
      Also runs automatically the first time a round-0 tournament page is visited.
    </p>
  </div>

  <script>
    const form = document.getElementById("rescrape-form") as HTMLFormElement;
    const tidInput = document.getElementById("tid") as HTMLInputElement;
    const statusMsg = document.getElementById("status-msg") as HTMLDivElement;
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

    function showStatus(msg: string, kind: "success" | "error" | "info") {
      statusMsg.textContent = msg;
      statusMsg.className = `status-msg status-msg--${kind}`;
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const tid = tidInput.value.trim();
      if (!tid) { showStatus("Please enter a tournament ID.", "error"); return; }

      submitBtn.disabled = true;
      showStatus("Scraping… this may take a moment.", "info");

      try {
        const res = await fetch("/api/admin/rescrape-tournament", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ tid }),
        });
        const data = await res.json();
        if (res.ok) {
          showStatus(`Done — ${data.players_updated} player(s) refreshed.`, "success");
        } else {
          showStatus(data.error ?? "Scrape failed.", "error");
        }
      } catch {
        showStatus("Network error.", "error");
      } finally {
        submitBtn.disabled = false;
      }
    });
  </script>
</ResponsiveLayout>

<style>
  .admin-shell {
    max-width: 520px;
    margin: var(--space-12) auto;
    padding: 0 var(--space-4);
  }

  .admin-header {
    margin-bottom: var(--space-10);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--text-dim);
    text-decoration: none;
    margin-bottom: var(--space-6);
    transition: color var(--duration-fast);
  }

  .back-link:hover { color: var(--accent-text); }

  .admin-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--accent-text);
    margin: 0 0 var(--space-2);
  }

  .admin-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--weight-extrabold);
    color: var(--text);
    margin: 0 0 var(--space-3);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
  }

  .admin-desc {
    font-size: var(--text-sm);
    color: var(--text-dim);
    line-height: var(--leading-normal);
    margin: 0;
  }

  code {
    background: var(--surface-container-high);
    color: var(--accent-text);
    padding: 0.1em 0.4em;
    border-radius: var(--radius-sm);
    font-size: 0.85em;
    font-family: var(--font-mono);
  }

  .rescrape-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .status-msg {
    font-size: var(--text-sm);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    min-height: 1.25rem;
  }

  .status-msg:empty { padding: 0; }
  .status-msg--success { background: var(--win-subtle); color: var(--win); }
  .status-msg--error   { background: var(--loss-subtle); color: var(--loss); }
  .status-msg--info    { background: var(--accent-subtle); color: var(--accent-text); }

  .form-actions { display: flex; gap: var(--space-3); }

  .admin-hint {
    margin-top: var(--space-6);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }
</style>
