---
import ResponsiveLayout from "../../layouts/ResponsiveLayout.astro";
import FormField from "../../components/controls/FormField.astro";
import TextInput from "../../components/controls/TextInput.astro";
import SelectInput from "../../components/controls/SelectInput.astro";
import ActionButton from "../../components/controls/ActionButton.astro";
import { resolvePageLang } from "../../lib/page-lang";
import { FIDE_FEDERATIONS } from "../../lib/federations";

const lang = resolvePageLang(Astro.url, Astro.cookies);
---

<ResponsiveLayout title="Admin – Player Photos" lang={lang} navMode="none">
  <div class="admin-shell">
    <header class="admin-header">
      <a href="/admin" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        Admin
      </a>
      <p class="admin-eyebrow">Player Management</p>
      <h1 class="admin-title">Player Photos</h1>
      <p class="admin-desc">
        Upload a photo for a player by their <strong>FIDE ID</strong> or <strong>National ID</strong>.
        Accepted formats: JPEG, PNG, WebP · Max 5 MB.
      </p>
    </header>

    <form id="upload-form" class="upload-form" novalidate>
      <div class="field-row">
        <FormField label="Identifier type" forId="id-type">
          <SelectInput id="id-type" name="id_type">
            <option value="national_id">National ID</option>
            <option value="fide_id">FIDE ID</option>
          </SelectInput>
        </FormField>

        <FormField label="Identifier value" forId="id-value">
          <TextInput
            id="id-value"
            name="id_value"
            placeholder="e.g. 1234567"
            autocomplete="off"
            required
          />
        </FormField>
      </div>

      <div id="federation-row">
        <FormField label="Federation" forId="federation">
          <TextInput
            id="federation"
            name="federation"
            placeholder="e.g. POR – Portugal"
            autocomplete="off"
            list="fed-list"
            maxlength="10"
          />
          <datalist id="fed-list">
            {FIDE_FEDERATIONS.map(({ code, name }) => (
              <option value={code}>{name}</option>
            ))}
          </datalist>
        </FormField>
        <p class="field-hint">Required when using National ID</p>
      </div>

      <label class="drop-zone" id="drop-zone">
        <input
          type="file"
          id="photo-input"
          name="photo"
          accept="image/jpeg,image/png,image/webp"
          class="drop-zone-input"
          required
        />
        <div class="drop-zone-content" id="drop-zone-content">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/>
            <line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
          <span class="drop-label">Click or drag a photo here</span>
          <span class="drop-hint">JPEG · PNG · WebP · max 5 MB</span>
        </div>
        <img id="preview-img" class="preview-img hidden" alt="Photo preview" />
      </label>

      <div id="status-msg" class="status-msg" role="status" aria-live="polite"></div>

      <div class="form-actions">
        <ActionButton id="submit-btn" type="submit">Upload photo</ActionButton>
        <ActionButton id="delete-btn" type="button" variant="secondary" class="btn-danger">Remove photo</ActionButton>
      </div>
    </form>
  </div>

  <script>
    const form = document.getElementById("upload-form") as HTMLFormElement;
    const idType = document.getElementById("id-type") as HTMLSelectElement;
    const idValue = document.getElementById("id-value") as HTMLInputElement;
    const federationInput = document.getElementById("federation") as HTMLInputElement;
    const federationRow = document.getElementById("federation-row") as HTMLDivElement;
    const photoInput = document.getElementById("photo-input") as HTMLInputElement;
    const dropZone = document.getElementById("drop-zone") as HTMLLabelElement;
    const dropContent = document.getElementById("drop-zone-content") as HTMLDivElement;
    const previewImg = document.getElementById("preview-img") as HTMLImageElement;
    const statusMsg = document.getElementById("status-msg") as HTMLDivElement;
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
    const deleteBtn = document.getElementById("delete-btn") as HTMLButtonElement;

    function updateFederationVisibility() {
      const show = idType.value === "national_id";
      federationRow.style.display = show ? "" : "none";
      federationInput.required = show;
    }

    idType.addEventListener("change", updateFederationVisibility);
    updateFederationVisibility();

    function showStatus(msg: string, kind: "success" | "error" | "info") {
      statusMsg.textContent = msg;
      statusMsg.className = `status-msg status-msg--${kind}`;
    }

    function showPreview(file: File) {
      const url = URL.createObjectURL(file);
      previewImg.src = url;
      previewImg.classList.remove("hidden");
      dropContent.classList.add("hidden");
    }

    function clearPreview() {
      if (previewImg.src) URL.revokeObjectURL(previewImg.src);
      previewImg.src = "";
      previewImg.classList.add("hidden");
      dropContent.classList.remove("hidden");
    }

    photoInput.addEventListener("change", () => {
      const file = photoInput.files?.[0];
      if (file) showPreview(file);
      else clearPreview();
    });

    dropZone.addEventListener("dragover", (e) => {
      e.preventDefault();
      dropZone.classList.add("drop-zone--active");
    });
    dropZone.addEventListener("dragleave", () => dropZone.classList.remove("drop-zone--active"));
    dropZone.addEventListener("drop", (e) => {
      e.preventDefault();
      dropZone.classList.remove("drop-zone--active");
      const file = e.dataTransfer?.files[0];
      if (file) {
        const dt = new DataTransfer();
        dt.items.add(file);
        photoInput.files = dt.files;
        showPreview(file);
      }
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const value = idValue.value.trim();
      if (!value) { showStatus("Please enter an identifier value.", "error"); return; }
      const file = photoInput.files?.[0];
      if (!file) { showStatus("Please select a photo.", "error"); return; }

      const useNationalId = idType.value === "national_id";
      const fed = federationInput.value.trim().toUpperCase();
      if (useNationalId && !fed) { showStatus("Please enter the federation code.", "error"); return; }

      submitBtn.disabled = true;
      showStatus("Uploading…", "info");

      const fd = new FormData();
      fd.append(idType.value, value);
      if (useNationalId) fd.append("federation", fed);
      fd.append("photo", file);

      try {
        const res = await fetch("/api/admin/player-photo", { method: "POST", body: fd });
        const data = await res.json();
        if (res.ok) {
          showStatus(`Photo saved for player #${data.player_id}.`, "success");
        } else {
          showStatus(data.error ?? "Upload failed.", "error");
        }
      } catch {
        showStatus("Network error.", "error");
      } finally {
        submitBtn.disabled = false;
      }
    });

    deleteBtn.addEventListener("click", async () => {
      const value = idValue.value.trim();
      if (!value) { showStatus("Please enter an identifier value.", "error"); return; }

      const useNationalId = idType.value === "national_id";
      const fed = federationInput.value.trim().toUpperCase();
      if (useNationalId && !fed) { showStatus("Please enter the federation code.", "error"); return; }

      deleteBtn.disabled = true;
      showStatus("Removing…", "info");

      try {
        const body: Record<string, string> = {};
        body[idType.value] = value;
        if (useNationalId) body.federation = fed;
        const res = await fetch("/api/admin/player-photo", {
          method: "DELETE",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        if (res.ok) {
          clearPreview();
          photoInput.value = "";
          showStatus("Photo removed.", "success");
        } else {
          showStatus(data.error ?? "Removal failed.", "error");
        }
      } catch {
        showStatus("Network error.", "error");
      } finally {
        deleteBtn.disabled = false;
      }
    });
  </script>
</ResponsiveLayout>

<style>
  .admin-shell {
    max-width: 560px;
    margin: var(--space-12) auto;
    padding: 0 var(--space-4);
  }

  .admin-header {
    margin-bottom: var(--space-10);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--text-dim);
    text-decoration: none;
    margin-bottom: var(--space-6);
    transition: color var(--duration-fast);
  }

  .back-link:hover { color: var(--accent-text); }

  .admin-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--accent-text);
    margin: 0 0 var(--space-2);
  }

  .admin-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--weight-extrabold);
    color: var(--text);
    margin: 0 0 var(--space-3);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
  }

  .admin-desc {
    font-size: var(--text-sm);
    color: var(--text-dim);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .admin-desc strong { color: var(--text-secondary); }

  /* Form layout */
  .upload-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  @media (max-width: 480px) {
    .field-row { grid-template-columns: 1fr; }
  }

  .field-hint {
    margin: var(--space-2) 0 0;
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  /* Drop zone */
  .drop-zone {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface-container-low);
    border-radius: var(--radius-xl);
    padding: var(--space-10) var(--space-6);
    cursor: pointer;
    position: relative;
    transition: background var(--duration-fast) var(--ease-out);
    min-height: 160px;
    overflow: hidden;
  }

  .drop-zone:hover,
  .drop-zone--active { background: var(--surface-container-high); }
  .drop-zone--active .drop-zone-content { color: var(--accent-text); }

  .drop-zone-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .drop-zone-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-dim);
    pointer-events: none;
    transition: color var(--duration-fast);
  }

  .drop-label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--text-secondary);
  }

  .drop-hint {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .preview-img {
    max-width: 100%;
    max-height: 220px;
    border-radius: var(--radius-lg);
    object-fit: cover;
    pointer-events: none;
  }

  .hidden { display: none; }

  /* Status */
  .status-msg {
    font-size: var(--text-sm);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    min-height: 1.25rem;
  }

  .status-msg:empty { padding: 0; }
  .status-msg--success { background: var(--win-subtle); color: var(--win); }
  .status-msg--error   { background: var(--loss-subtle); color: var(--loss); }
  .status-msg--info    { background: var(--accent-subtle); color: var(--accent-text); }

  /* Buttons */
  .form-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  :global(.btn-danger) {
    background: var(--loss-subtle) !important;
    color: var(--loss) !important;
  }

  :global(.btn-danger:hover:not(:disabled)) {
    background: var(--loss-subtle) !important;
    color: var(--loss) !important;
    opacity: 0.8;
  }
</style>
