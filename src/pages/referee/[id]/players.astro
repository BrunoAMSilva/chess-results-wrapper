---
import ResponsiveLayout from "../../../layouts/ResponsiveLayout.astro";
import { getTournamentPlayers, getTournament } from "../../../lib/db";
import { useTranslations } from "../../../i18n/ui";
import { resolvePageLang } from "../../../lib/page-lang";
import { generateCsrfToken } from "../../../lib/csrf";

const tid = Astro.params.id!;
const lang = resolvePageLang(Astro.url, Astro.cookies);
const t = useTranslations(lang);

const csrfToken = generateCsrfToken();
Astro.cookies.set("csrf-token", csrfToken, {
  secure: true,
  httpOnly: true,
  sameSite: "strict",
  maxAge: 3600,
  path: "/",
});

const tournament = getTournament(tid);
const players = getTournamentPlayers(tid);
const tournamentName = tournament?.name || "";
---

<ResponsiveLayout title={t("referee.playersTitle")} eyebrow={tournamentName} lang={lang} navMode="referee">
  <div class="players-page" data-csrf-token={csrfToken}>
    <p class="page-desc">{t("referee.playersDesc")}</p>

    <div class="search-bar">
      <input
        type="search"
        id="player-search"
        class="search-input"
        placeholder={t("referee.searchPlaceholder")}
        autocomplete="off"
      />
    </div>

    <div class="player-list" id="player-list">
      {players.map((p) => (
        <div
          class:list={["player-card", { "has-photo": !!p.photo_url }]}
          data-player-id={p.player_id}
          data-fide-id={p.fide_id || ""}
          data-national-id={p.national_id || ""}
          data-federation={p.federation || ""}
          data-name={p.name}
        >
          <div class="player-avatar">
            {p.photo_url ? (
              <img src={p.photo_url} alt={p.name} class="avatar-img" loading="lazy" />
            ) : (
              <div class="avatar-placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
              </div>
            )}
          </div>
          <div class="player-info">
            <span class="player-name">{p.name}</span>
            <span class="player-meta">
              {[p.federation, p.rating ? String(p.rating) : ""].filter(Boolean).join(" · ")}
              {p.fide_id ? ` · FIDE ${p.fide_id}` : ""}
            </span>
          </div>
          <span class:list={["photo-badge", p.photo_url ? "badge-ok" : "badge-none"]}>
            {p.photo_url ? t("referee.hasPhoto") : t("referee.noPhoto")}
          </span>
        </div>
      ))}
    </div>

    {players.length === 0 && (
      <p class="empty-msg">{t("referee.noResults")}</p>
    )}

    <!-- Photo upload modal -->
    <div class="modal-overlay hidden" id="photo-modal">
      <div class="modal-card">
        <div class="modal-header">
          <h2 class="modal-title" id="modal-player-name"></h2>
          <button class="modal-close" id="modal-close" type="button" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>

        <div class="modal-preview" id="modal-preview">
          <img id="modal-preview-img" class="modal-img hidden" alt="Player photo" />
          <div id="modal-placeholder" class="modal-placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
        </div>

        <label class="upload-zone" id="upload-zone">
          <input
            type="file"
            id="photo-file"
            accept="image/jpeg,image/png,image/webp"
            class="upload-input"
          />
          <div class="upload-content">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <span>Click or drag a photo</span>
          </div>
        </label>

        <div id="modal-status" class="modal-status" role="status" aria-live="polite"></div>

        <div class="modal-actions">
          <button id="btn-upload" class="btn btn-primary" type="button" disabled>Upload</button>
          <button id="btn-remove" class="btn btn-danger" type="button">
            {t("referee.removePhoto")}
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    const page = document.querySelector(".players-page") as HTMLElement;
    const csrfToken = page.getAttribute("data-csrf-token") || "";
    const search = document.getElementById("player-search") as HTMLInputElement;
    const list = document.getElementById("player-list") as HTMLElement;
    const modal = document.getElementById("photo-modal") as HTMLElement;
    const modalName = document.getElementById("modal-player-name") as HTMLElement;
    const modalClose = document.getElementById("modal-close") as HTMLButtonElement;
    const modalPreviewImg = document.getElementById("modal-preview-img") as HTMLImageElement;
    const modalPlaceholder = document.getElementById("modal-placeholder") as HTMLElement;
    const uploadZone = document.getElementById("upload-zone") as HTMLLabelElement;
    const fileInput = document.getElementById("photo-file") as HTMLInputElement;
    const statusEl = document.getElementById("modal-status") as HTMLElement;
    const btnUpload = document.getElementById("btn-upload") as HTMLButtonElement;
    const btnRemove = document.getElementById("btn-remove") as HTMLButtonElement;

    let activeCard: HTMLElement | null = null;
    let selectedFile: File | null = null;

    // Search filter
    search.addEventListener("input", () => {
      const q = search.value.toLowerCase();
      for (const card of list.children) {
        const name = (card as HTMLElement).dataset.name?.toLowerCase() || "";
        (card as HTMLElement).style.display = name.includes(q) ? "" : "none";
      }
    });

    // Open modal
    list.addEventListener("click", (e) => {
      const card = (e.target as HTMLElement).closest(".player-card") as HTMLElement | null;
      if (!card) return;
      activeCard = card;
      selectedFile = null;
      fileInput.value = "";
      btnUpload.disabled = true;
      statusEl.textContent = "";
      statusEl.className = "modal-status";

      modalName.textContent = card.dataset.name || "";

      // Show existing photo or placeholder
      const avatarImg = card.querySelector(".avatar-img") as HTMLImageElement | null;
      if (avatarImg) {
        modalPreviewImg.src = avatarImg.src;
        modalPreviewImg.classList.remove("hidden");
        modalPlaceholder.classList.add("hidden");
        btnRemove.style.display = "";
      } else {
        modalPreviewImg.src = "";
        modalPreviewImg.classList.add("hidden");
        modalPlaceholder.classList.remove("hidden");
        btnRemove.style.display = "none";
      }

      modal.classList.remove("hidden");
    });

    // Close modal
    modalClose.addEventListener("click", closeModal);
    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });

    function closeModal() {
      modal.classList.add("hidden");
      activeCard = null;
      selectedFile = null;
    }

    // File selection
    fileInput.addEventListener("change", () => {
      const file = fileInput.files?.[0];
      if (file) {
        selectedFile = file;
        const url = URL.createObjectURL(file);
        modalPreviewImg.src = url;
        modalPreviewImg.classList.remove("hidden");
        modalPlaceholder.classList.add("hidden");
        btnUpload.disabled = false;
      }
    });

    // Drag & drop
    uploadZone.addEventListener("dragover", (e) => {
      e.preventDefault();
      uploadZone.classList.add("upload-zone--active");
    });
    uploadZone.addEventListener("dragleave", () => uploadZone.classList.remove("upload-zone--active"));
    uploadZone.addEventListener("drop", (e) => {
      e.preventDefault();
      uploadZone.classList.remove("upload-zone--active");
      const file = e.dataTransfer?.files[0];
      if (file) {
        const dt = new DataTransfer();
        dt.items.add(file);
        fileInput.files = dt.files;
        selectedFile = file;
        const url = URL.createObjectURL(file);
        modalPreviewImg.src = url;
        modalPreviewImg.classList.remove("hidden");
        modalPlaceholder.classList.add("hidden");
        btnUpload.disabled = false;
      }
    });

    function showStatus(msg: string, kind: "success" | "error" | "info") {
      statusEl.textContent = msg;
      statusEl.className = `modal-status modal-status--${kind}`;
    }

    function getIdentifiers(card: HTMLElement) {
      const fideId = card.dataset.fideId || "";
      const nationalId = card.dataset.nationalId || "";
      const federation = card.dataset.federation || "";
      return { fideId, nationalId, federation };
    }

    // Upload
    btnUpload.addEventListener("click", async () => {
      if (!activeCard || !selectedFile) return;
      const { fideId, nationalId, federation } = getIdentifiers(activeCard);

      if (!fideId && !nationalId) {
        showStatus("Player has no FIDE ID or national ID.", "error");
        return;
      }

      btnUpload.disabled = true;
      showStatus("Uploading…", "info");

      const reader = new FileReader();
      reader.onload = async () => {
        const base64 = (reader.result as string).split(",")[1];
        const body: Record<string, string> = {
          photo: base64,
          photoType: selectedFile!.type,
          photoName: selectedFile!.name,
        };
        if (fideId) {
          body.fide_id = fideId;
        } else {
          body.national_id = nationalId;
          body.federation = federation;
        }

        try {
          const res = await fetch("/api/admin/player-photo", {
            method: "POST",
            headers: { "Content-Type": "application/json", "X-CSRF-Token": csrfToken },
            body: JSON.stringify(body),
          });
          const data = await res.json();
          if (res.ok) {
            showStatus((page.querySelector("[data-t-uploaded]") as HTMLElement)?.dataset.tUploaded || "Photo uploaded!", "success");
            // Update card in list
            updateCardPhoto(activeCard!, data.photo_url);
            btnRemove.style.display = "";
          } else {
            showStatus(data.error || "Upload failed.", "error");
          }
        } catch {
          showStatus("Network error.", "error");
        } finally {
          btnUpload.disabled = false;
        }
      };
      reader.readAsDataURL(selectedFile);
    });

    // Remove
    btnRemove.addEventListener("click", async () => {
      if (!activeCard) return;
      const { fideId, nationalId, federation } = getIdentifiers(activeCard);

      if (!fideId && !nationalId) {
        showStatus("Player has no FIDE ID or national ID.", "error");
        return;
      }

      btnRemove.disabled = true;
      showStatus("Removing…", "info");

      const body: Record<string, string> = {};
      if (fideId) {
        body.fide_id = fideId;
      } else {
        body.national_id = nationalId;
        body.federation = federation;
      }

      try {
        const res = await fetch("/api/admin/player-photo", {
          method: "DELETE",
          headers: { "Content-Type": "application/json", "X-CSRF-Token": csrfToken },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        if (res.ok) {
          showStatus("Photo removed.", "success");
          removeCardPhoto(activeCard!);
          modalPreviewImg.src = "";
          modalPreviewImg.classList.add("hidden");
          modalPlaceholder.classList.remove("hidden");
          btnRemove.style.display = "none";
        } else {
          showStatus(data.error || "Removal failed.", "error");
        }
      } catch {
        showStatus("Network error.", "error");
      } finally {
        btnRemove.disabled = false;
      }
    });

    function updateCardPhoto(card: HTMLElement, photoUrl: string) {
      card.classList.add("has-photo");
      const avatar = card.querySelector(".player-avatar")!;
      avatar.innerHTML = `<img src="${photoUrl}" alt="${card.dataset.name}" class="avatar-img" loading="lazy" />`;
      const badge = card.querySelector(".photo-badge")!;
      badge.classList.remove("badge-none");
      badge.classList.add("badge-ok");
      badge.textContent = badge.closest(".players-page")?.querySelector("[data-t-has]")?.textContent || "Has photo";
    }

    function removeCardPhoto(card: HTMLElement) {
      card.classList.remove("has-photo");
      const avatar = card.querySelector(".player-avatar")!;
      avatar.innerHTML = `<div class="avatar-placeholder"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>`;
      const badge = card.querySelector(".photo-badge")!;
      badge.classList.remove("badge-ok");
      badge.classList.add("badge-none");
      badge.textContent = badge.closest(".players-page")?.querySelector("[data-t-none]")?.textContent || "No photo";
    }
  </script>
</ResponsiveLayout>

<!-- Hidden translation holders for JS -->
<span class="hidden" data-t-has data-t-uploaded={t("referee.photoUploaded")}>{t("referee.hasPhoto")}</span>
<span class="hidden" data-t-none>{t("referee.noPhoto")}</span>

<style>
  .players-page {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .page-desc {
    font-size: var(--text-sm);
    color: var(--text-dim);
    margin: 0;
    text-align: center;
  }

  .search-bar {
    position: sticky;
    top: 0;
    z-index: 10;
    padding: var(--space-2) 0;
    background: var(--surface);
  }

  .search-input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface-container-low);
    color: var(--text);
    font-size: var(--text-sm);
    outline: none;
    transition: border-color var(--duration-fast);
  }

  .search-input:focus {
    border-color: var(--accent);
  }

  .player-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .player-card {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--surface-container-low);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: background var(--duration-fast);
  }

  .player-card:hover {
    background: var(--surface-container-high);
  }

  .player-avatar {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .avatar-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface-container-high);
    color: var(--text-muted);
  }

  .player-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  .player-name {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .player-meta {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .photo-badge {
    flex-shrink: 0;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .badge-ok {
    background: var(--win-subtle);
    color: var(--win);
  }

  .badge-none {
    background: var(--surface-container-high);
    color: var(--text-muted);
  }

  .empty-msg {
    text-align: center;
    color: var(--text-muted);
    padding: var(--space-8);
  }

  /* Modal */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
  }

  .modal-overlay.hidden { display: none; }

  .modal-card {
    background: var(--surface);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    max-width: 400px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .modal-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--text);
    margin: 0;
  }

  .modal-close {
    background: none;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    padding: var(--space-1);
    border-radius: var(--radius-sm);
    transition: color var(--duration-fast);
  }

  .modal-close:hover { color: var(--text); }

  .modal-preview {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 120px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--surface-container-low);
  }

  .modal-img {
    max-width: 100%;
    max-height: 200px;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }

  .modal-placeholder {
    color: var(--text-muted);
    padding: var(--space-6);
  }

  .upload-zone {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    background: var(--surface-container-low);
    border-radius: var(--radius-lg);
    cursor: pointer;
    position: relative;
    transition: background var(--duration-fast);
  }

  .upload-zone:hover,
  .upload-zone--active { background: var(--surface-container-high); }

  .upload-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .upload-content {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-dim);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    pointer-events: none;
  }

  .modal-status {
    font-size: var(--text-sm);
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-3);
    min-height: 1.25rem;
  }

  .modal-status:empty { padding: 0; }
  .modal-status--success { background: var(--win-subtle); color: var(--win); }
  .modal-status--error { background: var(--loss-subtle); color: var(--loss); }
  .modal-status--info { background: var(--accent-subtle); color: var(--accent-text); }

  .modal-actions {
    display: flex;
    gap: var(--space-3);
  }

  .btn {
    flex: 1;
    padding: var(--space-3) var(--space-4);
    border: none;
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    cursor: pointer;
    transition: opacity var(--duration-fast);
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--accent-on);
  }

  .btn-primary:hover:not(:disabled) { opacity: 0.85; }

  .btn-danger {
    background: var(--loss-subtle);
    color: var(--loss);
  }

  .btn-danger:hover:not(:disabled) { opacity: 0.8; }

  .hidden { display: none; }
</style>
