---
import ResponsiveLayout from "../../../layouts/ResponsiveLayout.astro";
import FormField from "../../../components/controls/FormField.astro";
import TextInput from "../../../components/controls/TextInput.astro";
import ActionButton from "../../../components/controls/ActionButton.astro";
import { getTournamentConfig } from "../../../lib/db";
import { useTranslations } from "../../../i18n/ui";
import { resolvePageLang } from "../../../lib/page-lang";

const tid = Astro.params.id!;
const lang = resolvePageLang(Astro.url, Astro.cookies);
const t = useTranslations(lang);

const existingSid = getTournamentConfig(tid, "sid");
const masked = existingSid
  ? existingSid.slice(0, 4) + "…" + existingSid.slice(-4)
  : null;
---

<ResponsiveLayout title={t("referee.settings")} lang={lang} navMode="referee">
  <div class="settings-page">
    <div class="settings-card">
      <div class="card-header">
        <div class="icon-wrapper">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div>
          <h2 class="card-title">{t("referee.sidTitle")}</h2>
          <p class="card-desc">{t("referee.sidDescription")}</p>
        </div>
      </div>

      {masked && (
        <div class="sid-status" role="status">
          <span class="status-badge configured">{t("referee.sidConfigured")}</span>
          <code class="sid-masked">{masked}</code>
        </div>
      )}

      <form class="form-grid" id="sidForm" novalidate>
        <input type="hidden" name="tid" value={tid} />

        <FormField label={t("referee.sidLabel")} forId="inputSid">
          <TextInput
            id="inputSid"
            name="sid"
            placeholder={t("referee.sidPlaceholder")}
            autocomplete="off"
            inputmode="text"
            maxlength="32"
            pattern="[0-9A-Fa-f]{32}"
            required
            aria-describedby="sid-help sid-error"
          />
          <p class="help-text" id="sid-help">{t("referee.sidHelp")}</p>
          <p class="error-text" id="sid-error" role="alert" aria-live="assertive"></p>
        </FormField>

        <div class="actions-row">
          <ActionButton class="save-btn" pill type="submit">
            {t("referee.sidSave")}
          </ActionButton>
          <ActionButton
            href={`/referee/${tid}/results?lang=${lang}`}
            variant="secondary"
            pill
          >
            {t("referee.back")}
          </ActionButton>
        </div>
      </form>

      <div class="success-msg" id="successMsg" role="status" aria-live="polite"></div>
    </div>
  </div>
</ResponsiveLayout>

<script is:inline>
  var form = document.getElementById("sidForm");
  var input = document.getElementById("inputSid");
  var errorEl = document.getElementById("sid-error");
  var successEl = document.getElementById("successMsg");
  var SID_RE = /^[0-9A-Fa-f]{32}$/;

  if (form && input) {
    form.addEventListener("submit", function(e) {
      e.preventDefault();
      errorEl.textContent = "";
      successEl.textContent = "";

      var sid = input.value.trim();
      if (!SID_RE.test(sid)) {
        errorEl.textContent = input.getAttribute("data-error-invalid") || "SID must be 32 hexadecimal characters";
        input.setAttribute("aria-invalid", "true");
        input.focus();
        return;
      }

      input.removeAttribute("aria-invalid");
      var tid = form.querySelector('input[name="tid"]').value;

      fetch("/api/tournament-config", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ tid: tid, key: "sid", value: sid }),
      })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.ok) {
            successEl.textContent = input.getAttribute("data-success") || "SID saved!";
            input.value = "";
          } else {
            errorEl.textContent = data.error || "Failed to save";
          }
        })
        .catch(function() {
          errorEl.textContent = "Network error";
        });
    });
  }
</script>

<style>
  .settings-page {
    max-width: 560px;
    margin: 0 auto;
    padding: var(--space-4) 0;
  }

  .settings-card {
    background: var(--surface-container-low);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    box-shadow: var(--shadow-card);
  }

  .card-header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-full);
    background: var(--surface-container-high);
    color: var(--text-dim);
    flex-shrink: 0;
  }

  .card-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--text);
    margin: 0;
  }

  .card-desc {
    font-size: var(--text-sm);
    color: var(--text-dim);
    margin: var(--space-1) 0 0;
    line-height: var(--leading-relaxed);
  }

  .sid-status {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    background: var(--surface-container-high);
  }

  .status-badge {
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .status-badge.configured {
    background: var(--accent-subtle);
    color: var(--accent-text);
  }

  .sid-masked {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-family: var(--font-mono, monospace);
  }

  .form-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .help-text {
    font-size: var(--text-xs);
    color: var(--text-dim);
    margin: var(--space-1) 0 0;
    line-height: var(--leading-relaxed);
  }

  .error-text {
    font-size: var(--text-sm);
    color: var(--danger, #e53e3e);
    margin: var(--space-1) 0 0;
    min-height: 1.25em;
  }

  .error-text:empty {
    display: none;
  }

  .actions-row {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .success-msg {
    font-size: var(--text-sm);
    color: var(--accent-text);
    margin-top: var(--space-4);
    min-height: 1.25em;
  }

  .success-msg:empty {
    display: none;
  }

  @media (forced-colors: active) {
    .settings-card {
      border: 1px solid CanvasText;
    }

    .status-badge.configured {
      border: 1px solid ButtonBorder;
    }
  }
</style>
