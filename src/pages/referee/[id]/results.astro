---
import ResponsiveLayout from "../../../layouts/ResponsiveLayout.astro";
import EmptyState from "../../../components/app/EmptyState.astro";
import ActionButton from "../../../components/controls/ActionButton.astro";
import RefereeRoundPreference from "../../../components/referee/RefereeRoundPreference.astro";
import RoundProgressCard from "../../../components/referee/RoundProgressCard.astro";
import { scrapePairings } from "../../../lib/scraper";
import {
  getRefereeResults,
  getTournamentConfig,
  getUploadLog,
} from "../../../lib/db";
import { useTranslations } from "../../../i18n/ui";
import { resolvePageLang } from "../../../lib/page-lang";
import type {
  LinkedTournament,
  Pairing,
  TeamPairing,
} from "../../../lib/types";

const tid = Astro.params.id!;
const lang = resolvePageLang(Astro.url, Astro.cookies);
const roundParam = Astro.url.searchParams.get("round");
const sectionParam = Astro.url.searchParams.get("section");

const t = useTranslations(lang);

let error: string | null = null;
let totalRounds = 0;
let activeRound = 1;
let linkedTournaments: LinkedTournament[] | undefined;
let currentLabel = "";
let tournamentName = "";

interface RefereeResult {
  table_number: number;
  result: string;
  created_at: string;
}

interface SectionData {
  id: string;
  name: string;
  tables: number[];
  tablePlayersMap: Record<number, { white: string; black: string }>;
  resultsMap: Record<number, RefereeResult>;
  submittedCount: number;
}

const allSections: SectionData[] = [];

try {
  const initial = await scrapePairings(tid, 1);
  totalRounds = initial.info.totalRounds;
  linkedTournaments = initial.info.linkedTournaments;
  tournamentName = initial.info.name;
  currentLabel = initial.info.currentLabel || initial.info.name;

  if (roundParam) {
    activeRound = Math.max(
      1,
      Math.min(parseInt(roundParam, 10) || 1, totalRounds),
    );
  } else {
    let foundRound = 1;
    for (let r = totalRounds; r >= 1; r--) {
      const data = r === 1 ? initial : await scrapePairings(tid, r);
      const pairings = data.pairings || [];
      const hasNoResults =
        pairings.length > 0 &&
        pairings.every((p) => !p.result || p.result.trim() === "");
      if (hasNoResults) {
        foundRound = r;
      } else if (pairings.length > 0) {
        break;
      }
    }
    activeRound = foundRound;
  }

  // Build section list
  const sectionIds: { id: string; name: string }[] = [];
  const hasSections = !!(linkedTournaments && linkedTournaments.length > 0);

  if (hasSections) {
    sectionIds.push({ id: tid, name: currentLabel });
    for (const lt of linkedTournaments!) {
      if (lt.id !== tid) {
        sectionIds.push({ id: lt.id, name: lt.name });
      }
    }
    sectionIds.sort((a, b) => a.name.localeCompare(b.name));
  } else {
    sectionIds.push({ id: tid, name: currentLabel });
  }

  // Determine which section to show (default to first)
  const activeSectionId =
    sectionParam && sectionIds.some((s) => s.id === sectionParam)
      ? sectionParam
      : sectionIds[0]?.id;
  const loadSections = sectionIds.filter((s) => s.id === activeSectionId);

  for (const sec of loadSections) {
    const data = await scrapePairings(sec.id, activeRound);
    const pairings: Pairing[] = data.pairings || [];
    const teamPairings: TeamPairing[] | undefined = data.teamPairings;

    const tablePlayersMap: Record<number, { white: string; black: string }> =
      {};
    if (teamPairings && teamPairings.length > 0) {
      for (const tm of teamPairings) {
        for (const b of tm.boards) {
          tablePlayersMap[b.table] = {
            white: b.white.name,
            black: b.black?.name || "—",
          };
        }
      }
    } else {
      for (const p of pairings) {
        tablePlayersMap[p.table] = {
          white: p.white.name,
          black: p.black?.name || "—",
        };
      }
    }

    const resultsMap: Record<number, RefereeResult> = {};
    const refResults = getRefereeResults(
      sec.id,
      activeRound,
    ) as RefereeResult[];
    for (const r of refResults) {
      resultsMap[r.table_number] = r;
    }

    const tables = Object.keys(tablePlayersMap)
      .map(Number)
      .sort((a, b) => a - b);
    const submittedCount = tables.filter((t) => resultsMap[t]).length;

    allSections.push({
      id: sec.id,
      name: sec.name,
      tables,
      tablePlayersMap,
      resultsMap,
      submittedCount,
    });
  }
} catch (e) {
  error = e instanceof Error ? e.message : t("error.load");
}

const hasSections = !!(linkedTournaments && linkedTournaments.length > 0);
const rounds = Array.from({ length: totalRounds }, (_, i) => i + 1);
const activeSection = allSections[0]?.id || tid;
const roundBaseUrl = `/referee/${tid}/results?lang=${lang}&section=${activeSection}`;

function formatTemplate(
  template: string,
  values: Record<string, string | number>,
) {
  let formatted = template;
  for (const [key, value] of Object.entries(values)) {
    formatted = formatted.replaceAll(`{${key}}`, String(value));
  }
  return formatted;
}

function getResultTone(
  result?: string,
): "pending" | "white" | "black" | "draw" | "other" {
  if (!result) return "pending";
  const normalized = result.replace(/\s+/g, "").toLowerCase();
  if (normalized.includes("1-0") || normalized.includes("1:0")) return "white";
  if (normalized.includes("0-1") || normalized.includes("0:1")) return "black";
  if (
    normalized.includes("1/2") ||
    normalized.includes("0.5") ||
    normalized.includes("½")
  )
    return "draw";
  return "other";
}

// Build section list for switcher
const sectionList: { id: string; name: string }[] = [];
if (hasSections) {
  sectionList.push({ id: tid, name: currentLabel });
  for (const lt of linkedTournaments!) {
    if (lt.id !== tid) {
      sectionList.push({ id: lt.id, name: lt.name });
    }
  }
  sectionList.sort((a, b) => a.name.localeCompare(b.name));
}

const resultsTitle =
  allSections[0]?.name || currentLabel || t("referee.results");
const eyebrow =
  tournamentName && tournamentName !== resultsTitle
    ? tournamentName
    : undefined;

// Check SID configuration and upload status
const hasSid = !!getTournamentConfig(activeSection, "sid");
const uploadLog = hasSid ? getUploadLog(activeSection, activeRound) : [];
const uploadStatusMap: Record<number, { status: string; statusMsg: string }> =
  {};
for (const entry of uploadLog) {
  uploadStatusMap[entry.table_number] = {
    status: entry.status,
    statusMsg: entry.status_msg,
  };
}
---

<ResponsiveLayout
  title={resultsTitle}
  eyebrow={eyebrow}
  lang={lang}
  navMode="referee"
>
  <RefereeRoundPreference
    tournamentId={tid}
    activeRound={activeRound}
    totalRounds={totalRounds}
    hasRoundParam={Boolean(roundParam)}
  />
  {
    error && (
      <div class="error-msg">
        <p>{error}</p>
      </div>
    )
  }

  <div class="results-overview">
    {
      allSections.map((sec, index) => {
        const remainingCount = Math.max(
          sec.tables.length - sec.submittedCount,
          0,
        );
        const eyebrowText = formatTemplate(t("referee.roundCompletion"), {
          round: activeRound,
        });
        const progressLabel = formatTemplate(t("referee.progressStatus"), {
          submitted: sec.submittedCount,
          total: sec.tables.length,
        });
        const remainingTemplate =
          remainingCount === 1
            ? t("referee.progressRemainingSingular")
            : t("referee.progressRemainingPlural");
        const summaryText =
          remainingCount === 0 && sec.tables.length > 0
            ? t("referee.allSubmitted")
            : formatTemplate(remainingTemplate, {
                count: remainingCount,
                section: sec.name,
              });
        const progressValueText = `${progressLabel}. ${summaryText}`;
        const hasExport = sec.submittedCount > 0;

        return (
          <div class="section-block">
            <RoundProgressCard
              submittedCount={sec.submittedCount}
              totalCount={sec.tables.length}
              eyebrowText={eyebrowText}
              progressLabel={progressLabel}
              summaryText={summaryText}
              progressValueText={progressValueText}
            >
              {index === 0 && (
                <Fragment slot="eyebrow-controls">
                  <select
                    class="card-inline-select round-inline-select"
                    id="roundSelect"
                    data-referee-round-select
                    aria-label={t("referee.round")}
                  >
                    {rounds.map((round) => (
                      <option value={round} selected={round === activeRound}>
                        {round}
                      </option>
                    ))}
                  </select>
                </Fragment>
              )}

              {index === 0 && (
                <Fragment slot="supporting-controls">
                  {hasSections && sectionList.length > 0 && (
                    <select
                      class="card-inline-select section-inline-select"
                      id="sectionSelect"
                      aria-label={t("referee.changeSection")}
                    >
                      {sectionList.map((s) => (
                        <option value={s.id} selected={s.id === activeSection}>
                          {s.name}
                        </option>
                      ))}
                    </select>
                  )}
                  {hasExport && (
                    <ActionButton
                      class="export-btn"
                      href={`/api/referee-export?tid=${sec.id}&round=${activeRound}`}
                      download={`round-${activeRound}-results.xml`}
                      variant="secondary"
                      size="compact"
                      pill
                    >
                      {t("referee.exportXml")}
                    </ActionButton>
                  )}
                  {hasExport && (
                    <ActionButton
                      id="copyResultsBtn"
                      class="copy-btn"
                      type="button"
                      variant="secondary"
                      size="compact"
                      pill
                      data-section={sec.name}
                      data-round={String(activeRound)}
                      data-copied={t("referee.copied")}
                    >
                      {t("referee.copyResults")}
                    </ActionButton>
                  )}
                  {hasExport && hasSid && (
                    <ActionButton
                      id="uploadBtn"
                      class="upload-btn"
                      type="button"
                      size="compact"
                      pill
                      data-tid={sec.id}
                      data-round={String(activeRound)}
                    >
                      {t("referee.upload")}
                    </ActionButton>
                  )}
                  {!hasSid && hasExport && (
                    <ActionButton
                      href={`/referee/${tid}/settings?lang=${lang}`}
                      variant="secondary"
                      size="compact"
                      pill
                    >
                      {t("referee.configureSid")}
                    </ActionButton>
                  )}
                </Fragment>
              )}
            </RoundProgressCard>

            {hasExport && index !== 0 && (
              <div class="export-section">
                <ActionButton
                  class="export-btn"
                  href={`/api/referee-export?tid=${sec.id}&round=${activeRound}`}
                  download={`round-${activeRound}-results.xml`}
                  variant="secondary"
                  size="compact"
                  pill
                >
                  {t("referee.exportXml")}
                </ActionButton>
              </div>
            )}

            {sec.tables.length === 0 ? (
              <EmptyState message={t("referee.noResultsYet")} compact />
            ) : (
              <table class="results-table">
                <thead>
                  <tr class="results-header">
                    <th class="col-table">{t("referee.table")}</th>
                    <th class="col-players">
                      {t("table.white")} – {t("table.black")}
                    </th>
                    <th class="col-result">{t("referee.result")}</th>
                  </tr>
                </thead>
                <tbody>
                  {sec.tables.map((tbl) => {
                    const players = sec.tablePlayersMap[tbl];
                    const result = sec.resultsMap[tbl];
                    const resultTone = getResultTone(result?.result);
                    return (
                      <tr
                        class:list={[
                          "results-row",
                          { submitted: !!result, pending: !result },
                        ]}
                      >
                        <td class="col-table">
                          <span class="table-badge">{tbl}</span>
                        </td>
                        <td class="col-players">
                          <span class="player-white">{players.white}</span>
                          <span class="vs">&nbsp;–&nbsp;</span>
                          <span class="player-black">{players.black}</span>
                        </td>
                        <td class="col-result">
                          <span
                            class:list={[
                              "result-badge",
                              resultTone,
                              { "has-result": !!result },
                            ]}
                          >
                            {result ? result.result : t("referee.pending")}
                          </span>
                          {uploadStatusMap[tbl] && (
                            <span
                              class:list={[
                                "upload-status",
                                uploadStatusMap[tbl].status.toLowerCase(),
                              ]}
                              title={uploadStatusMap[tbl].statusMsg}
                            >
                              {uploadStatusMap[tbl].status === "OK" ? "✓" : "✗"}
                            </span>
                          )}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            )}
          </div>
        );
      })
    }
  </div>
</ResponsiveLayout>

<script is:inline>
  // Round select navigation
  var roundSelect = document.getElementById("roundSelect");
  if (roundSelect) {
    roundSelect.addEventListener("change", function () {
      var url = new URL(window.location.href);
      url.searchParams.set("round", roundSelect.value);
      window.location.href = url.toString();
    });
  }

  // Section select navigation
  var sectionSelect = document.getElementById("sectionSelect");
  if (sectionSelect) {
    sectionSelect.addEventListener("change", function () {
      var url = new URL(window.location.href);
      url.searchParams.set("section", sectionSelect.value);
      window.location.href = url.toString();
    });
  }

  // Auto-refresh every 15 seconds
  setTimeout(function () {
    window.location.reload();
  }, 15000);

  // Upload to chess-results.com
  var uploadBtn = document.getElementById("uploadBtn");
  if (uploadBtn) {
    uploadBtn.addEventListener("click", function () {
      var btn = uploadBtn;
      var tid = btn.getAttribute("data-tid");
      var round = btn.getAttribute("data-round");
      btn.disabled = true;
      btn.textContent = btn.getAttribute("data-uploading") || "Uploading…";

      fetch("/api/referee-upload", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          tid: tid,
          round: parseInt(round, 10),
          section: tid,
        }),
      })
        .then(function (res) {
          return res.json();
        })
        .then(function (data) {
          if (data.ok) {
            // Reload to show updated upload status
            window.location.reload();
          } else {
            btn.disabled = false;
            btn.textContent = btn.getAttribute("data-label") || "Upload";
            alert(data.error || "Upload failed");
          }
        })
        .catch(function () {
          btn.disabled = false;
          btn.textContent = btn.getAttribute("data-label") || "Upload";
          alert("Network error");
        });
    });
  }

  // Copy results as text for organizer
  var copyBtn = document.getElementById("copyResultsBtn");
  if (copyBtn) {
    copyBtn.addEventListener("click", function () {
      var section = copyBtn.getAttribute("data-section") || "";
      var round = copyBtn.getAttribute("data-round") || "";
      var copiedLabel = copyBtn.getAttribute("data-copied") || "Copied!";
      var originalLabel = copyBtn.textContent;

      var rows = document.querySelectorAll(".results-row.submitted");
      var lines = [];
      lines.push(section + " — Round " + round);
      lines.push("");

      rows.forEach(function (row) {
        var table = row.querySelector(".table-badge");
        var white = row.querySelector(".player-white");
        var black = row.querySelector(".player-black");
        var result = row.querySelector(".result-badge");
        if (table && white && result) {
          var t = table.textContent.trim();
          var w = white.textContent.trim();
          var b = black ? black.textContent.trim() : "—";
          var r = result.textContent.trim();
          lines.push(t + ". " + w + " – " + b + "  " + r);
        }
      });

      var text = lines.join("\n");
      navigator.clipboard
        .writeText(text)
        .then(function () {
          copyBtn.textContent = copiedLabel;
          setTimeout(function () {
            copyBtn.textContent = originalLabel;
          }, 2000);
        })
        .catch(function () {
          // Fallback: select text in a temporary textarea
          var ta = document.createElement("textarea");
          ta.value = text;
          ta.style.position = "fixed";
          ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          document.execCommand("copy");
          document.body.removeChild(ta);
          copyBtn.textContent = copiedLabel;
          setTimeout(function () {
            copyBtn.textContent = originalLabel;
          }, 2000);
        });
    });
  }
</script>

<style>
  .results-overview {
    max-width: 760px;
    margin: 0 auto;
    padding: var(--space-4) 0;
  }

  .section-block {
    margin-bottom: var(--space-8);
  }

  .section-block:last-child {
    margin-bottom: 0;
  }

  .export-section {
    display: flex;
    justify-content: flex-end;
    margin-bottom: var(--space-4);
  }

  .export-btn {
    text-decoration: none;
  }

  :global(.export-btn.ui-action) {
    box-shadow: var(--shadow-sm);
  }

  .results-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    background: var(--surface-container-low);
  }

  .results-header th {
    padding: var(--space-3) var(--space-4);
    background: var(--surface-container-low);
    border-bottom: 1px solid var(--border-strong);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    text-align: left;
  }

  .results-header .col-table {
    width: 48px;
    text-align: center;
  }

  .results-header .col-result {
    width: 80px;
    text-align: right;
  }

  
  .results-row td {
    padding: var(--space-3) var(--space-4);
    border-block-end: 2px solid var(--border-light);
    font-size: var(--text-sm);
    background: var(--surface-container-low);
    height: 100%;
  }

  .results-row:last-child td {
    border-bottom: none;
  }

  .results-row.submitted td {
    background: color-mix(
      in srgb,
      var(--surface-container-low) 76%,
      var(--accent-subtle)
    );
  }

  .col-table {
    text-align: center;
    width: 48px;
  }

  .table-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.25rem;
    min-height: 2.25rem;
    padding: 0 var(--space-2);
    border-radius: var(--radius-full);
    background: var(--surface-container-high);
    color: var(--text);
    font-weight: var(--weight-bold);
    line-height: var(--leading-none);
  }

  .col-players {
    overflow: hidden;
  }

  .player-white,
  .player-black {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    min-width: 0;
  }

  .player-white {
    font-weight: var(--weight-semibold);
  }

  .player-black {
    color: var(--text-secondary);
  }

  .vs {
    color: var(--text-dim);
    flex-shrink: 0;
  }

  .col-result {
    text-align: right;
    width: 80px;
  }

  .result-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 5.25rem;
    min-height: 2.25rem;
    padding: 0 var(--space-3);
    border-radius: var(--radius-full);
    background: var(--surface-container-high);
    color: var(--text-dim);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    text-align: center;
  }

  .result-badge.has-result {
    color: var(--text);
  }

  .result-badge.pending {
    background: var(--surface-container-highest);
    color: var(--text-dim);
  }

  .result-badge.white {
    background: var(--tertiary-fixed-dim);
    color: var(--on-primary-fixed);
  }

  .result-badge.black {
    background: var(--secondary-fixed-dim);
    color: var(--on-primary-fixed);
  }

  .result-badge.draw {
    background: var(--draw-subtle);
    color: var(--text);
  }

  .result-badge.other {
    background: var(--accent-subtle);
    color: var(--accent-text);
  }

  .error-msg {
    color: var(--danger, #e53e3e);
    text-align: center;
    padding: var(--space-4);
  }

  @media screen and (max-width: 40rem), screen and (max-width: 640px) {
    .results-overview {
      padding: var(--space-3) 0;
    }

    .results-table,
    .results-table thead,
    .results-table tbody,
    .results-table tr,
    .results-table th,
    .results-table td {
      display: block;
    }

    .results-header {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      clip-path: inset(50%);
      white-space: nowrap;
    }

    .results-row {
      display: grid;
      grid-template-columns: auto 1fr;
      grid-template-areas:
        "table result"
        "players players";
      align-items: start;
      padding: var(--space-4);
    }

    .results-row td.col-table {
      grid-area: table;
      text-align: left;
      width: auto;
      padding: 0;
      border-bottom: none;
    }

    .results-row td.col-result {
      grid-area: result;
      width: auto;
      padding: 0;
      border-bottom: none;
    }

    .results-row td.col-players {
      grid-area: players;
      flex-wrap: wrap;
      gap: var(--space-1);
      margin-top: var(--space-2);
      padding: 0;
      border-bottom: none;
    }

    .results-row td {
      background: transparent;
    }

    .results-row.submitted td {
      background: transparent;
    }

    .results-row {
      background: var(--surface-container-low);
      border-bottom: 1px solid var(--border-light);
    }

    .results-row:last-child {
      border-bottom: none;
    }

    .results-row.submitted {
      background: color-mix(
        in srgb,
        var(--surface-container-low) 76%,
        var(--accent-subtle)
      );
    }

    .player-white,
    .player-black {
      flex: 1 1 100%;
    }

    .vs {
      display: none;
    }

    .result-badge {
      min-width: 4.75rem;
    }

    .export-section {
      justify-content: stretch;
    }

    .export-btn {
      width: 100%;
    }
  }

  .upload-status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    margin-left: var(--space-1);
    flex-shrink: 0;
  }

  .upload-status.ok {
    background: var(--accent-subtle);
    color: var(--accent-text);
  }

  .upload-status.error,
  .upload-status.warning {
    background: var(--danger-subtle, rgba(229, 62, 62, 0.15));
    color: var(--danger, #e53e3e);
  }

  .col-result :where(.result-badge, .upload-status) {
    vertical-align: middle;
  }

  @media (forced-colors: active) {
    .upload-status {
      border: 1px solid ButtonBorder;
    }
  }
</style>
