---
import ResponsiveLayout from "../../../layouts/ResponsiveLayout.astro";
import RoundSelector from "../../../components/RoundSelector.astro";
import { scrapePairings } from "../../../lib/scraper";
import { getRefereeResults } from "../../../lib/db";
import { useTranslations } from "../../../i18n/ui";
import { resolvePageLang } from "../../../lib/page-lang";
import type { LinkedTournament, Pairing, TeamPairing } from "../../../lib/types";

const tid = Astro.params.id!;
const lang = resolvePageLang(Astro.url, Astro.cookies);
const roundParam = Astro.url.searchParams.get("round");
const t = useTranslations(lang);

let error: string | null = null;
let totalRounds = 0;
let activeRound = 1;
let allPairings: Pairing[] = [];
let teamPairings: TeamPairing[] | undefined;
let linkedTournaments: LinkedTournament[] | undefined;
let currentLabel = "";

try {
  const initial = await scrapePairings(tid, 1, lang);
  totalRounds = initial.info.totalRounds;
  linkedTournaments = initial.info.linkedTournaments;
  currentLabel = initial.info.currentLabel || initial.info.name;

  if (roundParam) {
    activeRound = Math.max(1, Math.min(parseInt(roundParam, 10) || 1, totalRounds));
  } else {
    let foundRound = 1;
    for (let r = totalRounds; r >= 1; r--) {
      const data = r === 1 ? initial : await scrapePairings(tid, r, lang);
      const pairings = data.pairings || [];
      const hasNoResults = pairings.length > 0 && pairings.every((p) => !p.result || p.result.trim() === "");
      if (hasNoResults) {
        foundRound = r;
      } else if (pairings.length > 0) {
        break;
      }
    }
    activeRound = foundRound;
  }

  const activeData = activeRound === 1 ? initial : await scrapePairings(tid, activeRound, lang);
  allPairings = activeData.pairings || [];
  teamPairings = activeData.teamPairings;
} catch (e) {
  error = e instanceof Error ? e.message : t("error.load");
}

const hasSections = !!(linkedTournaments && linkedTournaments.length > 0);

// Section list for section picker
const sections: { id: string; name: string }[] = [];
if (hasSections) {
  sections.push({ id: tid, name: currentLabel });
  for (const lt of linkedTournaments!) {
    if (lt.id !== tid) {
      sections.push({ id: lt.id, name: lt.name });
    }
  }
  sections.sort((a, b) => a.name.localeCompare(b.name));
}

// Table grid data (only when no sections — tables shown inline)
const tables: number[] = [];
const isTeamTournament = !!(teamPairings && teamPairings.length > 0);
if (!hasSections) {
  if (teamPairings && teamPairings.length > 0) {
    for (const tm of teamPairings) {
      for (const b of tm.boards) {
        tables.push(b.table);
      }
    }
  } else {
    for (const p of allPairings) {
      tables.push(p.table);
    }
  }
  tables.sort((a, b) => a - b);
}

function formatTableLabel(table: number): string {
  if (isTeamTournament) {
    const match = Math.floor(table / 100);
    const board = table % 100;
    return `${match}.${board}`;
  }
  return String(table);
}

const submittedTables = new Set<number>();
if (!hasSections) {
  const refResults = getRefereeResults(tid, activeRound) as Array<{ table_number: number }>;
  for (const r of refResults) {
    submittedTables.add(r.table_number);
  }
}

const title = hasSections ? t("referee.selectSection") : t("referee.selectTable");
const q = `round=${activeRound}&lang=${lang}`;
const rounds = Array.from({ length: totalRounds }, (_, i) => i + 1);
const roundBaseUrl = `/referee/${tid}?lang=${lang}`;
---

<ResponsiveLayout title={title} lang={lang} navMode="referee">
  {error && <div class="error-msg"><p>{error}</p></div>}

  <div class="referee-page">
    <RoundSelector rounds={rounds} activeRound={activeRound} baseUrl={roundBaseUrl} label={t("referee.round")} />

    {hasSections ? (
      <div class="section-list">
        {sections.map((s) => (
          <a class="option-btn" href={`/referee/${tid}/${s.id}?${q}`}>
            {s.name}
          </a>
        ))}
      </div>
    ) : (
      <div class="table-grid">
        {tables.map((tbl) => (
          <a
            class:list={["table-btn", { done: submittedTables.has(tbl) }]}
            href={`/referee/${tid}/${tid}/${tbl}?${q}`}
          >
            {formatTableLabel(tbl)}
            {submittedTables.has(tbl) && <span class="done-check">✓</span>}
          </a>
        ))}
      </div>
    )}
  </div>
</ResponsiveLayout>

<style>
  .referee-page {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }



  .section-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    width: 100%;
  }

  .option-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4) var(--space-6);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--text);
    font-size: var(--text-lg);
    font-weight: var(--font-medium);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
    min-height: 56px;
    text-align: center;
    text-decoration: none;
  }

  .option-btn:hover {
    border-color: var(--accent-hover);
    background: var(--surface-hover);
  }

  .table-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-2);
    width: 100%;
  }

  .table-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--text);
    font-size: var(--text-4xl);
    font-weight: var(--font-bold);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
    aspect-ratio: 1;
    position: relative;
    text-decoration: none;
  }

  .table-btn:hover {
    border-color: var(--accent-hover);
    color: var(--accent-text);
  }

  .table-btn.done {
    border-color: var(--success, #38a169);
    opacity: 0.5;
  }

  .table-btn.done:hover {
    opacity: 0.8;
  }

  .done-check {
    position: absolute;
    top: var(--space-1);
    right: var(--space-1);
    font-size: var(--text-xs);
    color: var(--success, #38a169);
    line-height: 1;
  }

  .error-msg {
    color: var(--danger, #e53e3e);
    text-align: center;
    padding: var(--space-4);
  }
</style>


</script>
