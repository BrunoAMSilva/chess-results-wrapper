---
import ResponsiveLayout from "../../../layouts/ResponsiveLayout.astro";
import RoundSelector from "../../../components/controls/RoundSelector.astro";
import RefereeSelectionTile from "../../../components/referee/RefereeSelectionTile.astro";
import { scrapePairings } from "../../../lib/scraper";
import { getRefereeResults, findLatestIncompleteRound } from "../../../lib/db";
import { useTranslations } from "../../../i18n/ui";
import { resolvePageLang } from "../../../lib/page-lang";
import type { LinkedTournament, Pairing, TeamPairing } from "../../../lib/types";

const tid = Astro.params.id!;
const lang = resolvePageLang(Astro.url, Astro.cookies);
const roundParam = Astro.url.searchParams.get("round");
const t = useTranslations(lang);

let error: string | null = null;
let totalRounds = 0;
let activeRound = 1;
let allPairings: Pairing[] = [];
let teamPairings: TeamPairing[] | undefined;
let linkedTournaments: LinkedTournament[] | undefined;
let currentLabel = "";
let tournamentName = "";
let tournamentDate = "";
let tournamentLocation = "";
let tournamentType = "";

try {
  const initial = await scrapePairings(tid, 1);
  totalRounds = initial.info.totalRounds;
  linkedTournaments = initial.info.linkedTournaments;
  tournamentName = initial.info.name;
  tournamentDate = initial.info.date || "";
  tournamentLocation = initial.info.location || "";
  tournamentType = initial.info.type || "";
  currentLabel = initial.info.currentLabel || initial.info.name;

  if (roundParam) {
    activeRound = Math.max(1, Math.min(parseInt(roundParam, 10) || 1, totalRounds));
  } else {
    // Use DB query instead of looping through all rounds via scrapePairings
    activeRound = findLatestIncompleteRound(tid, totalRounds);
  }

  const activeData = activeRound === 1 ? initial : await scrapePairings(tid, activeRound);
  allPairings = activeData.pairings || [];
  teamPairings = activeData.teamPairings;
} catch (e) {
  error = e instanceof Error ? e.message : t("error.load");
}

const hasSections = !!(linkedTournaments && linkedTournaments.length > 0);

// Section list for section picker
const sections: { id: string; name: string }[] = [];
if (hasSections) {
  sections.push({ id: tid, name: currentLabel });
  for (const lt of linkedTournaments!) {
    if (lt.id !== tid) {
      sections.push({ id: lt.id, name: lt.name });
    }
  }
  sections.sort((a, b) => a.name.localeCompare(b.name));
}

// Table grid data (only when no sections — tables shown inline)
const tables: number[] = [];
const isTeamTournament = !!(teamPairings && teamPairings.length > 0);
if (!hasSections) {
  if (teamPairings && teamPairings.length > 0) {
    for (const tm of teamPairings) {
      for (const b of tm.boards) {
        tables.push(b.table);
      }
    }
  } else {
    for (const p of allPairings) {
      tables.push(p.table);
    }
  }
  tables.sort((a, b) => a - b);
}

function formatTableLabel(table: number): string {
  if (isTeamTournament) {
    const match = Math.floor(table / 100);
    const board = table % 100;
    return `${match}.${board}`;
  }
  return String(table);
}

const submittedTables = new Set<number>();
if (!hasSections) {
  const refResults = getRefereeResults(tid, activeRound) as Array<{ table_number: number }>;
  for (const r of refResults) {
    submittedTables.add(r.table_number);
  }
}

const sectionTitle = currentLabel || t("referee.selectTable");
const title = hasSections ? t("referee.selectSection") : sectionTitle;
const eyebrow = tournamentName && tournamentName !== title ? tournamentName : undefined;
const q = `round=${activeRound}&lang=${lang}`;
const rounds = Array.from({ length: totalRounds }, (_, i) => i + 1);
const roundBaseUrl = `/referee/${tid}?lang=${lang}`;
---

<ResponsiveLayout title={title} eyebrow={eyebrow} lang={lang} navMode="referee">
  {error && <div class="error-msg"><p>{error}</p></div>}

  <div class="referee-page">
    <RoundSelector rounds={rounds} activeRound={activeRound} baseUrl={roundBaseUrl} label={t("referee.round")} />

    {hasSections ? (
      <div class="section-list">
        {sections.map((s) => (
          <RefereeSelectionTile
            href={`/referee/${tid}/${s.id}?${q}`}
            label={s.name}
            showArrow
          />
        ))}
      </div>
    ) : (
      <div class="table-grid">
        {tables.map((tbl) => (
          <RefereeSelectionTile
            href={`/referee/${tid}/${tid}/${tbl}?${q}`}
            variant="table"
            label={formatTableLabel(tbl)}
            eyebrow={t("referee.table")}
            done={submittedTables.has(tbl)}
            doneLabel={t("referee.saved")}
          />
        ))}
      </div>
    )}
  </div>
</ResponsiveLayout>

<style>
  .referee-page {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }



  .section-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    width: 100%;
  }

  .table-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
    width: 100%;
  }

  .error-msg {
    color: var(--danger);
    text-align: center;
    padding: var(--space-4);
  }

  @media (max-width: 720px) {
    .table-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 460px) {
    .table-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script is:inline define:vars={{ tid, tournamentName, tournamentDate, tournamentLocation, tournamentType }}>
  (function () {
    try {
      if (!tid) return;
      var key = "recentTournaments";
      var stored = localStorage.getItem(key);
      var recent = stored ? JSON.parse(stored) : [];
      var existing = recent.find(function (r) {
        return r.id === tid;
      });
      recent = recent.filter(function (r) {
        return r.id !== tid;
      });
      recent.unshift({
        id: tid,
        name: tournamentName || (existing && existing.name) || ("Tournament " + tid),
        type: tournamentType || (existing && existing.type) || "",
        date: tournamentDate || (existing && existing.date) || "",
        location: tournamentLocation || (existing && existing.location) || "",
        playerCount: existing && typeof existing.playerCount === "number"
          ? existing.playerCount
          : undefined,
      });
      recent = recent.slice(0, 5);
      localStorage.setItem(key, JSON.stringify(recent));
    } catch (e) {
      /* localStorage unavailable */
    }
  })();
</script>
