---
import ResponsiveLayout from "../../../../layouts/ResponsiveLayout.astro";
import ActionButton from "../../../../components/controls/ActionButton.astro";
import { scrapePairings } from "../../../../lib/scraper";
import { useTranslations } from "../../../../i18n/ui";
import { resolvePageLang } from "../../../../lib/page-lang";
import type { Pairing, TeamPairing } from "../../../../lib/types";
import Matchup from "../../../../components/referee/Matchup.astro";
import ResultOptions from "../../../../components/referee/ResultOptions.astro";
import { getRefereeResults, getTournament } from "../../../../lib/db";

const tid = Astro.params.id!;
const section = Astro.params.section!;
const tableNum = parseInt(Astro.params.table!, 10);
const lang = resolvePageLang(Astro.url, Astro.cookies);
const roundParam = Astro.url.searchParams.get("round");
const t = useTranslations(lang);

let error: string | null = null;
let activeRound = 1;
let whiteName = "";
let blackName = "";
let tournamentName = "";
let sectionTitle = "";

try {
  // Try DB first for tournament metadata to avoid scraping round 1 just for meta
  const dbTournament = getTournament(section);
  let totalRounds = dbTournament?.total_rounds ?? 0;

  if (roundParam) {
    activeRound = Math.max(1, Math.min(parseInt(roundParam, 10) || 1, totalRounds || 99));
  }

  // Only scrape the round we need (the active round for this table)
  const data = await scrapePairings(section, activeRound);
  if (!totalRounds) totalRounds = data.info.totalRounds;
  if (roundParam) {
    activeRound = Math.max(1, Math.min(activeRound, totalRounds));
  }
  tournamentName = data.info.name;
  sectionTitle = data.info.currentLabel || data.info.name;

  const pairings: Pairing[] = data.pairings || [];
  const teamPairings: TeamPairing[] | undefined = data.teamPairings;

  // Find player names for this table
  if (teamPairings && teamPairings.length > 0) {
    for (const tm of teamPairings) {
      for (const b of tm.boards) {
        if (b.table === tableNum) {
          whiteName = b.white.name;
          blackName = b.black?.name || "—";
          break;
        }
      }
    }
  } else {
    for (const p of pairings) {
      if (p.table === tableNum) {
        whiteName = p.white.name;
        blackName = p.black?.name || "—";
        break;
      }
    }
  }
} catch (e) {
  error = e instanceof Error ? e.message : t("error.load");
}

// Look up any previously saved result for this table
const existingResults = getRefereeResults(section, activeRound);
const existingResult = existingResults.find(r => r.table_number === tableNum)?.result;

const isTeamTournament = tableNum >= 100;
const tableLabel = isTeamTournament
  ? `${Math.floor(tableNum / 100)}.${tableNum % 100}`
  : String(tableNum);

const q = `round=${activeRound}&lang=${lang}`;
// Back goes to the table grid for this section
const backUrl = `/referee/${tid}/${section}?${q}`;
const eyebrow = sectionTitle && sectionTitle !== `${t("referee.table")} ${tableLabel}`
  ? sectionTitle
  : tournamentName || undefined;
---

<ResponsiveLayout title={`${t("referee.table")} ${tableLabel}`} eyebrow={eyebrow} lang={lang} navMode="referee">
  {error && <div class="error-msg"><p>{error}</p></div>}

  <div class="result-page">
    <Matchup
      whiteName={whiteName}
      blackName={blackName}
    />

    <form
      class="result-form"
      id="resultForm"
      action="/api/referee-result"
      method="POST"
    >
      <input type="hidden" name="tid" value={section} />
      <input type="hidden" name="round" value={String(activeRound)} />
      <input type="hidden" name="table" value={String(tableNum)} />
      <input type="hidden" name="_redirect" value={backUrl} />

      <ResultOptions value={existingResult} />
      <ActionButton class="save-btn" id="saveBtn" type="submit" size="large" fullWidth>
        <span class="save-label">{t("referee.save")} →</span>
        <span class="saving-label" aria-hidden="true">{t("referee.saving")}</span>
      </ActionButton>
    </form>

    <div class="feedback hidden" id="feedback" aria-live="assertive" tabindex="-1"></div>
  </div>
</ResponsiveLayout>

<style>
  .result-page {
    max-width: 500px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .result-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    width: 100%;
  }

  :global(.save-btn) {
    margin-top: var(--space-4);
  }

  :global(.save-btn:active) {
    transform: scale(0.98);
  }

  :global(.save-btn[aria-disabled="true"]) {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .saving-label {
    display: none;
  }

  :global(.save-btn[aria-disabled="true"] .save-label) {
    display: none;
  }

  :global(.save-btn[aria-disabled="true"] .saving-label) {
    display: inline;
  }

  .hidden {
    display: none;
  }

  .form-hidden {
    display: none;
  }

  .feedback {
    text-align: center;
    margin-top: var(--space-4);
    padding: var(--space-4);
    border-radius: var(--radius-md);
    font-weight: var(--font-semibold);
    width: 100%;
  }

  .feedback.error {
    background: var(--loss);
    color: var(--on-loss);
  }

  .error-msg {
    color: var(--danger);
    text-align: center;
    padding: var(--space-4);
  }
</style>

<script is:inline define:vars={{
  errorMsg: t("referee.error"),
}}>
(function() {
  var form = document.getElementById("resultForm");
  var saveBtn = document.getElementById("saveBtn");
  var feedback = document.getElementById("feedback");
  var gameRadios = document.querySelectorAll('input[name="gameResult"]');

  var saving = false;

  // Hide save button — selection auto-submits
  if (saveBtn) saveBtn.classList.add("hidden");

  function submitResult() {
    if (saving || !form) return;

    var fd = new FormData(form);
    var result = fd.get("gameResult");

    // If no result selected (cleared), send DELETE and redirect
    if (!result) {
      saving = true;
      gameRadios.forEach(function(r) { r.disabled = true; });
      fetch(form.action, {
        method: "DELETE",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          tid: fd.get("tid"),
          round: Number(fd.get("round")),
          table: Number(fd.get("table")),
        }),
      })
      .then(function() {
        window.location.href = form.querySelector('input[name="_redirect"]').value;
      })
      .catch(function() {
        saving = false;
        gameRadios.forEach(function(r) { r.disabled = false; });
      });
      return;
    }

    saving = true;
    // Disable all radios to prevent double-tap
    gameRadios.forEach(function(r) { r.disabled = true; });

    fetch(form.action, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        tid: fd.get("tid"),
        round: Number(fd.get("round")),
        table: Number(fd.get("table")),
        result: result,
      }),
    })
    .then(function(res) { return res.json().then(function(data) { return { ok: res.ok, data: data }; }); })
    .then(function(resp) {
      if (resp.ok) {
        window.location.href = form.querySelector('input[name="_redirect"]').value;
      } else {
        if (feedback) {
          feedback.classList.remove("hidden", "success", "error");
          feedback.classList.add("error");
          feedback.textContent = resp.data.error || errorMsg;
          feedback.focus();
        }
        saving = false;
        gameRadios.forEach(function(r) { r.disabled = false; });
      }
    })
    .catch(function() {
      if (feedback) {
        feedback.classList.remove("hidden", "success", "error");
        feedback.classList.add("error");
        feedback.textContent = errorMsg;
        feedback.focus();
      }
      saving = false;
      gameRadios.forEach(function(r) { r.disabled = false; });
    });
  }

  // Auto-submit on selection
  gameRadios.forEach(function(radio) {
    radio.addEventListener("change", submitResult);
  });

  // Keep form submit as fallback (no-JS progressive enhancement)
  if (form) {
    form.addEventListener("submit", function(e) {
      e.preventDefault();
      submitResult();
    });
  }
})();
</script>
