---
import ResponsiveLayout from "../../../../layouts/ResponsiveLayout.astro";
import RoundSelector from "../../../../components/controls/RoundSelector.astro";
import RefereeSelectionTile from "../../../../components/referee/RefereeSelectionTile.astro";
import { scrapePairings } from "../../../../lib/scraper";
import { getRefereeResults, findLatestIncompleteRound } from "../../../../lib/db";
import { useTranslations } from "../../../../i18n/ui";
import { resolvePageLang } from "../../../../lib/page-lang";
import type { Pairing, TeamPairing } from "../../../../lib/types";

const tid = Astro.params.id!;
const section = Astro.params.section!;
const lang = resolvePageLang(Astro.url, Astro.cookies);
const roundParam = Astro.url.searchParams.get("round");
const t = useTranslations(lang);

let error: string | null = null;
let totalRounds = 0;
let activeRound = 1;
let allPairings: Pairing[] = [];
let teamPairings: TeamPairing[] | undefined;
let tournamentName = "";
let sectionTitle = "";

try {
  const initial = await scrapePairings(section, 1);
  totalRounds = initial.info.totalRounds;
  tournamentName = initial.info.name;
  sectionTitle = initial.info.currentLabel || initial.info.name;

  if (roundParam) {
    activeRound = Math.max(1, Math.min(parseInt(roundParam, 10) || 1, totalRounds));
  } else {
    // Use DB query instead of looping through all rounds via scrapePairings
    activeRound = findLatestIncompleteRound(section, totalRounds);
  }

  const activeData = activeRound === 1 ? initial : await scrapePairings(section, activeRound);
  allPairings = activeData.pairings || [];
  teamPairings = activeData.teamPairings;
} catch (e) {
  error = e instanceof Error ? e.message : t("error.load");
}

// Build table list
const tables: number[] = [];
const isTeamTournament = !!(teamPairings && teamPairings.length > 0);
if (teamPairings && teamPairings.length > 0) {
  for (const tm of teamPairings) {
    for (const b of tm.boards) {
      tables.push(b.table);
    }
  }
} else {
  for (const p of allPairings) {
    tables.push(p.table);
  }
}
tables.sort((a, b) => a - b);

function formatTableLabel(table: number): string {
  if (isTeamTournament) {
    const match = Math.floor(table / 100);
    const board = table % 100;
    return `${match}.${board}`;
  }
  return String(table);
}

const RESULT_DISPLAY: Record<string, string> = {
  "+:-": "1-0F",
  "-:+": "0-1F",
  "-:-": "0-0F",
};

type ResultType = "white-win" | "black-win" | "draw" | "forfeit-white" | "forfeit-black" | "forfeit-both";
function resultToType(result: string): ResultType {
  if (result === "+:-") return "forfeit-white";
  if (result === "-:+") return "forfeit-black";
  if (result === "-:-") return "forfeit-both";
  if (result === "1-0") return "white-win";
  if (result === "0-1") return "black-win";
  return "draw";
}

function resultDisplayLabel(result: string): string {
  return RESULT_DISPLAY[result] ?? result;
}

const submittedTables = new Map<number, { result: string; type: ResultType }>();
const refResults = getRefereeResults(section, activeRound) as Array<{ table_number: number; result: string }>;
for (const r of refResults) {
  submittedTables.set(r.table_number, { result: r.result, type: resultToType(r.result) });
}

const q = `round=${activeRound}&lang=${lang}`;
const rounds = Array.from({ length: totalRounds }, (_, i) => i + 1);
const roundBaseUrl = `/referee/${tid}/${section}?lang=${lang}`;
const pageTitle = sectionTitle || t("referee.selectTable");
const eyebrow = tournamentName && tournamentName !== pageTitle ? tournamentName : undefined;
---

<ResponsiveLayout title={pageTitle} eyebrow={eyebrow} lang={lang} navMode="referee">
  {error && <div class="error-msg"><p>{error}</p></div>}

  <div class="referee-page">
    <RoundSelector rounds={rounds} activeRound={activeRound} baseUrl={roundBaseUrl} label={t("referee.round")} />

    <div class="table-grid">
      {tables.map((tbl) => (
        <RefereeSelectionTile
          href={`/referee/${tid}/${section}/${tbl}?${q}`}
          variant="table"
          label={formatTableLabel(tbl)}
          done={submittedTables.has(tbl)}
          doneLabel={submittedTables.has(tbl) ? resultDisplayLabel(submittedTables.get(tbl)!.result) : undefined}
          resultType={submittedTables.get(tbl)?.type}
        />
      ))}
    </div>
  </div>
</ResponsiveLayout>

<style>
  .referee-page {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }



  .table-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
    width: 100%;
  }

  .error-msg {
    color: var(--danger);
    text-align: center;
    padding: var(--space-4);
  }

  @media (max-width: 720px) {
    .table-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 460px) {
    .table-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>


