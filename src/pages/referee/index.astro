---
import ResponsiveLayout from "../../layouts/ResponsiveLayout.astro";
import RecentTournaments from "../../components/RecentTournaments.astro";
import { scrapePairings } from "../../lib/scraper";
import { getRefereeResults } from "../../lib/db";
import { useTranslations } from "../../i18n/ui";
import { getIntParam } from "../../lib/request-params";
import { resolvePageLang } from "../../lib/page-lang";
import type { LinkedTournament, Pairing, TeamPairing } from "../../lib/types";

const tid = Astro.url.searchParams.get("tid") || "";
const lang = resolvePageLang(Astro.url, Astro.cookies);
const stepParam = getIntParam(Astro.url.searchParams.get("step"), -1, 0, 2);
const roundParam = Astro.url.searchParams.get("round");

const t = useTranslations(lang);

const hasTournament = tid.length > 0;

let error: string | null = null;
let totalRounds = 0;
let activeRound = 1;
let allPairings: Pairing[] = [];
let teamPairings: TeamPairing[] | undefined;
let linkedTournaments: LinkedTournament[] | undefined;
let currentLabel = "";

if (hasTournament) {
  try {
  // First fetch round 1 to get totalRounds and tournament metadata
  const initial = await scrapePairings(tid, 1, lang);
  totalRounds = initial.info.totalRounds;
  linkedTournaments = initial.info.linkedTournaments;
  currentLabel = initial.info.currentLabel || initial.info.name;

  // Use explicit round param if provided, otherwise auto-detect
  if (roundParam) {
    activeRound = Math.max(1, Math.min(parseInt(roundParam, 10) || 1, totalRounds));
  } else {
    // Find the latest round without results: scan from the last round backwards
    let foundRound = 1;
    for (let r = totalRounds; r >= 1; r--) {
      const data = r === 1 ? initial : await scrapePairings(tid, r, lang);
      const pairings = data.pairings || [];
      const hasNoResults = pairings.length > 0 && pairings.every((p) => !p.result || p.result.trim() === "");
      if (hasNoResults) {
        foundRound = r;
      } else if (pairings.length > 0) {
        break;
      }
    }
    activeRound = foundRound;
  }

  // Fetch the active round's pairings
  const activeData = activeRound === 1 ? initial : await scrapePairings(tid, activeRound, lang);
  allPairings = activeData.pairings || [];
  teamPairings = activeData.teamPairings;
} catch (e) {
  error = e instanceof Error ? e.message : t("error.load");
}
}

// Build section list: current + linked tournaments
const sections: { id: string; name: string }[] = [];
if (linkedTournaments && linkedTournaments.length > 0) {
  sections.push({ id: tid, name: currentLabel });
  for (const lt of linkedTournaments) {
    if (lt.id !== tid) {
      sections.push({ id: lt.id, name: lt.name });
    }
  }
  sections.sort((a, b) => a.name.localeCompare(b.name));
}

// Build table list from pairings
const tables: number[] = [];
const isTeamTournament = !!(teamPairings && teamPairings.length > 0);
if (teamPairings && teamPairings.length > 0) {
  for (const tm of teamPairings) {
    for (const b of tm.boards) {
      tables.push(b.table);
    }
  }
} else {
  for (const p of allPairings) {
    tables.push(p.table);
  }
}
tables.sort((a, b) => a - b);

// Format table label: for team tournaments show "match.board" (e.g., "1.1")
function formatTableLabel(table: number): string {
  if (isTeamTournament) {
    const match = Math.floor(table / 100);
    const board = table % 100;
    return `${match}.${board}`;
  }
  return String(table);
}

// Build a lookup for table -> player names
const tablePlayersMap: Record<number, { white: string; black: string }> = {};
if (teamPairings && teamPairings.length > 0) {
  for (const tm of teamPairings) {
    for (const b of tm.boards) {
      tablePlayersMap[b.table] = {
        white: b.white.name,
        black: b.black?.name || "—",
      };
    }
  }
} else {
  for (const p of allPairings) {
    tablePlayersMap[p.table] = {
      white: p.white.name,
      black: p.black?.name || "—",
    };
  }
}

// Fetch submitted referee results for the active round
const submittedTables = new Set<number>();
if (hasTournament) {
  const refResults = getRefereeResults(tid, activeRound) as Array<{ table_number: number }>;
  for (const r of refResults) {
    submittedTables.add(r.table_number);
  }
}
---

<ResponsiveLayout title={t("referee.title")} lang={lang} navMode="referee">
  {!hasTournament ? (
    <div class="referee-search" id="refereeSearch">
      <h2 class="step-title">{t("referee.searchTournament")}</h2>
      <input
        type="text"
        id="searchInput"
        class="search-input"
        placeholder={t("referee.searchPlaceholder")}
        autofocus
      />
      <div class="search-results" id="searchResults"></div>
      <RecentTournaments recentLabel={t("home.recent")} linkBase="/referee" />
    </div>
  ) : (
    <>
      {error && (
        <div class="error-msg">
          <p>{error}</p>
        </div>
      )}

      <div class="referee-wizard" id="refereeWizard">
        <div class="wizard-top-links">
          <a class="change-tournament" href={`/referee?lang=${lang}`}>
            ← {t("referee.changeSection")}
          </a>
          <div class="top-actions">
            <a class="view-results-link" href={`/referee/results?tid=${tid}&lang=${lang}`}>
              {t("referee.viewResults")}
            </a>
            <a
              class="export-link"
              href={`/api/referee-export?tid=${tid}&round=${activeRound}`}
              download={`round-${activeRound}-results.xml`}
              title={t("referee.exportXml")}
            >
              ↓ XML
            </a>
          </div>
        </div>

        <!-- Step indicator -->
        <div class="step-indicator" id="stepIndicator">
          {sections.length > 0 && (<>
            <div class="step-dot active" data-step="0"></div>
            <div class="step-line"></div>
          </>)}
          <div class:list={["step-dot", { active: sections.length === 0 }]} data-step="1"></div>
          <div class="step-line"></div>
          <div class="step-dot" data-step="2"></div>
        </div>

        <!-- Round selector -->
    <div class="round-selector">
      <label for="roundSelect">{t("referee.round")}</label>
      <select id="roundSelect">
        {Array.from({ length: totalRounds }, (_, i) => i + 1).map((r) => (
          <option value={r} selected={r === activeRound}>{r}</option>
        ))}
      </select>
    </div>

    <!-- Step header: back button + step title -->
    <div class="step-header" id="stepHeader">
      <button class="back-header-btn hidden" id="backBtn" type="button">
        ←
      </button>
      <h2 class="step-title" id="stepTitle"></h2>
    </div>

    <!-- Step 0: Select Section (only if linked tournaments exist) -->
    {sections.length > 0 && (
      <div class="step" id="step-0" data-title={t("referee.selectSection")}>
        <div class="step-options">
          {sections.map((s) => (
            <button
              class:list={["option-btn", "section-btn", { selected: s.id === tid }]}
              data-section-id={s.id}
              type="button"
            >
              {s.name}
            </button>
          ))}
        </div>
      </div>
    )}

    <!-- Step 1: Select Table -->
    <div class:list={["step", { hidden: sections.length > 0 }]} id="step-1" data-title={t("referee.selectTable")}>
      <div class="table-grid" id="tableGrid">
        {tables.map((tbl) => (
          <button class:list={["table-btn", { done: submittedTables.has(tbl) }]} data-table={tbl} type="button">
            {formatTableLabel(tbl)}
            {submittedTables.has(tbl) && <span class="done-check">✓</span>}
          </button>
        ))}
      </div>
    </div>

    <!-- Step 2: Select Result -->
    <div class="step hidden" id="step-2" data-title={t("referee.selectResult")}>
      <div class="table-matchup" id="tableMatchup"></div>
      <div class="step-options result-options" id="resultOptions">
        <div class="result-row">
          <label class="result-card white-card">
            <input type="radio" name="gameResult" value="1-0" class="sr-only" />
            <span class="result-label">{t("referee.white")}</span>
            <span class="result-score">1 – 0</span>
          </label>
          <label class="result-card draw-card">
            <input type="radio" name="gameResult" value="½-½" class="sr-only" />
            <span class="result-label">{t("referee.draw")}</span>
            <span class="result-score">½ – ½</span>
          </label>
          <label class="result-card black-card">
            <input type="radio" name="gameResult" value="0-1" class="sr-only" />
            <span class="result-label">{t("referee.black")}</span>
            <span class="result-score">0 – 1</span>
          </label>
        </div>
        <div class="result-row absent-row">
          <label class="absent-card">
            <input type="checkbox" name="absentWhite" class="sr-only" />
            <span class="absent-check"></span>
            <span>{t("referee.whiteAbsent")}</span>
          </label>
          <label class="absent-card">
            <input type="checkbox" name="absentBlack" class="sr-only" />
            <span class="absent-check"></span>
            <span>{t("referee.blackAbsent")}</span>
          </label>
        </div>
        <button class="continue-btn hidden" id="confirmSaveBtn" type="button">
          {t("referee.save")} →
        </button>
      </div>
      <div class="save-feedback hidden" id="saveFeedback"></div>
    </div>
  </div>
    </>
  )}
</ResponsiveLayout>

<style>
  .referee-search {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-4) 0;
  }

  .search-input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--text);
    font-size: var(--text-base);
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-out);
    box-sizing: border-box;
  }

  .search-input:focus {
    border-color: var(--accent-400);
  }

  .search-results {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .search-result-item {
    display: block;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .search-result-item:hover {
    border-color: var(--accent-400);
  }

  .search-result-name {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
  }

  .search-result-meta {
    font-size: var(--text-xs);
    color: var(--text-dim);
    margin-top: var(--space-1);
  }

  .search-no-results {
    text-align: center;
    color: var(--text-dim);
    padding: var(--space-6);
  }

  .wizard-top-links {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-4);
  }

  .change-tournament {
    font-size: var(--text-sm);
    color: var(--text-dim);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .change-tournament:hover {
    color: var(--accent-400);
  }

  .back-header-btn {
    padding: var(--space-1) var(--space-2);
    border: none;
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--text-dim);
    font-size: var(--text-xl);
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-out);
    line-height: 1;
    flex-shrink: 0;
  }

  .back-header-btn:hover {
    color: var(--accent-400);
  }

  .back-header-btn.hidden {
    display: none;
  }

  .step-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    width: 100%;
  }

  .step-header .step-title {
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    color: var(--text);
    margin: 0;
    flex: 1;
  }

  .step-header:not(:has(.back-header-btn:not(.hidden))) .step-title {
    text-align: center;
  }

  .top-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .view-results-link {
    font-size: var(--text-sm);
    color: var(--accent-400);
    text-decoration: none;
    font-weight: var(--font-semibold);
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .export-link {
    font-size: var(--text-xs);
    color: var(--text-dim);
    text-decoration: none;
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    transition: all var(--duration-fast) var(--ease-out);
  }

  .export-link:hover {
    border-color: var(--accent-400);
    color: var(--accent-400);
  }

  .view-results-link:hover {
    opacity: 0.8;
  }

  .referee-wizard {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-4) 0;
  }

  .step-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
    margin-bottom: var(--space-8);
  }

  .step-dot {
    width: 12px;
    height: 12px;
    border-radius: var(--radius-full);
    background: var(--border);
    border: 2px solid transparent;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .step-dot.active {
    background: var(--accent-400);
    border-color: var(--accent-400);
    box-shadow: 0 0 0 3px rgba(252, 211, 77, 0.3);
  }

  .step-dot.completed {
    background: var(--green-400);
  }

  .step-line {
    width: 32px;
    height: 2px;
    background: var(--border);
  }

  .step.hidden {
    display: none;
  }

  .round-selector {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--text-dim);
  }

  .round-selector select {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
  }

  .referee-wizard {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .referee-wizard > .step,
  .referee-wizard > .wizard-nav {
    width: 100%;
  }

  .step-options {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .option-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4) var(--space-6);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--text);
    font-size: var(--text-lg);
    font-weight: var(--font-medium);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
    min-height: 56px;
    width: 100%;
    text-align: center;
  }

  .option-btn:hover {
    border-color: var(--accent-400);
    background: var(--surface-hover);
  }

  .option-btn.selected {
    border-color: var(--accent-400);
    background: var(--accent-400);
    color: var(--accent-text, #000);
  }

  .table-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-2);
  }

  .table-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--text);
    font-size: var(--text-4xl);
    font-weight: var(--font-bold);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
    aspect-ratio: 1;
    position: relative;
  }

  .table-btn:hover {
    border-color: var(--accent-400);
    color: var(--accent-400);
  }

  .table-btn.selected {
    background: var(--accent-400);
    border-color: var(--accent-400);
    color: var(--accent-text, #000);
  }

  .table-btn.done {
    border-color: var(--success, #38a169);
    opacity: 0.5;
  }

  .table-btn.done:hover {
    opacity: 0.8;
  }

  .done-check {
    position: absolute;
    top: var(--space-1);
    right: var(--space-1);
    font-size: var(--text-xs);
    color: var(--success, #38a169);
    line-height: 1;
  }

  .table-matchup {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--text-dim);
    margin-bottom: var(--space-4);
    padding: var(--space-2) var(--space-4);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }

  .table-matchup:empty {
    display: none;
  }

  .result-options {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .result-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }

  .absent-row {
    grid-template-columns: repeat(2, 1fr);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  .result-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-6) var(--space-3);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--text);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
    min-height: 88px;
  }

  .result-card:hover {
    border-color: var(--accent-400);
  }

  .result-card:has(input:checked) {
    border-color: var(--accent-400);
    background: var(--accent-400);
    color: var(--accent-text, #000);
  }

  .white-card:has(input:checked) {
    background: var(--surface);
    border-color: var(--text);
    color: var(--text);
  }

  .draw-card:has(input:checked) {
    background: var(--border);
    border-color: var(--text-dim);
    color: var(--text);
  }

  .black-card:has(input:checked) {
    background: var(--text);
    border-color: var(--text);
    color: var(--surface);
  }

  .result-options.has-absent .result-card {
    opacity: 0.4;
    pointer-events: none;
  }

  .result-score {
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
  }

  .absent-card {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--text);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
    min-height: 52px;
  }

  .absent-card:hover {
    border-color: var(--accent-400);
  }

  .absent-check {
    display: inline-block;
    width: 18px;
    height: 18px;
    border: 2px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    transition: all var(--duration-fast) var(--ease-out);
    flex-shrink: 0;
  }

  .absent-card:has(input:checked) {
    border-color: var(--danger, #e53e3e);
    background: var(--danger, #e53e3e);
    color: #fff;
  }

  .absent-card:has(input:checked) .absent-check {
    border-color: #fff;
    background: #fff;
  }

  .continue-btn {
    width: 100%;
    margin-top: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border: 2px solid var(--accent-400);
    border-radius: var(--radius-lg);
    background: var(--accent-400);
    color: var(--accent-text, #000);
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    cursor: pointer;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .continue-btn:hover {
    opacity: 0.9;
  }

  .save-feedback {
    text-align: center;
    margin-top: var(--space-4);
    padding: var(--space-4);
    border-radius: var(--radius-md);
    font-weight: var(--font-semibold);
  }

  .save-feedback.success {
    background: var(--green-400);
    color: #000;
  }

  .save-feedback.error {
    background: var(--red-400);
    color: #fff;
  }

  .save-feedback.hidden {
    display: none;
  }

  .another-btn {
    width: 100%;
    margin-top: var(--space-4);
    padding: var(--space-4) var(--space-6);
    border: 2px solid var(--accent-400);
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--accent-400);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    cursor: pointer;
  }
</style>

<script is:inline define:vars={{
  searchLang: lang,
  noResultsMsg: t("referee.noResults"),
}}>
(function() {
  var searchInput = document.getElementById("searchInput");
  var searchResults = document.getElementById("searchResults");
  if (!searchInput || !searchResults) return;

  var debounceTimer = null;

  function extractTournamentId(input) {
    if (/^\d+$/.test(input)) return input;
    var urlMatch = input.match(/chess-results\.com\/tnr(\d+)\.aspx/i);
    if (urlMatch) return urlMatch[1];
    return null;
  }

  function navigateToTournament(tid) {
    window.location.href = "/referee?tid=" + encodeURIComponent(tid) + "&lang=" + searchLang;
  }

  // Handle Enter key for direct ID/URL submission
  searchInput.addEventListener("keydown", function(e) {
    if (e.key === "Enter") {
      e.preventDefault();
      var raw = searchInput.value.trim();
      var tid = extractTournamentId(raw);
      if (tid) navigateToTournament(tid);
    }
  });

  searchInput.addEventListener("input", function() {
    clearTimeout(debounceTimer);
    var query = searchInput.value.trim();
    if (query.length < 2) {
      searchResults.innerHTML = "";
      return;
    }

    // If it looks like a numeric ID or URL, don't search — just show direct option
    var directId = extractTournamentId(query);
    if (directId) {
      var href = "/referee?tid=" + encodeURIComponent(directId) + "&lang=" + searchLang;
      searchResults.innerHTML = '<a class="search-result-item" href="' + href + '">'
        + '<div class="search-result-name">ID: ' + escapeHtml(directId) + '</div>'
        + '<div class="search-result-meta">↗</div>'
        + '</a>';
      return;
    }

    debounceTimer = setTimeout(function() {
      fetch("/api/search?q=" + encodeURIComponent(query) + "&limit=10")
        .then(function(res) { return res.json(); })
        .then(function(items) {
          if (items.length === 0) {
            searchResults.innerHTML = '<div class="search-no-results">' + noResultsMsg + '</div>';
            return;
          }
          searchResults.innerHTML = items.map(function(item) {
            var href = "/referee?tid=" + encodeURIComponent(item.id) + "&lang=" + searchLang;
            var meta = [item.date, item.location].filter(Boolean).join(" • ");
            return '<a class="search-result-item" href="' + href + '">'
              + '<div class="search-result-name">' + escapeHtml(item.name) + '</div>'
              + (meta ? '<div class="search-result-meta">' + escapeHtml(meta) + '</div>' : '')
              + '</a>';
          }).join("");
        });
    }, 300);
  });

  function escapeHtml(str) {
    var div = document.createElement("div");
    div.textContent = str;
    return div.innerHTML;
  }
})();
</script>

<script is:inline define:vars={{
  initialTid: tid,
  activeRound,
  totalRounds,
  hasSections: sections.length > 0,
  tablePlayersJson: JSON.stringify(tablePlayersMap),
  savedMsg: t("referee.saved"),
  errorMsg: t("referee.error"),
  anotherLabel: t("referee.another"),
  lang,
  stepParam,
}}>
(function() {
  var wizard = document.getElementById("refereeWizard");
  if (!wizard) return;

  var tablePlayers = JSON.parse(tablePlayersJson);

  // Steps: 0=section (if exists), 1=table, 2=result
  var firstStep = hasSections ? 0 : 1;
  var startStep;
  if (stepParam >= 0) {
    startStep = stepParam;
  } else {
    startStep = firstStep;
  }

  var currentStep = startStep;
  var selectedSection = initialTid;
  var selectedSectionName = "";
  var selectedTable = null;
  var selectedResult = null;
  var saving = false;

  var steps = [
    document.getElementById("step-0"),
    document.getElementById("step-1"),
    document.getElementById("step-2"),
  ];
  var dots = wizard.querySelectorAll(".step-dot");
  var backBtn = document.getElementById("backBtn");
  var changeTournamentLink = wizard.querySelector(".change-tournament");
  var stepTitleEl = document.getElementById("stepTitle");

  // Initialize section name from pre-selected
  var preSelectedSection = wizard.querySelector(".section-btn.selected");
  if (preSelectedSection) {
    selectedSectionName = preSelectedSection.textContent.trim();
  }

  function showStep(step) {
    steps.forEach(function(s, i) {
      if (s) s.classList.toggle("hidden", i !== step);
    });
    dots.forEach(function(d) {
      var dotStep = parseInt(d.getAttribute("data-step"));
      d.classList.toggle("active", dotStep === step);
      d.classList.toggle("completed", dotStep < step);
    });
    var canGoBack = step > firstStep;
    if (backBtn) backBtn.classList.toggle("hidden", !canGoBack);
    if (changeTournamentLink) changeTournamentLink.classList.toggle("hidden", canGoBack);
    // Update step title from active step's data-title
    if (stepTitleEl && steps[step]) {
      stepTitleEl.textContent = steps[step].getAttribute("data-title") || "";
    }
  }

  function advanceTo(step) {
    currentStep = step;
    showStep(step);
  }

  var currentRound = activeRound;

  function buildUrl(overrides) {
    var tid = overrides.tid || selectedSection;
    var st = overrides.step != null ? overrides.step : "";
    var url = "/referee?tid=" + encodeURIComponent(tid) + "&lang=" + lang;
    if (st !== "" && st >= 0) url += "&step=" + st;
    url += "&round=" + currentRound;
    return url;
  }

  // Section buttons
  wizard.querySelectorAll(".section-btn").forEach(function(btn) {
    btn.addEventListener("click", function() {
      wizard.querySelectorAll(".section-btn").forEach(function(b) { b.classList.remove("selected"); });
      btn.classList.add("selected");
      selectedSection = btn.getAttribute("data-section-id");
      selectedSectionName = btn.textContent.trim();

      // Navigate to the selected section, advancing to table step
      setTimeout(function() {
        window.location.href = buildUrl({ tid: selectedSection, step: 1 });
      }, 200);
    });
  });

  // Table buttons
  var tableMatchup = document.getElementById("tableMatchup");
  wizard.querySelectorAll(".table-btn").forEach(function(btn) {
    btn.addEventListener("click", function() {
      wizard.querySelectorAll(".table-btn").forEach(function(b) { b.classList.remove("selected"); });
      btn.classList.add("selected");
      selectedTable = parseInt(btn.getAttribute("data-table"));

      // Show matchup in result step
      var players = tablePlayers[selectedTable];
      if (tableMatchup && players) {
        tableMatchup.textContent = players.white + " vs " + players.black;
      }

      setTimeout(function() { advanceTo(2); }, 200);
    });
  });

  // Result radios & absent checkboxes
  var resultOptions = document.getElementById("resultOptions");
  var confirmSaveBtn = document.getElementById("confirmSaveBtn");
  var gameRadios = wizard.querySelectorAll('input[name="gameResult"]');
  var absentWhite = wizard.querySelector('input[name="absentWhite"]');
  var absentBlack = wizard.querySelector('input[name="absentBlack"]');
  var feedback = document.getElementById("saveFeedback");

  function saveResult() {
    if (saving || !selectedResult || !selectedTable) return;
    saving = true;
    if (confirmSaveBtn) confirmSaveBtn.classList.add("hidden");
    if (resultOptions) resultOptions.classList.add("has-absent");
    fetch("/api/referee-result", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        tid: selectedSection,
        round: activeRound,
        table: selectedTable,
        result: selectedResult,
      }),
    })
      .then(function(res) { return res.json().then(function(data) { return { ok: res.ok, data: data }; }); })
      .then(function(resp) {
        if (feedback) {
          feedback.classList.remove("hidden", "success", "error");
          if (resp.ok) {
            feedback.classList.add("success");
            feedback.textContent = savedMsg;

            // Mark table as done client-side
            var doneBtn = wizard.querySelector('.table-btn[data-table="' + selectedTable + '"]');
            if (doneBtn && !doneBtn.classList.contains("done")) {
              doneBtn.classList.add("done");
              var check = document.createElement("span");
              check.className = "done-check";
              check.textContent = "✓";
              doneBtn.appendChild(check);
            }

            var anotherBtn = document.createElement("button");
            anotherBtn.className = "another-btn";
            anotherBtn.textContent = anotherLabel;
            anotherBtn.addEventListener("click", function() {
              selectedTable = null;
              selectedResult = null;
              saving = false;
              gameRadios.forEach(function(r) { r.checked = false; });
              if (absentWhite) absentWhite.checked = false;
              if (absentBlack) absentBlack.checked = false;
              if (resultOptions) resultOptions.classList.remove("has-absent");
              if (confirmSaveBtn) confirmSaveBtn.classList.add("hidden");
              wizard.querySelectorAll(".table-btn").forEach(function(b) { b.classList.remove("selected"); });
              feedback.classList.add("hidden");
              var old = wizard.querySelectorAll(".another-btn");
              old.forEach(function(o) { o.remove(); });
              advanceTo(1);
            });
            feedback.parentNode.insertBefore(anotherBtn, feedback.nextSibling);
          } else {
            feedback.classList.add("error");
            feedback.textContent = resp.data.error || errorMsg;
            saving = false;
            if (resultOptions) resultOptions.classList.remove("has-absent");
          }
        }
      })
      .catch(function() {
        if (feedback) {
          feedback.classList.remove("hidden", "success", "error");
          feedback.classList.add("error");
          feedback.textContent = errorMsg;
        }
        saving = false;
        if (resultOptions) resultOptions.classList.remove("has-absent");
      });
  }

  // Game result radios — show confirm button on selection
  gameRadios.forEach(function(radio) {
    radio.addEventListener("change", function() {
      if (absentWhite) absentWhite.checked = false;
      if (absentBlack) absentBlack.checked = false;
      if (resultOptions) resultOptions.classList.remove("has-absent");

      selectedResult = radio.value;
      if (confirmSaveBtn) confirmSaveBtn.classList.remove("hidden");
    });
  });

  // Absence checkboxes
  function handleAbsentChange() {
    var wAbsent = absentWhite && absentWhite.checked;
    var bAbsent = absentBlack && absentBlack.checked;

    if (wAbsent || bAbsent) {
      gameRadios.forEach(function(r) { r.checked = false; });
      if (resultOptions) resultOptions.classList.add("has-absent");

      if (wAbsent && bAbsent) {
        selectedResult = "-:-";
      } else if (wAbsent) {
        selectedResult = "-:+";
      } else {
        selectedResult = "+:-";
      }
      if (confirmSaveBtn) confirmSaveBtn.classList.remove("hidden");
    } else {
      if (resultOptions) resultOptions.classList.remove("has-absent");
      selectedResult = null;
      if (confirmSaveBtn) confirmSaveBtn.classList.add("hidden");
    }
  }

  if (absentWhite) absentWhite.addEventListener("change", handleAbsentChange);
  if (absentBlack) absentBlack.addEventListener("change", handleAbsentChange);

  if (confirmSaveBtn) {
    confirmSaveBtn.addEventListener("click", function() {
      if (selectedResult) saveResult();
    });
  }

  // Back button
  if (backBtn) {
    backBtn.addEventListener("click", function() {
      var old = wizard.querySelectorAll(".another-btn");
      old.forEach(function(o) { o.remove(); });
      if (feedback) feedback.classList.add("hidden");
      saving = false;
      gameRadios.forEach(function(r) { r.checked = false; });
      if (absentWhite) absentWhite.checked = false;
      if (absentBlack) absentBlack.checked = false;
      if (resultOptions) resultOptions.classList.remove("has-absent");
      if (confirmSaveBtn) confirmSaveBtn.classList.add("hidden");

      if (currentStep === 2) {
        selectedTable = null;
        wizard.querySelectorAll(".table-btn").forEach(function(b) { b.classList.remove("selected"); });
        advanceTo(1);
      } else if (currentStep === 1 && hasSections) {
        window.location.href = buildUrl({ step: 0 });
      }
    });
  }

  // Round selector — navigate to reload pairings for the chosen round
  var roundSelect = document.getElementById("roundSelect");
  if (roundSelect) {
    roundSelect.addEventListener("change", function() {
      currentRound = parseInt(roundSelect.value, 10);
      window.location.href = buildUrl({ step: hasSections ? 1 : -1 });
    });
  }

  showStep(currentStep);
})();
</script>
