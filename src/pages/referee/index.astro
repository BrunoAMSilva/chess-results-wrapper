---
import ResponsiveLayout from "../../layouts/ResponsiveLayout.astro";
import RecentTournaments from "../../components/tournaments/RecentTournaments.astro";
import TournamentSearchForm from "../../components/tournaments/TournamentSearchForm.astro";
import { useTranslations } from "../../i18n/ui";
import { resolvePageLang } from "../../lib/page-lang";

const lang = resolvePageLang(Astro.url, Astro.cookies);
const t = useTranslations(lang);
---

<ResponsiveLayout title={t("referee.searchTournament")} lang={lang} navMode="none">
  <div class="referee-search" id="refereeSearch">
    <TournamentSearchForm
      label={t("referee.searchTournament")}
      placeholder={t("referee.searchPlaceholder")}
      loadingMessage={t("home.loading")}
      noResultsMessage={t("referee.noResults")}
      lang={String(lang)}
      navigatePathTemplate="/referee/{id}"
      searchLimit={10}
      showSubmit={false}
      resultLayout="stacked"
      autofocus
      class="referee-search-form"
    />
    <RecentTournaments recentLabel={t("home.recent")} linkBase="/referee/{id}" />
  </div>
</ResponsiveLayout>

<style>
  .referee-search {
    max-width: 640px;
    margin: 0 auto;
    padding: var(--space-4) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  :global(.referee-search-form) {
    margin-top: 0;
    gap: var(--space-3);
  }

  :global(.referee-search-form .search-input) {
    background:
      linear-gradient(140deg, color-mix(in srgb, var(--primary-fixed-dim) 6%, transparent), transparent 48%),
      var(--input-bg);
  }
</style>
