---
import ResponsiveLayout from "../../layouts/ResponsiveLayout.astro";
import RecentTournaments from "../../components/RecentTournaments.astro";
import { useTranslations } from "../../i18n/ui";
import { resolvePageLang } from "../../lib/page-lang";

const lang = resolvePageLang(Astro.url, Astro.cookies);
const t = useTranslations(lang);
---

<ResponsiveLayout title={t("referee.searchTournament")} lang={lang} navMode="none">
  <div class="referee-search" id="refereeSearch">
    <h2 class="step-title">{t("referee.searchTournament")}</h2>
    <input
      type="text"
      id="searchInput"
      class="search-input"
      placeholder={t("referee.searchPlaceholder")}
      autofocus
    />
    <div class="search-results" id="searchResults"></div>
    <RecentTournaments recentLabel={t("home.recent")} linkBase="/referee/{id}/tables" />
  </div>
</ResponsiveLayout>

<style>
  .referee-search {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-4) 0;
  }

  .step-title {
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    color: var(--text);
    text-align: center;
    margin-bottom: var(--space-6);
  }

  .search-input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--text);
    font-size: var(--text-base);
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-out);
    box-sizing: border-box;
  }

  .search-input:focus {
    border-color: var(--accent-400);
  }

  .search-results {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .search-result-item {
    display: block;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .search-result-item:hover {
    border-color: var(--accent-400);
  }

  .search-result-name {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
  }

  .search-result-meta {
    font-size: var(--text-xs);
    color: var(--text-dim);
    margin-top: var(--space-1);
  }

  .search-no-results {
    text-align: center;
    color: var(--text-dim);
    padding: var(--space-6);
  }
</style>

<script is:inline define:vars={{
  searchLang: lang,
  noResultsMsg: t("referee.noResults"),
}}>
(function() {
  var searchInput = document.getElementById("searchInput");
  var searchResults = document.getElementById("searchResults");
  if (!searchInput || !searchResults) return;

  var debounceTimer = null;

  function extractTournamentId(input) {
    if (/^\d+$/.test(input)) return input;
    var urlMatch = input.match(/chess-results\.com\/tnr(\d+)\.aspx/i);
    if (urlMatch) return urlMatch[1];
    return null;
  }

  function navigateToTournament(tid) {
    window.location.href = "/referee/" + encodeURIComponent(tid) + "/tables?lang=" + searchLang;
  }

  searchInput.addEventListener("keydown", function(e) {
    if (e.key === "Enter") {
      e.preventDefault();
      var raw = searchInput.value.trim();
      var tid = extractTournamentId(raw);
      if (tid) navigateToTournament(tid);
    }
  });

  searchInput.addEventListener("input", function() {
    clearTimeout(debounceTimer);
    var query = searchInput.value.trim();
    if (query.length < 2) {
      searchResults.innerHTML = "";
      return;
    }

    var directId = extractTournamentId(query);
    if (directId) {
      var href = "/referee/" + encodeURIComponent(directId) + "/tables?lang=" + searchLang;
      searchResults.innerHTML = '<a class="search-result-item" href="' + href + '">'
        + '<div class="search-result-name">ID: ' + escapeHtml(directId) + '</div>'
        + '<div class="search-result-meta">↗</div>'
        + '</a>';
      return;
    }

    debounceTimer = setTimeout(function() {
      fetch("/api/search?q=" + encodeURIComponent(query) + "&limit=10")
        .then(function(res) { return res.json(); })
        .then(function(items) {
          if (items.length === 0) {
            searchResults.innerHTML = '<div class="search-no-results">' + noResultsMsg + '</div>';
            return;
          }
          searchResults.innerHTML = items.map(function(item) {
            var href = "/referee/" + encodeURIComponent(item.id) + "/tables?lang=" + searchLang;
            var meta = [item.date, item.location].filter(Boolean).join(" • ");
            return '<a class="search-result-item" href="' + href + '">'
              + '<div class="search-result-name">' + escapeHtml(item.name) + '</div>'
              + (meta ? '<div class="search-result-meta">' + escapeHtml(meta) + '</div>' : '')
              + '</a>';
          }).join("");
        });
    }, 300);
  });

  function escapeHtml(str) {
    var div = document.createElement("div");
    div.textContent = str;
    return div.innerHTML;
  }
})();
</script>
