---
import MobileLayout from "../layouts/ResponsiveLayout.astro";
import EmptyState from "../components/app/EmptyState.astro";
import PlayerIdentityActions from "../components/player/PlayerIdentityActions.astro";
import PlayerRoundRow from "../components/player/PlayerRoundRow.astro";
import TieBreaks from "../components/standings/TieBreaks.astro";
import { scrapePairings, scrapeStandings } from "../lib/scraper";
import { reverseName } from "../lib/utils";
import { useTranslations } from "../i18n/ui";
import { DEFAULT_TOURNAMENT } from "../lib/constants";
import { resolvePageLang } from "../lib/page-lang";
import type { Pairing } from "../lib/types";

const tid = Astro.url.searchParams.get("tid") || DEFAULT_TOURNAMENT;
const playerParam = Astro.url.searchParams.get("name") || "";
const lang = resolvePageLang(Astro.url, Astro.cookies);

const t = useTranslations(lang);

let error: string | null = null;
let playerName = "";
let playerRating = "";
let playerFed = "";
let playerClub = "";
let playerRank = 0;
let playerPoints = "";
let tieBreak1 = "";
let tieBreak2 = "";
let tieBreak3 = "";
let tieBreak4 = "";
let tieBreak5 = "";
let tieBreak6 = "";
let totalRounds = 0;

interface RoundResult {
  round: number;
  opponent: string;
  result: string;
  table: number;
  color: "white" | "black";
  isBye: boolean;
}

const rounds: RoundResult[] = [];
let canonicalPlayerName = playerParam;

const normalizeName = (n: string) =>
  n.replace(/,\s*/g, " ").replace(/\s+/g, " ").trim().toLowerCase();

if (!playerParam) {
  error = t("player.empty");
} else {
  try {
    // Get standings for player metadata
    const standingsData = await scrapeStandings(tid);
    totalRounds = standingsData.info.totalRounds;

    // Standings (crosstable) may omit the comma in "Last, First" names,
    // so compare with a normalised form that strips commas.
    const normalizedParam = normalizeName(playerParam);

    const standing = standingsData.standings.find(
      (s) => s.name === playerParam || normalizeName(s.name) === normalizedParam
    );
    if (standing) {
      canonicalPlayerName = standing.name;
      playerName = reverseName(standing.name);
      playerRating = standing.rating;
      playerFed = standing.fed;
      playerClub = standing.club;
      playerRank = standing.rank;
      playerPoints = standing.points;
      tieBreak1 = standing.tieBreak1;
      tieBreak2 = standing.tieBreak2;
      tieBreak3 = standing.tieBreak3;
      tieBreak4 = standing.tieBreak4;
      tieBreak5 = standing.tieBreak5;
      tieBreak6 = standing.tieBreak6;
    }

    // Fallback: use the param name if standings didn't match
    if (!playerName) {
      playerName = reverseName(playerParam);
    }

    // If standings didn't provide totalRounds, discover it from pairings round 1
    if (!totalRounds) {
      try {
        const r1 = await scrapePairings(tid, 1);
        totalRounds = r1.info.totalRounds;
      } catch (_) { /* best-effort */ }
    }

    // Fetch all rounds and find this player's games
    const roundPromises = Array.from({ length: totalRounds }, (_, i) =>
      scrapePairings(tid, i + 1).catch(() => null)
    );
    const allRounds = await Promise.all(roundPromises);

    for (let i = 0; i < allRounds.length; i++) {
      const roundData = allRounds[i];
      if (!roundData) {
        rounds.push({
          round: i + 1,
          opponent: "",
          result: "",
          table: 0,
          color: "white",
          isBye: false,
        });
        continue;
      }

      const pairing = roundData.pairings.find(
        (p: Pairing) =>
          normalizeName(p.white?.name || "") === normalizedParam ||
          normalizeName(p.black?.name || "") === normalizedParam
      );

      if (!pairing) {
        rounds.push({
          round: i + 1,
          opponent: "",
          result: "",
          table: 0,
          color: "white",
          isBye: false,
        });
        continue;
      }

      const isWhite = normalizeName(pairing.white?.name || "") === normalizedParam;
      const opponent = isWhite ? pairing.black : pairing.white;
      const isBye = !opponent || (!pairing.black && /bye|spielfrei/i.test(pairing.unpairedLabel || ""));

      const selfName = isWhite ? pairing.white?.name : pairing.black?.name;
      if (selfName) canonicalPlayerName = selfName;

      rounds.push({
        round: i + 1,
        opponent: opponent?.name || "",
        result: pairing.result,
        table: pairing.table,
        color: isWhite ? "white" : "black",
        isBye,
      });

      // If we didn't get the player name from standings, grab it from pairings
      if (!playerName) {
        const self = isWhite ? pairing.white : pairing.black;
        if (self) playerName = reverseName(self.name);
      }
    }
  } catch (e) {
    error = e instanceof Error ? e.message : t("error.load");
  }
}

const pageTitle = playerName || t("player.progress");
const profileHref = `/player-profile?name=${encodeURIComponent(canonicalPlayerName)}${playerFed ? `&fed=${encodeURIComponent(playerFed)}` : ""}&lang=${lang}`;
---

<MobileLayout title={pageTitle} lang={lang}>
  {error && (
    <div class="error-msg">
      <p>{error}</p>
    </div>
  )}

  {playerName && (
    <section class="hero-section">
      <div class="hero-image-container">
        <img class="hero-image" alt="Player Identity Avatar" src="/images/avatar-placeholder.png" />
        <div class="hero-image-gradient">
          <span class="hero-tag">{playerClub || playerFed || "Player Profile"}</span>
        </div>
      </div>
      <div class="hero-content">
        <h2 class="hero-name">{playerName}</h2>
        <div class="hero-actions">
          <a class="profile-link-modern" href={profileHref}>{t("player.profile.openProfile")}</a>
          <PlayerIdentityActions playerName={canonicalPlayerName} federation={playerFed} lang={lang} />
        </div>
        
        {/* Performance Bento Grid */}
        <div class="bento-grid">
          <div class="bento-card">
            <span class="bento-label">{t("standings.pts") || "Pts"} / {t("standings.rank") || "Rank"}</span>
            <span class="bento-val">{playerPoints || "0"}<span class="bento-val-sub">#{playerRank || "-"}</span></span>
          </div>
          <div class="bento-card">
            <span class="bento-label">Current ELO</span>
            <span class="bento-val">{playerRating && playerRating !== "0" ? playerRating : "N/A"}</span>
          </div>
        </div>

        {/* Tie-Breaks below Bento Grid */}
        {(tieBreak1 || tieBreak2 || tieBreak3 || tieBreak4 || tieBreak5 || tieBreak6) && (
          <div class="hero-tb">
            <TieBreaks values={[tieBreak1, tieBreak2, tieBreak3, tieBreak4, tieBreak5, tieBreak6]} />
          </div>
        )}
      </div>
    </section>
  )}

  {!error && (
    <section class="rounds-section-modern">
      <div class="rounds-header">
        <h3 class="rounds-title-modern">{t("player.progress")}</h3>
        <div class="rounds-dots">
          <span class="dot dot-primary"></span>
          <span class="dot dot-highest"></span>
          <span class="dot dot-highest"></span>
        </div>
      </div>

      <div class="rounds-list">
        {rounds.length > 0 ? (
          rounds.map((r, i) => (
            <PlayerRoundRow
              round={r.round}
              opponent={r.opponent}
              result={r.result}
              table={r.table}
              color={r.color}
              isBye={r.isBye}
              index={i}
              lang={lang}
            />
          ))
        ) : (
          <EmptyState message={t("player.empty")} variant="surface" compact />
        )}
      </div>
    </section>
  )}
</MobileLayout>

<style is:global>
  /* Base Hero Layout */
  .hero-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 768px) {
    .hero-section {
      grid-template-columns: repeat(12, minmax(0, 1fr));
    }
  }

  /* Image Container */
  .hero-image-container {
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--surface-container-high);
    position: relative;
  }

  @media (min-width: 768px) {
    .hero-image-container {
      grid-column: span 4 / span 4;
    }
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-image-gradient {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-4);
    background: linear-gradient(to top, var(--bg) 0%, transparent 100%);
  }

  .hero-tag {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    background: var(--primary-container);
    color: var(--on-primary-fixed);
    font-size: 10px;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    margin-bottom: var(--space-1);
  }

  /* Content Container */
  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  @media (min-width: 768px) {
    .hero-content {
      grid-column: span 8 / span 8;
    }
  }

  .hero-name {
    font-family: var(--font-display);
    font-weight: var(--weight-extrabold);
    font-size: var(--text-4xl);
    color: var(--text);
    margin-bottom: var(--space-4);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-none);
  }

  @media (min-width: 768px) {
    .hero-name {
      font-size: var(--text-6xl);
    }
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .profile-link-modern {
    display: inline-flex;
    text-decoration: none;
    color: var(--accent-text);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
  }

  /* Bento Grid */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .bento-card {
    background: var(--surface-container-low);
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-left: 4px solid var(--primary-container);
  }

  .bento-label {
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
  }

  .bento-val {
    font-family: var(--font-display);
    font-weight: var(--weight-extrabold);
    font-size: var(--text-5xl);
    color: var(--text);
    margin-top: var(--space-2);
  }

  .bento-val-sub {
    font-size: var(--text-lg);
    opacity: 0.5;
    margin-left: var(--space-2);
  }

  .hero-tb {
    margin-top: var(--space-4);
    padding: var(--space-4);
    background: var(--surface-container-low);
    border-radius: var(--radius-xl);
    display: inline-flex;
  }

  /* Rounds Section */
  .rounds-section-modern {
    box-sizing: border-box;
  }

  .rounds-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-8);
  }

  .rounds-title-modern {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--text-2xl);
    color: var(--text);
    margin: 0;
  }

  .rounds-dots {
    display: flex;
    gap: var(--space-2);
  }

  .dot {
    height: 8px;
    width: 8px;
    border-radius: var(--radius-full);
  }

  .dot-primary {
    background: var(--primary-container);
  }

  .dot-highest {
    background: var(--surface-container-highest);
  }

  .rounds-list {
    display: flex;
    flex-direction: column;
  }
</style>
