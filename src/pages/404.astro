---
import ThemeToggle from "../components/app/ThemeToggle.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#fcd34d" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <title>404 — Page Not Found</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script>
      (function() {
        const stored = (() => { try { return localStorage.getItem('theme'); } catch { return null; } })();
        if (stored === 'light' || stored === 'dark') {
          document.documentElement.setAttribute('data-theme', stored);
        }
      })();
    </script>
    <script src="../scripts/theme.ts"></script>
  </head>
  <body>
    <div class="error-shell">
      <div class="ambient ambient-a"></div>
      <div class="ambient ambient-b"></div>

      <header class="error-topbar">
        <ThemeToggle />
      </header>

      <main class="error-main">
        <div class="error-content animate-enter">
          <div class="error-icon">
            <svg viewBox="0 0 200 200" width="200" height="200" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- 4x4 chessboard corner (bottom-right of a board) -->
              <!-- Row 1 (rank 8): squares e8 f8 g8 h8 -->
              <rect x="10" y="10" width="45" height="45" fill="var(--board-light)" />
              <rect x="55" y="10" width="45" height="45" fill="var(--board-dark)" />
              <rect x="100" y="10" width="45" height="45" fill="var(--board-light)" />
              <rect x="145" y="10" width="45" height="45" fill="var(--board-dark)" />
              <!-- Row 2 (rank 7) -->
              <rect x="10" y="55" width="45" height="45" fill="var(--board-dark)" />
              <rect x="55" y="55" width="45" height="45" fill="var(--board-light)" />
              <rect x="100" y="55" width="45" height="45" fill="var(--board-dark)" />
              <rect x="145" y="55" width="45" height="45" fill="var(--board-light)" />
              <!-- Row 3 (rank 6) -->
              <rect x="10" y="100" width="45" height="45" fill="var(--board-light)" />
              <rect x="55" y="100" width="45" height="45" fill="var(--board-dark)" />
              <rect x="100" y="100" width="45" height="45" fill="var(--board-light)" />
              <rect x="145" y="100" width="45" height="45" fill="var(--board-dark)" />
              <!-- Row 4 (rank 5) -->
              <rect x="10" y="145" width="45" height="45" fill="var(--board-dark)" />
              <rect x="55" y="145" width="45" height="45" fill="var(--board-light)" />
              <rect x="100" y="145" width="45" height="45" fill="var(--board-dark)" />
              <rect x="145" y="145" width="45" height="45" fill="var(--board-light)" />

              <!-- Board border -->
              <rect x="10" y="10" width="180" height="180" rx="4" stroke="var(--border)" stroke-width="2" fill="none" />

              <!-- Checkmate position: Rook + King vs King back-rank mate -->

              <!-- Black King on h8 (col 4, row 1) — trapped -->
              <text x="167" y="46" font-size="36" text-anchor="middle" fill="var(--text)">♚</text>

              <!-- Black Pawns blocking escape on g7 and h7 -->
              <text x="122" y="91" font-size="30" text-anchor="middle" fill="var(--text)">♟</text>
              <text x="167" y="91" font-size="30" text-anchor="middle" fill="var(--text)">♟</text>

              <!-- White Rook delivering checkmate on e8 -->
              <text x="32" y="47" font-size="36" text-anchor="middle" fill="var(--accent)">♜</text>

              <!-- White King safe on f5 -->
              <text x="77" y="181" font-size="36" text-anchor="middle" fill="var(--accent)">♔</text>

              <!-- Check indicator — red glow behind black king -->
              <circle cx="167" cy="34" r="20" fill="var(--check-glow)" />
              <text x="167" y="46" font-size="36" text-anchor="middle" fill="var(--text)">♚</text>
            </svg>
          </div>
          <h1 class="error-code">404</h1>
          <p class="error-message">Checkmate!</p>
          <p class="error-hint">This page has been captured and removed from the board.</p>
          <a href="/" class="btn--primary">Back to search</a>
        </div>
      </main>
    </div>
  </body>
</html>

<style>
  .error-shell {
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .error-topbar {
    display: flex;
    justify-content: flex-end;
    padding: var(--space-4);
  }

  .error-main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-6);
  }

  .error-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .error-icon {
    margin-bottom: var(--space-2);
    --board-light: rgba(255, 255, 255, 0.12);
    --board-dark: rgba(255, 255, 255, 0.04);
    --check-glow: rgba(239, 68, 68, 0.35);
  }

  :global([data-theme="light"]) .error-icon {
    --board-light: rgba(180, 140, 100, 0.3);
    --board-dark: rgba(120, 80, 50, 0.25);
    --check-glow: rgba(220, 38, 38, 0.25);
  }

  .error-code {
    font-size: var(--text-4xl);
    font-weight: var(--weight-extrabold);
    color: var(--accent);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-none);
  }

  .error-message {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    color: var(--text);
  }

  .error-hint {
    font-size: var(--text-sm);
    color: var(--text-dim);
    max-width: 28rem;
  }

  .btn--primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
    padding: var(--space-3) var(--space-6);
    background: var(--accent);
    color: var(--on-accent);
    font-weight: var(--weight-semibold);
    font-size: var(--text-sm);
    font-family: var(--font-sans);
    border: none;
    border-radius: var(--radius-lg);
    text-decoration: none;
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease-in-out),
                box-shadow var(--duration-fast) var(--ease-in-out);
  }

  .btn--primary:hover {
    background: var(--accent-hover);
    box-shadow: 0 0 20px var(--accent-glow);
  }
</style>
