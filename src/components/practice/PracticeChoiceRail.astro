---
interface Props {
  id: string;
  title: string;
  helper?: string;
  class?: string;
}

const {
  id,
  title,
  helper,
  class: className = "",
} = Astro.props;

const titleId = `${id}-title`;
const helperId = `${id}-helper`;
const hasMeta = Astro.slots.has('meta');
---

<section class:list={["practice-rail", className]} aria-labelledby={titleId}>
  <div class="practice-rail__header">
    <div class="practice-rail__heading-row">
      <h2 id={titleId} class="practice-rail__title">{title}</h2>
      {hasMeta && (
        <div class="practice-rail__meta">
          <slot name="meta" />
        </div>
      )}
    </div>
    {helper && <p id={helperId} class="practice-rail__helper">{helper}</p>}
  </div>
  <div class="practice-rail__body">
    <slot />
  </div>
</section>

<style>
  .practice-rail {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-width: 0;
  }

  .practice-rail__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .practice-rail__heading-row {
    display: flex;
    gap: var(--space-2);
    align-items: center;
    justify-content: space-between;
  }

  .practice-rail__title {
    margin: 0;
    color: var(--text-dim);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    line-height: var(--leading-tight);
    text-transform: uppercase;
  }

  .practice-rail__meta {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: var(--space-1);
    min-width: 0;
  }

  .practice-rail__helper {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-xs);
    line-height: var(--leading-normal);
  }

  .practice-rail__body {
    min-width: 0;
  }

  @media (forced-colors: active) {
    .practice-rail__title,
    .practice-rail__helper {
      color: CanvasText;
    }

    .practice-rail__meta {
      color: CanvasText;
    }
  }
</style>