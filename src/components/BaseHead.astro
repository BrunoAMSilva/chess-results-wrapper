---
interface Props {
  title: string;
  manifest?: string;
}

const { title, manifest = "/manifest.json" } = Astro.props;
---

<meta charset="UTF-8" />
<meta
  name="viewport"
  content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"
/>
<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content="Chess Results" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="manifest" href={manifest} />
<meta name="theme-color" content="#fcd34d" />
<title>{title}</title>
<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap"
  rel="stylesheet"
/>
<script>
  // Inline theme script to prevent FOUC
  (function() {
    const stored = (() => { try { return localStorage.getItem('theme'); } catch { return null; } })();
    if (stored === 'light' || stored === 'dark') {
      document.documentElement.setAttribute('data-theme', stored);
    }
  })();
</script>

<script src="../scripts/theme.ts"></script>
<script>
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js');
  }
</script>
