---
import QueenPieceIcon from "../app/QueenPieceIcon.astro";
import ChessResultScore from "../app/ChessResultScore.astro";
import type { Pairing } from "../../lib/types";
import { useTranslations } from "../../i18n/ui";
import PlayerName from "../player/PlayerName.astro";

interface Props {
  pairing: Pairing;
  index: number;
  lang: number;
  variant?: "list" | "card";
  titleMap?: Record<string, string>;
}

const { pairing, index, lang, variant = "card", titleMap = {} } = Astro.props;
const t = useTranslations(lang);

const normalized = pairing.result.replace(/\s+/g, "").toLowerCase();
const whiteWins = normalized.includes("1-0") || normalized.includes("1:0");
const blackWins = normalized.includes("0-1") || normalized.includes("0:1");
const draw =
  normalized.includes("½") ||
  normalized.includes("1/2") ||
  normalized.includes("0.5");
const isBye = !pairing.black;
const delayStep = Math.max(0, Math.min(10, index));
const delayClass = `delay-${delayStep}`;
---

<article
  class:list={[
    "presenter-card",
    delayClass,
    variant,
    { bye: isBye, draw, "white-wins": whiteWins, "black-wins": blackWins },
  ]}
>
  <div class="color-strip white-strip">
    <QueenPieceIcon tone="white" size="lg" />
  </div>
  <div class="color-strip black-strip">
    <QueenPieceIcon tone="black" size="lg" />
  </div>
  <span class="board-label">{pairing.table.toString().padStart(2, "0")}</span>

  <div class:list={["player-row", "white", { winner: whiteWins }]}>
    <PlayerName
      name={pairing.white.name}
      title={titleMap[pairing.white.name]}
    />
  </div>
  <div class:list={["player-row", "black", { winner: blackWins }]}>
    {
      pairing.black ? (
        <PlayerName
          name={pairing.black.name}
          title={titleMap[pairing.black.name]}
        />
      ) : (
        <span class="player-name unpaired">
          {pairing.result === "1" ? t("match.bye") : t("match.notPaired")}
        </span>
      )
    }
  </div>

  <div class:list={["score-slot", { winner: whiteWins || blackWins, draw }]}>
    <ChessResultScore result={pairing.result} size="lg" />
  </div>
</article>

<style>
  .presenter-card {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    border-radius: var(--radius-lg);
    background: var(--surface);
    overflow: hidden;
    animation: fadeInUp var(--duration-slow) ease both;
  }

  /* Color strips — left column with piece color background + icon */
  .color-strip {
    grid-column: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-inline: var(--space-4);
  }

  .white-strip {
    grid-row: 1;
    background: #ffffff;
  }

  .black-strip {
    grid-row: 2;
    background: #1a1a1a;
  }

  .board-label {
    font-size: var(--text-3xl);
    font-weight: var(--weight-extrabold);
    grid-column: 1;
    grid-row: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: center;
    justify-self: center;
    align-self: center;
    z-index: 2;
    background-color: var(--accent);
    color: var(--on-accent);
    padding: var(--space-1) var(--space-3);
    border-radius: 999px;
    line-height: 1.2;
    font-family: var(--font-display);
    letter-spacing: var(--tracking-tight);
  }

  .player-row {
    grid-column: 2;
    display: flex;
    align-items: center;
    gap: var(--space-5);
    min-width: 0;
    padding-inline: var(--space-4);
    min-height: 4em;
    font-size: var(--text-2xl);
    font-weight: var(--weight-semiBold);
  }

  .player-row.white {
    grid-row: 1;
    justify-content: flex-start;
    text-align: left;
  }

  .player-row.black {
    grid-row: 2;
    justify-content: flex-start;
    text-align: left;
  }

  .player-name {
    color: var(--text);
    text-overflow: ellipsis;
    line-height: var(--leading-tight);
    text-wrap: balance;
    padding: var(--space-3) var(--space-6) var(--space-3) 0;
  }

  .player-row.winner {
    background: color-mix(in oklab, var(--accent-subtle) 70%, transparent);
  }

  .player-row.winner .player-name {
    color: var(--accent-text);
  }

  .presenter-card.draw .player-row {
    background: color-mix(in oklab, var(--accent-subtle) 45%, transparent);
  }

  .unpaired {
    font-size: var(--text-xl);
    color: var(--text-dim);
    font-style: italic;
  }

  .score-slot {
    grid-column: 2;
    grid-row: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: center;
    justify-self: end;
    align-self: center;
    z-index: 1;
    background-color: var(--bg-subtle);
    color: var(--accent-text);
    padding: var(--space-2) var(--space-6);
    margin-inline-end: var(--space-6);
    border-radius: 999px;
  }

  .delay-0 {
    animation-delay: 0ms;
  }
  .delay-1 {
    animation-delay: 40ms;
  }
  .delay-2 {
    animation-delay: 80ms;
  }
  .delay-3 {
    animation-delay: 120ms;
  }
  .delay-4 {
    animation-delay: 160ms;
  }
  .delay-5 {
    animation-delay: 200ms;
  }
  .delay-6 {
    animation-delay: 240ms;
  }
  .delay-7 {
    animation-delay: 280ms;
  }
  .delay-8 {
    animation-delay: 320ms;
  }
  .delay-9 {
    animation-delay: 360ms;
  }
  .delay-10 {
    animation-delay: 400ms;
  }
</style>
