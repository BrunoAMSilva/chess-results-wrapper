---
import ActionButton from "../controls/ActionButton.astro";
import SegmentedControl from "../controls/SegmentedControl.astro";

interface Segment {
  value: string;
  label: string;
  href?: string;
}

interface HiddenField {
  name: string;
  value: string;
}

interface Props {
  idPrefix: string;
  title: string;
  action: string;
  submitLabel: string;
  segments?: Segment[];
  activeSegment?: string;
  hiddenFields?: HiddenField[];
}

const {
  idPrefix,
  title,
  action,
  submitLabel,
  segments = [],
  activeSegment,
  hiddenFields = [],
} = Astro.props;

const panelId = `${idPrefix}-panel`;
const toggleId = `${idPrefix}-toggle`;
const bodyId = `${idPrefix}-body`;
---

<div class="config-panel" id={panelId} data-presenter-config-panel>
  <button
    class="config-toggle"
    id={toggleId}
    type="button"
    aria-label={title}
    aria-controls={bodyId}
    aria-expanded="false"
    data-config-toggle
  >
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="3"/>
      <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
    </svg>
  </button>

  <form class="config-body" id={bodyId} action={action} method="GET" data-config-body>
    {segments.length > 0 && (
      <div class="view-switch-panel">
        <SegmentedControl name={`${idPrefix}-view-switch`} segments={segments} active={activeSegment} />
      </div>
    )}
    {hiddenFields.map((field) => <input type="hidden" name={field.name} value={field.value} />)}
    <slot />
    <ActionButton class="config-btn" size="compact" type="submit">{submitLabel}</ActionButton>
  </form>
</div>

<style>
  .config-panel {
    position: fixed;
    inset-inline-end: var(--space-6);
    inset-block-end: var(--space-6);
    z-index: 100;
  }

  .config-toggle {
    inline-size: var(--space-10);
    block-size: var(--space-10);
    border: none;
    border-radius: var(--radius-full);
    background: var(--surface-container-high);
    color: var(--text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      background-color var(--duration-fast) var(--ease-in-out),
      transform var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-in-out);
    box-shadow: var(--shadow-ambient);
  }

  .config-toggle:hover {
    background: var(--surface-container-highest);
    transform: rotate(90deg);
  }

  .config-toggle:focus-visible {
    outline: 2px solid transparent;
    outline-offset: 2px;
    box-shadow: 0 0 0 3px var(--input-focus-ring);
  }

  .config-body {
    position: absolute;
    inset-inline-end: 0;
    inset-block-end: calc(100% + var(--space-2));
    width: min(18rem, calc(100vw - var(--space-12)));
    border: none;
    border-radius: var(--radius-lg);
    background: var(--surface-container-high);
    padding: var(--space-4);
    display: none;
    flex-direction: column;
    gap: var(--space-3);
    box-shadow: var(--shadow-elevated);
    backdrop-filter: blur(24px);
    animation: fadeInUp var(--duration-normal) var(--ease-out) both;
  }

  .config-body.open {
    display: flex;
  }

  .view-switch-panel {
    display: flex;
    background: var(--bg);
    border-radius: var(--radius-sm);
    padding: var(--space-1);
    gap: var(--space-1);
    margin-block-end: var(--space-2);
  }

  @media (max-width: 720px) {
    .config-panel {
      inset-inline-end: var(--space-4);
      inset-block-end: calc(var(--space-12) + var(--space-6));
    }

    .config-body {
      width: min(18rem, calc(100vw - var(--space-8)));
    }
  }

  @media (forced-colors: active) {
    .config-toggle,
    .config-body {
      border: 1px solid ButtonBorder;
      background: Canvas;
      color: CanvasText;
      box-shadow: none;
      backdrop-filter: none;
    }

    .config-toggle:focus-visible {
      outline: 2px solid Highlight;
      box-shadow: none;
    }
  }
</style>

<script>
  function initPresenterConfigPanels() {
    document.querySelectorAll<HTMLElement>("[data-presenter-config-panel]").forEach((panel) => {
      if (panel.dataset.ready === "true") return;
      panel.dataset.ready = "true";

      const toggle = panel.querySelector<HTMLButtonElement>("[data-config-toggle]");
      const body = panel.querySelector<HTMLElement>("[data-config-body]");
      if (!toggle || !body) return;

      const close = () => {
        body.classList.remove("open");
        toggle.setAttribute("aria-expanded", "false");
      };

      const open = () => {
        body.classList.add("open");
        toggle.setAttribute("aria-expanded", "true");
        const firstFocusable = body.querySelector<HTMLElement>(
          'input:not([type="hidden"]), select, textarea, button, a[href]'
        );
        firstFocusable?.focus();
      };

      toggle.addEventListener("click", (event) => {
        event.stopPropagation();
        if (body.classList.contains("open")) close();
        else open();
      });

      document.addEventListener("click", (event) => {
        if (!panel.contains(event.target as Node)) close();
      });

      panel.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          close();
          toggle.focus();
        }
      });
    });
  }

  initPresenterConfigPanels();
  document.addEventListener("astro:after-swap", initPresenterConfigPanels);
</script>