---
import type { Standing } from "../../lib/types";
import WinnerPlayerCard from "./WinnerPlayerCard.astro";
import { useTranslations } from "../../i18n/ui";

interface Props {
  standings: Standing[];
  tournamentId: string;
  lang: number;
}

const { standings, tournamentId, lang } = Astro.props;
const t = useTranslations(lang);

// Encode standings as JSON for client script
const standingsJson = JSON.stringify(standings);
---

<div class="winners-carousel" data-tournament-id={tournamentId} data-standings={standingsJson}>
  <!-- Current player display -->
  <div class="player-display" id="playerDisplay">
    {standings[0] && (
      <WinnerPlayerCard
        standing={standings[0]}
        rank={standings[0].rank}
        lang={lang}
        isEntering={true}
      />
    )}
  </div>

  <!-- Navigation hint (visible first 3 seconds) -->
  <div class="nav-hint">
    <p class="hint-text">Press <kbd>SPACE</kbd> or click to continue</p>
  </div>

  <!-- Hidden data attributes for client script -->
  <script type="application/json" id="standings-data">
    {standingsJson}
  </script>
</div>

<script>
  import "../../scripts/winners-presentation";
</script>

<style>
  .winners-carousel {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .player-display {
    width: 100%;
    height: 100%;
  }

  .nav-hint {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    padding: var(--space-4) var(--space-6);
    border-radius: var(--radius-md);
    animation: fadeInUp 600ms var(--ease-out), fadeOutDown 600ms var(--ease-out) 2400ms forwards;
  }

  .hint-text {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text);
    text-align: center;
    font-weight: var(--weight-medium);
  }

  kbd {
    display: inline-block;
    background: var(--accent);
    color: var(--on-accent);
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    margin: 0 0.25rem;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  }

  @keyframes fadeOutDown {
    from {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
    to {
      opacity: 0;
      transform: translateX(-50%) translateY(20px);
    }
  }
</style>
