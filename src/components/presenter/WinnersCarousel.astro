---
import type { Standing } from "../../lib/types";

interface Props {
  standings: Standing[];
  tournamentId: string;
  lang: number;
  tournamentName: string;
  sponsorImage?: string;
  sponsorAlt?: string;
}

const { standings, tournamentId, lang, tournamentName, sponsorImage = "", sponsorAlt = "Sponsor" } = Astro.props;
---

<div
  class="winners-stage"
  id="winnersStage"
  data-tournament-id={tournamentId}
  data-lang={String(lang)}
  data-tournament-name={tournamentName}
  data-sponsor-image={sponsorImage}
  data-sponsor-alt={sponsorAlt}
>
  <script type="application/json" id="standings-data" set:html={JSON.stringify(standings)} />

  <!-- Intro + Player cards get rendered here by JS -->
  <div class="player-slot" id="playerSlot"></div>

  <!-- Navigation hint (hidden during intro, shown after first player) -->
  <div class="nav-hint hidden" id="navHint">
    <p>Press <kbd>Space</kbd>, <kbd>Enter</kbd> or <strong>click</strong> to reveal next</p>
  </div>
</div>

<script>
  import "../../scripts/winners-presentation";
</script>

<!--
  Styles are :global because the .wc-* DOM is built by JS at runtime.
  Astro scoped styles would not apply to dynamically injected elements.
-->
<style is:global>
  /* ── Stage ── */
  .winners-stage {
    position: fixed;
    inset: 0;
    background: var(--bg);
    overflow: hidden;
  }

  .player-slot {
    position: absolute;
    inset: 0;
  }

  /* ── Hint ── */
  .nav-hint {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    opacity: 1;
    transition: opacity 0.6s ease;
    pointer-events: none;
  }

  .nav-hint.hidden { opacity: 0; }

  .nav-hint p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .nav-hint kbd {
    display: inline-block;
    background: var(--accent);
    color: var(--on-accent);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
  }

  /* ============================================================
     Intro Title Card (.wc-intro)
     Full-viewport cinematic intro with sponsor billboard + title.

     Layout (top to bottom):
       — dark background with glow + particles
       — large white sponsor banner (dominates viewport)
       — gold divider
       — tournament name + subtitle
     ============================================================ */

  .wc-intro {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    z-index: 10;
  }

  /* Animated radial glow behind content */
  .wc-intro-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 40%, rgba(252, 211, 77, 0.10) 0%, transparent 70%),
      radial-gradient(ellipse 50% 40% at 50% 45%, rgba(245, 158, 11, 0.07) 0%, transparent 60%);
    animation: intro-glow-pulse 4s ease-in-out infinite;
  }

  @keyframes intro-glow-pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50%      { opacity: 1;   transform: scale(1.06); }
  }

  /* Floating particles */
  .wc-intro-particles {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .wc-intro-particle {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0;
    animation: intro-particle-float 6s ease-in-out infinite;
  }

  .wc-intro-particle:nth-child(1)  { left: 15%; top: 20%; animation-delay: 0s; }
  .wc-intro-particle:nth-child(2)  { left: 75%; top: 30%; animation-delay: 1.2s; width: 3px; height: 3px; }
  .wc-intro-particle:nth-child(3)  { left: 25%; top: 70%; animation-delay: 2.5s; }
  .wc-intro-particle:nth-child(4)  { left: 85%; top: 65%; animation-delay: 0.8s; width: 5px; height: 5px; }
  .wc-intro-particle:nth-child(5)  { left: 50%; top: 15%; animation-delay: 3.2s; width: 3px; height: 3px; }
  .wc-intro-particle:nth-child(6)  { left: 10%; top: 50%; animation-delay: 1.8s; }
  .wc-intro-particle:nth-child(7)  { left: 65%; top: 80%; animation-delay: 4s; width: 3px; height: 3px; }
  .wc-intro-particle:nth-child(8)  { left: 40%; top: 85%; animation-delay: 2s; }

  @keyframes intro-particle-float {
    0%   { opacity: 0; transform: translateY(0) scale(0); }
    15%  { opacity: 0.6; transform: translateY(-10px) scale(1); }
    85%  { opacity: 0.3; transform: translateY(-40px) scale(0.8); }
    100% { opacity: 0; transform: translateY(-60px) scale(0); }
  }

  /* Content — stacked: sponsor billboard → divider → title → subtitle */
  .wc-intro-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
    width: 100%;
    padding: 2rem;
  }

  /* ── Sponsor billboard ──
     Wide white panel that dominates the viewport.
     Tall enough to give the logo breathing room. */
  .wc-intro-sponsor-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    width: min(85vw, 900px);
    min-height: clamp(200px, 35vh, 360px);
    border-radius: var(--radius-xl);
    background: #ffffff;
    padding: 3rem 4rem;
    box-shadow:
      0 0 80px rgba(252, 211, 77, 0.14),
      0 0 160px rgba(252, 211, 77, 0.07),
      0 12px 48px rgba(0, 0, 0, 0.35);
    opacity: 0;
    transform: scale(0.88) translateY(20px);
    transition:
      opacity 0.8s ease 0.2s,
      transform 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.2s;
  }

  .wc-intro.in .wc-intro-sponsor-wrap {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  /* Gold border accent on the billboard */
  .wc-intro-sponsor-wrap::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 2px solid rgba(252, 211, 77, 0.25);
    pointer-events: none;
  }

  /* Shimmer sweep across the billboard */
  .wc-intro-sponsor-wrap::after {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(252, 211, 77, 0.05) 40%,
      rgba(252, 211, 77, 0.10) 50%,
      rgba(252, 211, 77, 0.05) 60%,
      transparent 100%
    );
    animation: intro-shimmer 3.5s ease-in-out 1.5s infinite;
  }

  @keyframes intro-shimmer {
    0%   { left: -100%; }
    100% { left: 200%; }
  }

  /* Sponsor logo inside the billboard */
  .wc-intro-sponsor {
    max-width: 90%;
    max-height: 80%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  /* Gold accent divider */
  .wc-intro-divider {
    width: 100px;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    border-radius: 2px;
    opacity: 0;
    transform: scaleX(0);
    transition: opacity 0.5s ease 0.6s, transform 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.6s;
  }

  .wc-intro.in .wc-intro-divider {
    opacity: 1;
    transform: scaleX(1);
  }

  /* Tournament title */
  .wc-intro-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3.5vw, 3rem);
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--text);
    text-align: center;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease 0.75s, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.75s;
  }

  .wc-intro.in .wc-intro-title {
    opacity: 1;
    transform: translateY(0);
  }

  /* Subtitle */
  .wc-intro-subtitle {
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 1.8vw, 1.3rem);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--accent);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease 0.95s, transform 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.95s;
  }

  .wc-intro.in .wc-intro-subtitle {
    opacity: 1;
    transform: translateY(0);
  }

  /* Intro hint */
  .wc-intro-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: var(--text-sm);
    color: var(--text-muted);
    opacity: 0;
    transition: opacity 0.8s ease 2s;
    animation: intro-hint-pulse 2.5s ease-in-out 3s infinite;
  }

  .wc-intro.in .wc-intro-hint {
    opacity: 1;
  }

  .wc-intro-hint kbd {
    display: inline-block;
    background: var(--accent);
    color: var(--on-accent);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
  }

  @keyframes intro-hint-pulse {
    0%, 100% { opacity: 0.5; }
    50%      { opacity: 1; }
  }

  /* Intro exit */
  .wc-intro.out .wc-intro-sponsor-wrap,
  .wc-intro.out .wc-intro-divider,
  .wc-intro.out .wc-intro-title,
  .wc-intro.out .wc-intro-subtitle,
  .wc-intro.out .wc-intro-hint {
    opacity: 0;
    transform: scale(0.92);
    transition: opacity 0.35s ease, transform 0.4s ease;
  }

  .wc-intro.out .wc-intro-glow,
  .wc-intro.out .wc-intro-particles {
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  /* When no sponsor: make title bigger */
  .wc-intro--no-sponsor .wc-intro-title {
    font-size: clamp(2.2rem, 5vw, 4.5rem);
  }

  /* Corner accent lines */
  .wc-intro-corner {
    position: absolute;
    width: 80px;
    height: 80px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.8s ease 1.2s;
  }

  .wc-intro.in .wc-intro-corner { opacity: 0.3; }

  .wc-intro-corner--tl { top: 3rem; left: 3rem; border-top: 2px solid var(--accent); border-left: 2px solid var(--accent); }
  .wc-intro-corner--tr { top: 3rem; right: 3rem; border-top: 2px solid var(--accent); border-right: 2px solid var(--accent); }
  .wc-intro-corner--bl { bottom: 3rem; left: 3rem; border-bottom: 2px solid var(--accent); border-left: 2px solid var(--accent); }
  .wc-intro-corner--br { bottom: 3rem; right: 3rem; border-bottom: 2px solid var(--accent); border-right: 2px solid var(--accent); }


  /* ============================================================
     Winner Card (.wc)
     Full-viewport two-panel layout with diagonal blade dividers.
     ============================================================ */

  .wc {
    position: absolute;
    inset: 0;
    display: flex;
    overflow: hidden;
    background: var(--bg);
  }

  /* ── Photo panel ── */
  .wc-photo {
    position: absolute;
    top: 0;
    left: 0;
    width: 55%;
    height: 100%;
    overflow: hidden;
    transform: translateX(-100%);
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .wc.in .wc-photo {
    transform: translateX(0);
  }

  .wc.out .wc-photo {
    transform: translateX(-100%);
    transition: transform 0.45s cubic-bezier(0.55, 0, 1, 0.45);
  }

  .wc-photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .wc-photo-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(
      circle at 40% 40%,
      rgba(252, 211, 77, 0.12) 0%,
      var(--bg-subtle) 70%
    );
  }

  .wc-photo-fallback span {
    font-family: var(--font-display);
    font-size: clamp(6rem, 12vw, 14rem);
    font-weight: var(--weight-extrabold);
    color: var(--accent);
    opacity: 0.25;
    text-transform: uppercase;
    user-select: none;
  }

  /* ── Blade dividers ── */
  .wc-blade {
    position: absolute;
    top: -5%;
    right: 0;
    height: 110%;
    pointer-events: none;
  }

  .wc-blade-1 {
    width: 56%;
    background: var(--surface);
    transform: translateX(110%) skewX(-6deg);
    transition: transform 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.06s;
    z-index: 2;
  }

  .wc.in .wc-blade-1 { transform: translateX(0) skewX(-6deg); }
  .wc.out .wc-blade-1 { transform: translateX(110%) skewX(-6deg); transition: transform 0.4s cubic-bezier(0.55, 0, 1, 0.45) 0.06s; }

  .wc-blade-2 {
    width: 54%;
    background: var(--accent);
    transform: translateX(110%) skewX(-6deg);
    transition: transform 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.14s;
    z-index: 3;
  }

  .wc.in .wc-blade-2 { transform: translateX(0) skewX(-6deg); }
  .wc.out .wc-blade-2 { transform: translateX(110%) skewX(-6deg); transition: transform 0.4s cubic-bezier(0.55, 0, 1, 0.45) 0.03s; }

  /* ── Info panel ── */
  .wc-info {
    position: absolute;
    top: -5%;
    right: 0;
    width: 52%;
    height: 110%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 4rem 4rem 8rem;
    z-index: 4;
    background:
      radial-gradient(ellipse at 80% 30%, rgba(252, 211, 77, 0.10) 0%, transparent 60%),
      radial-gradient(ellipse at 20% 80%, rgba(245, 158, 11, 0.06) 0%, transparent 50%),
      linear-gradient(135deg, var(--surface-raised) 0%, var(--surface) 100%);
    transform: translateX(110%) skewX(-6deg);
    transition: transform 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.22s;
  }

  .wc.in .wc-info { transform: translateX(0) skewX(-6deg); }
  .wc.out .wc-info { transform: translateX(110%) skewX(-6deg); transition: transform 0.4s cubic-bezier(0.55, 0, 1, 0.45); }

  .wc-info-inner {
    transform: skewX(6deg);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 480px;
    width: 100%;
  }

  /* ── Medal display ── */
  .wc-medal {
    display: flex;
    align-items: center;
    gap: 1rem;
    opacity: 0;
    transform: translateY(16px) scale(0.8);
    transition: opacity 0.4s ease 0.5s, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.5s;
  }

  .wc.in .wc-medal {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .wc-medal-icon {
    font-size: clamp(3rem, 5vw, 4.5rem);
    line-height: 1;
    filter: drop-shadow(0 0 12px var(--medal-glow, rgba(252, 211, 77, 0.4)));
  }

  .wc-medal--gold .wc-medal-icon  { --medal-glow: rgba(255, 215, 0, 0.5); }
  .wc-medal--silver .wc-medal-icon { --medal-glow: rgba(192, 192, 192, 0.5); }
  .wc-medal--bronze .wc-medal-icon { --medal-glow: rgba(205, 127, 50, 0.5); }

  .wc-medal-label {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.2vw, 2rem);
    font-weight: var(--weight-extrabold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--accent);
  }

  .wc-medal--gold .wc-medal-label  { color: var(--medal-gold); }
  .wc-medal--silver .wc-medal-label { color: var(--medal-silver); }
  .wc-medal--bronze .wc-medal-label { color: var(--medal-bronze); }

  /* Rank 4+ badge */
  .wc-medal-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: clamp(3rem, 5vw, 4.5rem);
    height: clamp(3rem, 5vw, 4.5rem);
    border-radius: 50%;
    background: var(--surface-hover);
    border: 2px solid var(--accent);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2.2rem);
    font-weight: var(--weight-extrabold);
    color: var(--accent);
    filter: drop-shadow(0 0 10px rgba(252, 211, 77, 0.3));
  }

  /* ── Title badge (GM / IM / …) ── */
  .wc-title-badge {
    display: inline-block;
    width: fit-content;
    background: var(--accent);
    color: var(--on-accent);
    padding: 0.4rem 0.9rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.4s ease 0.58s, transform 0.4s cubic-bezier(0.22, 1, 0.36, 1) 0.58s;
  }

  .wc.in .wc-title-badge {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Name ── */
  .wc-name {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.75rem);
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--text);
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.4s ease 0.65s, transform 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.65s;
  }

  .wc.in .wc-name {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Metadata ── */
  .wc-meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s ease 0.8s, transform 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.8s;
  }

  .wc.in .wc-meta {
    opacity: 1;
    transform: translateY(0);
  }

  .wc-meta-row {
    display: flex;
    gap: 1rem;
    align-items: baseline;
  }

  .wc-meta-label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--text-muted);
    min-width: 120px;
  }

  .wc-meta-value {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--text-secondary);
  }

  /* Federation as subtle inline text (no label) */
  .wc-fed {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--text-dim);
    letter-spacing: var(--tracking-wide);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .wc-photo   { width: 50%; }
    .wc-info    { width: 58%; padding: 2.5rem 2.5rem 2.5rem 6rem; }
    .wc-blade-1 { width: 62%; }
    .wc-blade-2 { width: 60%; }
  }
</style>
