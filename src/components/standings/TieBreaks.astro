---
interface Props {
  values: (string | null | undefined)[];
}

const { values } = Astro.props;

const tieBreaks = values
  .map((val, i) => ({ label: `TB${i + 1}`, value: val?.trim() || "" }))
  .filter((tb) => tb.value !== "");
---

{
  tieBreaks.length > 0 && (
    <div class="tie-breaks">
      {tieBreaks.map((tb) => (
        <div class="tb-group">
          <span class="tb-val">{tb.value || "–"}</span>
          <span class="tb-lbl">{tb.label}</span>
        </div>
      ))}
    </div>
  )
}

<style>
  .tie-breaks {
    display: flex;
    gap: var(--space-3);
    align-self: center;
    justify-content: space-between;
    width: 100%;
  }

  .tb-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 4em;
    flex: 1;
  }

  .tb-val {
    font-size: 1.5em;
    font-weight: var(--weight-bold);
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }

  .tb-lbl {
    display: none;
    font-size: 0.6em;
    font-weight: var(--weight-semibold);
    color: var(--text-dim);
    margin-top: 0.1em;
  }

  @media (max-width: 480px) {
    .tie-breaks {
      display: none;
    }
  }

  @media (min-width: 1068px) {
    .tie-breaks {
      display: flex;
      gap: var(--space-3);
      align-items: center;
    }
    .tb-lbl {
      display: block;
    }
  }
</style>
