---
interface Props {
  recentLabel: string;
  linkBase?: string;
}

const { recentLabel, linkBase = "/pairings" } = Astro.props;
---

<section class="recent-section hidden" id="recentTournaments" aria-label={recentLabel} data-link-base={linkBase}>
  <h2 class="recent-heading">{recentLabel}</h2>
  <ul class="recent-list" id="recentList"></ul>
</section>

<style>
  .recent-section {
    width: 100%;
    margin-top: var(--space-6);
  }

  .recent-heading {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-3);
  }

  .recent-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .recent-list :global(.recent-item) {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--surface);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text);
    transition: background var(--duration-fast) var(--ease-in-out),
                border-color var(--duration-fast) var(--ease-in-out);
  }

  .recent-list :global(.recent-item:hover) {
    background: var(--surface-hover);
    border-color: var(--border);
  }

  .recent-list :global(.recent-item-icon) {
    flex-shrink: 0;
    color: var(--text-muted);
  }

  .recent-list :global(.recent-item-info) {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .recent-list :global(.recent-item-name) {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .recent-list :global(.recent-item-date) {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }
</style>

<script>
  function initRecentTournaments() {
    const section = document.getElementById('recentTournaments');
    const list = document.getElementById('recentList');
    if (!section || !list) return;

    try {
      const stored = localStorage.getItem('recentTournaments');
      if (!stored) return;
      const recent: { id: string; name: string; date: string }[] = JSON.parse(stored);
      if (!Array.isArray(recent) || recent.length === 0) return;

      const base = section.getAttribute('data-link-base') || '/pairings';

      list.innerHTML = '';
      for (const t of recent.slice(0, 5)) {
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.className = 'recent-item';
        a.href = base.includes('{id}')
          ? base.replace('{id}', encodeURIComponent(t.id))
          : `${base}?tid=${encodeURIComponent(t.id)}`;

        const nameText = escapeHtmlRecent(t.name || `Tournament ${t.id}`);
        const dateText = t.date ? escapeHtmlRecent(t.date) : '';

        a.innerHTML = `
          <svg class="recent-item-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 6v6l4 2"></path>
          </svg>
          <span class="recent-item-info">
            <span class="recent-item-name">${nameText}</span>
            ${dateText ? `<span class="recent-item-date">${dateText}</span>` : ''}
          </span>
        `;

        li.appendChild(a);
        list.appendChild(li);
      }

      section.classList.remove('hidden');
    } catch {
      // localStorage unavailable or corrupted data — just hide
    }
  }

  function escapeHtmlRecent(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  document.addEventListener('DOMContentLoaded', initRecentTournaments);
  document.addEventListener('astro:after-swap', initRecentTournaments);
</script>
