---
import type { Pairing } from "../../lib/scraper";
import { reverseName } from "../../lib/utils";
import { useTranslations } from "../../i18n/ui";

interface Props {
  pairing: Pairing;
  index: number;
  lang: number;
  variant?: "list" | "card";
}

const { pairing, index, lang, variant = "card" } = Astro.props;
const t = useTranslations(lang);

function resultClass(result: string): string {
  if (result.includes("1 - 0")) return "white-wins";
  if (result.includes("0 - 1")) return "black-wins";
  if (result.includes("½") || result.includes("0.5") || result.includes("draw"))
    return "draw";
  return "";
}

const rClass = resultClass(pairing.result);
const isBye = !pairing.black;
const delayStep = Math.max(0, Math.min(10, index));
const delayClass = `delay-${delayStep}`;
---

<div
  class:list={[
    "match-row",
    variant === "list" ? "list-variant" : "card-variant",
    delayClass,
    {
      bye: isBye,
      "white-wins": rClass === "white-wins",
      "black-wins": rClass === "black-wins",
      draw: rClass === "draw",
    },
  ]}
>
  <div class="player white-side">
    <span class="player-name">{reverseName(pairing.white.name)}</span>
  </div>

  <span class="table-num">{pairing.table}</span>

  <div class="player black-side">
    {
      pairing.black ? (
        <span class="player-name">{reverseName(pairing.black.name)}</span>
      ) : (
        <span class="bye-label">
          {pairing.result === "1" ? t("match.bye") : t("match.notPaired")}
        </span>
      )
    }
  </div>
</div>

<style>
  .match-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: stretch;
    background: var(--surface);
    flex: 1;
    min-height: 0;
    animation: fadeInUp var(--duration-slow) ease both;
    color: var(--text);
  }

  .match-row.card-variant {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-elevation-3);
    overflow: clip;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    background-color: rebeccapurple !important;
  }

  .match-row.card-variant .table-num {
    font-size: var(--text-5xl);
  }

  .match-row:last-child {
  }

  .match-row.bye {
  }

  .match-row.bye .white-side {
    background: var(--surface-raised);
  }

  .match-row.white-wins .white-side {
    background: var(--accent);
  }

  .match-row.white-wins .white-side .player-name {
    color: var(--on-accent);
    text-shadow: none;
    font-weight: 800;
  }

  .match-row.black-wins .black-side {
    background: var(--accent);
  }

  .match-row.black-wins .black-side .player-name {
    color: var(--on-accent);
    text-shadow: none;
    font-weight: 800;
  }

  .match-row.draw .white-side {
    background: var(--accent-subtle);
  }

  .match-row.draw .white-side .player-name {
    color: var(--text);
    text-shadow: none;
  }

  .match-row.draw .black-side {
    background: var(--accent-subtle);
  }

  .player {
    display: flex;
    align-items: center;
    min-width: 0;
    overflow: hidden;
    padding: 0 var(--space-8);
  }

  .white-side {
    justify-content: flex-end;
    text-align: right;
    background: var(--surface-raised);
  }

  .white-side .player-name {
    color: var(--on-accent);
    text-shadow: none;
  }

  .black-side {
    justify-content: flex-start;
    text-align: left;
  }

  .player-name {
    font-size: var(--text-display-md);
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .list-variant .table-num {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: 900;
    color: var(--text);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .bye-label {
    font-size: var(--text-display-sm);
    color: var(--text-dim);
    font-style: italic;
  }

  .delay-0 {
    animation-delay: 0ms;
  }
  .delay-1 {
    animation-delay: 40ms;
  }
  .delay-2 {
    animation-delay: 80ms;
  }
  .delay-3 {
    animation-delay: 120ms;
  }
  .delay-4 {
    animation-delay: 160ms;
  }
  .delay-5 {
    animation-delay: 200ms;
  }
  .delay-6 {
    animation-delay: 240ms;
  }
  .delay-7 {
    animation-delay: 280ms;
  }
  .delay-8 {
    animation-delay: 320ms;
  }
  .delay-9 {
    animation-delay: 360ms;
  }
  .delay-10 {
    animation-delay: 400ms;
  }
</style>
