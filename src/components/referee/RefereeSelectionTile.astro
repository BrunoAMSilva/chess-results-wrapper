---
interface Props {
  href: string;
  label: string;
  eyebrow?: string;
  variant?: "section" | "table";
  done?: boolean;
  showArrow?: boolean;
  doneLabel?: string;
  resultType?:
    | "white-win"
    | "black-win"
    | "draw"
    | "forfeit-white"
    | "forfeit-black"
    | "forfeit-both";
  ariaLabel?: string;
}

const {
  href,
  label,
  eyebrow,
  variant = "section",
  done = false,
  showArrow = false,
  doneLabel,
  resultType,
  ariaLabel,
} = Astro.props;
---

<a
  class:list={[
    "selection-tile",
    `selection-tile--${variant}`,
    { "selection-tile--done": done, "selection-tile--arrow": showArrow },
    resultType && `selection-tile--${resultType}`,
  ]}
  href={href}
  aria-label={ariaLabel}
>
  <span class="selection-tile__body">
    {eyebrow && <span class="selection-tile__eyebrow">{eyebrow}</span>}
    <span class="selection-tile__label">{label}</span>
  </span>

  {
    done && (
      <div class="selection-tile__done" aria-hidden="true">
        <span class="selection-tile__done-circle">
          <span class="selection-tile__done-icon">✓</span>
        </span>
        {doneLabel && (
          <span class="selection-tile__done-text">{doneLabel}</span>
        )}
      </div>
    )
  }

  {
    showArrow && (
      <span class="selection-tile__arrow-mark" aria-hidden="true">
        →
      </span>
    )
  }
</a>

<style>
  .selection-tile {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    min-width: 0;
    min-height: calc(var(--space-12) + var(--space-6));
    padding: var(--space-5);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(
        140deg,
        color-mix(in srgb, var(--primary-fixed-dim) 8%, transparent),
        transparent 45%
      ),
      var(--surface-container-high);
    color: var(--on-surface);
    text-decoration: none;
    overflow: hidden;
    transition:
      transform var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .selection-tile:hover {
    background:
      linear-gradient(
        140deg,
        color-mix(in srgb, var(--primary-fixed-dim) 12%, transparent),
        transparent 52%
      ),
      var(--surface-container-highest);
    transform: translateY(-1px);
    box-shadow: var(--shadow-ambient);
  }

  .selection-tile:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .selection-tile__accent {
    align-self: stretch;
    width: 4px;
    border-radius: var(--radius-full);
    background: linear-gradient(
      180deg,
      var(--primary-fixed-dim),
      var(--primary-container)
    );
    flex-shrink: 0;
  }

  .selection-tile__body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-1);
    min-width: 0;
    flex: 1;
  }

  .selection-tile__eyebrow {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .selection-tile__label {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: inherit;
    overflow-wrap: anywhere;
  }

  .selection-tile__arrow-mark {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--primary-container);
    flex-shrink: 0;
  }

  .selection-tile__done {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-1);
    border-radius: var(--radius-full);
    background: var(--accent);
    color: var(--on-primary-fixed);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }

  .selection-tile__done-circle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.125rem;
    height: 1.125rem;
    border-radius: var(--radius-full);
    background: var(--on-primary-fixed);
    color: var(--accent);
    flex-shrink: 0;
  }

  .selection-tile__done-icon {
    font-size: var(--text-sm);
    font-weight: var(--weight-extrabold);
    line-height: 1;
  }

  .selection-tile--done {
    background:
      linear-gradient(
        140deg,
        color-mix(in srgb, var(--primary-container) 10%, transparent),
        transparent 55%
      ),
      var(--surface-container-high);
  }

  .selection-tile--done:hover {
    background:
      linear-gradient(
        140deg,
        color-mix(in srgb, var(--primary-container) 12%, transparent),
        transparent 55%
      ),
      var(--surface-container-highest);
  }

  .selection-tile--white-win {
    background: var(--tertiary-fixed-dim);
    color: #000;
  }

  .selection-tile--white-win:hover {
    background: color-mix(in srgb, var(--tertiary-fixed-dim) 85%, #fff);
  }

  .selection-tile--white-win .selection-tile__label {
    color: #000;
  }

  .selection-tile--black-win {
    background: #000;
    color: #fff;
  }

  .selection-tile--black-win:hover {
    background: #1a1a1a;
  }

  .selection-tile--black-win .selection-tile__label {
    color: #fff;
  }

  .selection-tile--draw {
    background: var(--accent);
    color: #000;
  }

  .selection-tile--draw:hover {
    background: color-mix(in srgb, var(--accent) 85%, #fff);
  }

  .selection-tile--draw .selection-tile__label {
    color: #000;
  }

  .selection-tile--draw .selection-tile__done {
    background: #000;
    color: #fff;
  }

  .selection-tile--draw .selection-tile__done-circle {
    background: #fff;
    color: #000;
  }

  .selection-tile--forfeit-white {
    background: linear-gradient(
      45deg,
      var(--tertiary-fixed-dim) 80%,
      var(--red-500) 80%
    );
    color: #000;
  }

  .selection-tile--forfeit-white:hover {
    background: linear-gradient(
      45deg,
      color-mix(in srgb, var(--tertiary-fixed-dim) 85%, #fff) 80%,
      color-mix(in srgb, var(--red-500) 85%, #fff) 80%
    );
  }

  .selection-tile--forfeit-white .selection-tile__label {
    color: #000;
  }

  .selection-tile--forfeit-black {
    background: linear-gradient(135deg, var(--red-500) 20%, #000 20%);
    color: #fff;
  }

  .selection-tile--forfeit-black:hover {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--red-500) 85%, #fff) 20%,
      #1a1a1a 20%
    );
  }

  .selection-tile--forfeit-black .selection-tile__label {
    color: #fff;
  }

  .selection-tile--forfeit-both {
    background: var(--red-500);
    color: #fff;
  }

  .selection-tile--forfeit-both:hover {
    background: color-mix(in srgb, var(--red-500) 85%, #fff);
  }

  .selection-tile--forfeit-both .selection-tile__label {
    color: #fff;
  }

  .selection-tile--table {
    min-height: 0;
    justify-content: center;
    flex-direction: column;
    padding: var(--space-6);
  }

  .selection-tile--table .selection-tile__body {
    align-items: center;
    text-align: center;
    gap: var(--space-2);
  }

  .selection-tile--table .selection-tile__eyebrow {
    color: var(--text-muted);
  }

  .selection-tile--table .selection-tile__label {
    font-size: clamp(var(--text-4xl), 6vw, var(--text-display-lg));
    line-height: var(--leading-none);
    letter-spacing: var(--tracking-tight);
  }

  .selection-tile--table .selection-tile__done {
    padding-inline: var(--space-2);
  }

  @media (max-width: 720px) {
    .selection-tile {
      min-height: calc(var(--space-12) + var(--space-4));
      padding: var(--space-4);
    }

    .selection-tile__label {
      font-size: var(--text-xl);
    }
  }

  @media (forced-colors: active) {
    .selection-tile {
      background: Canvas;
      color: CanvasText;
      border: 1px solid ButtonBorder;
      box-shadow: none;
    }

    .selection-tile:hover {
      background: Canvas;
      transform: none;
    }

    .selection-tile__accent,
    .selection-tile__done {
      background: Highlight;
      color: HighlightText;
    }

    .selection-tile__done-circle {
      background: HighlightText;
      color: Highlight;
    }

    .selection-tile__arrow-mark {
      color: CanvasText;
    }
  }
</style>
