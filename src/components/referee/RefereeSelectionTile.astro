---
interface Props {
  href: string;
  label: string;
  eyebrow?: string;
  variant?: "section" | "table";
  done?: boolean;
  showArrow?: boolean;
  doneLabel?: string;
  ariaLabel?: string;
}

const {
  href,
  label,
  eyebrow,
  variant = "section",
  done = false,
  showArrow = false,
  doneLabel,
  ariaLabel,
} = Astro.props;
---

<a
  class:list={[
    "selection-tile",
    `selection-tile--${variant}`,
    { "selection-tile--done": done, "selection-tile--arrow": showArrow },
  ]}
  href={href}
  aria-label={ariaLabel}
>
  <span class="selection-tile__accent" aria-hidden="true"></span>
  {done && (
    <span class="selection-tile__done" aria-hidden="true">
      <span class="selection-tile__done-icon">✓</span>
      {doneLabel && <span class="selection-tile__done-text">{doneLabel}</span>}
    </span>
  )}

  <span class="selection-tile__body">
    {eyebrow && <span class="selection-tile__eyebrow">{eyebrow}</span>}
    <span class="selection-tile__label">{label}</span>
  </span>

  {showArrow && <span class="selection-tile__arrow-mark" aria-hidden="true">→</span>}
</a>

<style>
  .selection-tile {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-4);
    min-width: 0;
    min-height: calc(var(--space-12) + var(--space-6));
    padding: var(--space-5);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(140deg, color-mix(in srgb, var(--primary-fixed-dim) 8%, transparent), transparent 45%),
      var(--surface-container-high);
    color: var(--on-surface);
    text-decoration: none;
    overflow: hidden;
    transition:
      transform var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .selection-tile:hover {
    background:
      linear-gradient(140deg, color-mix(in srgb, var(--primary-fixed-dim) 12%, transparent), transparent 52%),
      var(--surface-container-highest);
    transform: translateY(-1px);
    box-shadow: var(--shadow-ambient);
  }

  .selection-tile:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .selection-tile__accent {
    align-self: stretch;
    width: 4px;
    border-radius: var(--radius-full);
    background: linear-gradient(180deg, var(--primary-fixed-dim), var(--primary-container));
    flex-shrink: 0;
  }

  .selection-tile__body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-1);
    min-width: 0;
    flex: 1;
  }

  .selection-tile__eyebrow {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .selection-tile__label {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: inherit;
    overflow-wrap: anywhere;
  }

  .selection-tile__arrow-mark {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--primary-container);
    flex-shrink: 0;
  }

  .selection-tile__done {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-full);
    background: var(--win-subtle);
    color: var(--green-400);
    font-size: var(--text-2xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }

  .selection-tile__done-icon {
    font-size: var(--text-xs);
    line-height: 1;
  }

  .selection-tile--done {
    background:
      linear-gradient(140deg, color-mix(in srgb, var(--green-400) 10%, transparent), transparent 55%),
      var(--surface-container-high);
  }

  .selection-tile--done:hover {
    background:
      linear-gradient(140deg, color-mix(in srgb, var(--green-400) 12%, transparent), transparent 55%),
      var(--surface-container-highest);
  }

  .selection-tile--table {
    aspect-ratio: 1;
    min-height: 0;
    justify-content: center;
    padding: var(--space-4);
  }

  .selection-tile--table .selection-tile__accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    width: auto;
    height: 4px;
    align-self: auto;
  }

  .selection-tile--table .selection-tile__body {
    align-items: center;
    text-align: center;
    gap: var(--space-2);
  }

  .selection-tile--table .selection-tile__eyebrow {
    color: var(--text-muted);
  }

  .selection-tile--table .selection-tile__label {
    font-size: clamp(var(--text-4xl), 6vw, var(--text-display-lg));
    line-height: var(--leading-none);
    letter-spacing: var(--tracking-tight);
  }

  .selection-tile--table .selection-tile__done {
    padding-inline: var(--space-2);
  }

  .selection-tile--table .selection-tile__done-text {
    display: none;
  }

  @media (max-width: 720px) {
    .selection-tile {
      min-height: calc(var(--space-12) + var(--space-4));
      padding: var(--space-4);
    }

    .selection-tile__label {
      font-size: var(--text-xl);
    }
  }

  @media (forced-colors: active) {
    .selection-tile {
      background: Canvas;
      color: CanvasText;
      border: 1px solid ButtonBorder;
      box-shadow: none;
    }

    .selection-tile:hover {
      background: Canvas;
      transform: none;
    }

    .selection-tile__accent,
    .selection-tile__done {
      background: Highlight;
      color: HighlightText;
    }

    .selection-tile__arrow-mark {
      color: CanvasText;
    }
  }
</style>