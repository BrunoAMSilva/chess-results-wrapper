---
import { useTranslations } from '../../i18n/ui';
import { resolvePageLang } from '../../lib/page-lang';
import PlayerName from '../player/PlayerName.astro';

type Props = {
  whiteName: string;
  blackName: string;
  whiteTitle?: string;
  blackTitle?: string;
};
const lang = resolvePageLang(Astro.url, Astro.cookies);
const t = useTranslations(lang);
const { whiteName, blackName, whiteTitle, blackTitle } = Astro.props;
---

<div class="table-matchup">
  <div class="player-row">
    <span class="piece-icon white-icon">♔</span>
    <div class="player-wrapper">
      <PlayerName name={whiteName} title={whiteTitle} />
      <span class="player-color">{t("player.white")}</span>
    </div>
  </div>
  <div class="matchup-divider" aria-hidden="true">
    <hr class="divider-line" />
    <span class="divider-label">vs</span>
    <hr class="divider-line" />
  </div>
  <div class="player-row">
    <span class="piece-icon black-icon">♚</span>
    <div class="player-wrapper">
      <PlayerName name={blackName} title={blackTitle} />
      <span class="player-color">{t("player.black")}</span>
    </div>
  </div>
</div>
<style>
  .table-matchup {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: var(--space-6);
    width: 100%;
    background: var(--bg-subtle);
    padding: var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
  }

  .player-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) 0;
  }

  .piece-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-full, 50%);
    font-size: var(--text-2xl);
    line-height: 1;
    flex-shrink: 0;
  }

  .white-icon {
    background: var(--white-piece);
    color: var(--white-piece-text);
  }

  .black-icon {
    background: var(--black-piece-dark);
    color: var(--white-piece);
  }

  .player-name {
    display: block;
    font-size: var(--text-lg);
    font-weight: var(--font-semibold);
    line-height: var(--leading-tight);
    color: var(--text);
  }

  .player-color {
    font-size: var(--text-xs);
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: var(--leading-normal);
  }

  .matchup-divider {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-1) 0;
  }

  .divider-line {
    flex: 1;
    border: 1px solid var(--border);
    margin: 0;
  }

  .divider-label {
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--text-dim);
    background-color: var(--bg);
    padding: var(--space-2);
    display: inline-block;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }
</style>
