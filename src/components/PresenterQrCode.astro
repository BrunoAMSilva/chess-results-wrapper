---
interface Props {
  targetPath: string;
  label: string;
  hint: string;
  alt?: string;
  size?: "compact" | "large";
}

const {
  targetPath,
  label,
  hint,
  alt = "QR Code",
  size = "compact",
} = Astro.props;

const qrSize = size === "large" ? 180 : 80;
---

<div class:list={["presenter-qr-card", size]}>
  <div class="presenter-qr-text">
    <div class="presenter-qr-label">{label}</div>
    <div class="presenter-qr-hint">{hint}</div>
  </div>
  <div class="presenter-qr-image-wrap">
    <img
      class="presenter-qr-image"
      data-qr-path={targetPath}
      data-qr-size={qrSize}
      src=""
      alt={alt}
      width={size === "large" ? 180 : 48}
      height={size === "large" ? 180 : 48}
    />
  </div>
</div>

<script>
  document.querySelectorAll<HTMLImageElement>('img[data-qr-path]').forEach((img) => {
    const path = img.dataset.qrPath!;
    const size = img.dataset.qrSize || '180';
    const targetUrl = `${window.location.origin}${path}`;
    img.src = `https://api.qrserver.com/v1/create-qr-code/?size=${size}x${size}&data=${encodeURIComponent(targetUrl)}`;
  });
</script>

<style>
  .presenter-qr-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    background: var(--surface);
    padding: var(--space-2);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }

  .presenter-qr-text {
    font-size: var(--text-sm);
    text-align: right;
    line-height: var(--leading-tight);
  }

  .presenter-qr-card.large {
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-3);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
  }

  .presenter-qr-card.large .presenter-qr-text {
    text-align: center;
  }

  .presenter-qr-card.large .presenter-qr-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: var(--tracking-wide);
  }

  .presenter-qr-card.large .presenter-qr-hint {
    font-size: var(--text-lg);
    color: var(--text);
    line-height: var(--leading-tight);
  }

  .presenter-qr-card.large .presenter-qr-image-wrap {
    display: flex;
    justify-content: center;
  }

  .presenter-qr-card.large .presenter-qr-image {
    width: min(100%, 220px);
    height: auto;
    aspect-ratio: 1;
    background: var(--neutral-50);
    padding: var(--space-2);
    box-shadow: var(--shadow-sm);
  }

  .presenter-qr-label {
    color: var(--text-dim);
    text-transform: uppercase;
  }

  .presenter-qr-hint {
    font-weight: var(--weight-bold);
    color: var(--accent);
  }

  .presenter-qr-image {
    border-radius: var(--radius-sm);
  }
</style>
