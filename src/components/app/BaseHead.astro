---
interface Props {
  title: string;
  manifest?: string;
}

const { title, manifest = "/manifest.json" } = Astro.props;
const shouldRegisterServiceWorker = import.meta.env.PROD;
---

<meta charset="UTF-8" />
<meta
  name="viewport"
  content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"
/>
<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content="Chess Results" />
<link rel="manifest" href={manifest} />
<meta name="theme-color" content="#fcd34d" />
<title>{title}</title>
<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap"
  rel="stylesheet"
/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
<style is:global>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
</style>
<script is:inline define:vars={{ shouldRegisterServiceWorker }}>
  const devServiceWorkerResetKey = 'dev-service-worker-reset';

  if ('serviceWorker' in navigator && !shouldRegisterServiceWorker) {
    const hadController = Boolean(navigator.serviceWorker.controller);
    const alreadyReset = sessionStorage.getItem(devServiceWorkerResetKey) === '1';

    Promise.all([
      navigator.serviceWorker.getRegistrations().then((registrations) => {
        registrations.forEach((registration) => {
          registration.unregister();
        });
      }),
      'caches' in window
        ? caches.keys().then((keys) => {
            keys.forEach((key) => caches.delete(key));
          })
        : Promise.resolve(),
    ]).finally(() => {
      if (hadController && !alreadyReset) {
        sessionStorage.setItem(devServiceWorkerResetKey, '1');
        location.reload();
        return;
      }

      sessionStorage.removeItem(devServiceWorkerResetKey);
    });
  }
</script>
<script>
  // Inline theme script to prevent FOUC
  (function() {
    const stored = (() => { try { return localStorage.getItem('theme'); } catch { return null; } })();
    if (stored === 'light' || stored === 'dark') {
      document.documentElement.setAttribute('data-theme', stored);
    }
  })();
</script>

<script src="../../scripts/theme.ts"></script>
<script is:inline define:vars={{ shouldRegisterServiceWorker }}>
  if ('serviceWorker' in navigator) {
    if (shouldRegisterServiceWorker) {
      navigator.serviceWorker.register('/sw.js');
    }
  }
</script>
