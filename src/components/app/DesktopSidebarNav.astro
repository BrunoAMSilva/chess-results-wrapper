---
import Icon from "./Icon.astro";
import type { IconName } from "../../lib/ui/icons";

interface SidebarItem {
  href?: string;
  label: string;
  icon: IconName;
  active?: boolean;
  hidden?: boolean;
  profileNav?: boolean;
}

interface Props {
  brand: string;
  brandHref: string;
  navLabel: string;
  collapseLabel: string;
  expandLabel: string;
  items: SidebarItem[];
  footerActions?: SidebarItem[];
}

const {
  brand,
  brandHref,
  navLabel,
  collapseLabel,
  expandLabel,
  items,
  footerActions = [],
} = Astro.props;
---

<aside class="desktop-sidebar" aria-label={navLabel}>
  <div class="desktop-sidebar__panel">
    <div class="desktop-sidebar__header">
      <a href={brandHref} class="desktop-sidebar__brand" aria-label={brand} title={brand}>
        <span class="desktop-sidebar__brand-mark" aria-hidden="true">VC</span>
        <span class="desktop-sidebar__brand-copy">{brand}</span>
      </a>

      <button
        type="button"
        class="desktop-sidebar__trigger"
        data-sidebar-toggle
        data-collapse-label={collapseLabel}
        data-expand-label={expandLabel}
        aria-expanded="true"
        aria-label={collapseLabel}
        title={collapseLabel}
      >
        <Icon name="chevron-left" size={18} />
        <span class="desktop-sidebar__sr-only">{collapseLabel}</span>
      </button>
    </div>

    <div class="desktop-sidebar__content">
      <nav class="desktop-sidebar__nav" aria-label={navLabel}>
        <ul class="desktop-sidebar__menu" role="list">
          {items.map((item) => (
            <li class="desktop-sidebar__menu-item">
              <a
                href={item.href}
                class:list={["desktop-sidebar__item", { active: item.active }]}
                aria-current={item.active ? "page" : undefined}
                aria-label={item.label}
                hidden={item.hidden}
                data-profile-nav={item.profileNav ? true : undefined}
              >
                <span class="desktop-sidebar__icon" aria-hidden="true">
                  <Icon name={item.icon} size={20} />
                </span>
                <span class="desktop-sidebar__label">{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    {footerActions.length > 0 && (
      <div class="desktop-sidebar__footer">
        <ul class="desktop-sidebar__menu desktop-sidebar__menu--footer" role="list">
          {footerActions.map((item) => (
            <li class="desktop-sidebar__menu-item">
              <a
                href={item.href}
                class:list={["desktop-sidebar__item", "desktop-sidebar__item--footer", { active: item.active }]}
                aria-current={item.active ? "page" : undefined}
                aria-label={item.label}
              >
                <span class="desktop-sidebar__icon" aria-hidden="true">
                  <Icon name={item.icon} size={20} />
                </span>
                <span class="desktop-sidebar__label">{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</aside>

<style>
  .desktop-sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .desktop-sidebar {
      display: flex;
      width: var(--sidebar-width);
      flex-shrink: 0;
      min-height: 0;
      transition: width var(--duration-normal) var(--ease-in-out);
    }

    .desktop-sidebar__panel {
      display: flex;
      flex: 1;
      min-height: 0;
      flex-direction: column;
      gap: var(--space-4);
      padding: var(--space-4);
      border-radius: var(--radius-xl);
      background: color-mix(in srgb, var(--surface-container-low) 88%, transparent);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      box-shadow: var(--shadow-ambient);
    }

    .desktop-sidebar__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-2);
    }

    .desktop-sidebar__brand,
    .desktop-sidebar__trigger,
    .desktop-sidebar__item {
      outline: 2px solid transparent;
      outline-offset: 2px;
    }

    .desktop-sidebar__brand {
      min-width: 0;
      flex: 1;
      display: inline-flex;
      align-items: center;
      gap: var(--space-3);
      min-height: calc(var(--space-10) + var(--space-1));
      padding: 0 var(--space-2);
      border-radius: var(--radius-md);
      text-decoration: none;
      color: var(--text);
    }

    .desktop-sidebar__brand:hover {
      background: color-mix(in srgb, var(--surface-container-high) 72%, transparent);
    }

    .desktop-sidebar__brand-mark {
      width: calc(var(--space-8) + var(--space-2));
      height: calc(var(--space-8) + var(--space-2));
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--radius-md);
      background: linear-gradient(145deg, var(--primary-fixed-dim), var(--primary-container));
      color: var(--on-primary-fixed);
      font-size: var(--text-sm);
      font-weight: var(--weight-extrabold);
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .desktop-sidebar__brand-copy {
      min-width: 0;
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
      font-family: var(--font-display);
      font-size: var(--text-lg);
      font-weight: var(--weight-bold);
      transition:
        width var(--duration-fast) var(--ease-in-out),
        opacity var(--duration-fast) var(--ease-in-out);
    }

    .desktop-sidebar__trigger {
      width: calc(var(--space-8) + var(--space-1));
      height: calc(var(--space-8) + var(--space-1));
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      border: none;
      border-radius: var(--radius-md);
      background: transparent;
      color: var(--text-dim);
      cursor: pointer;
      transition:
        background var(--duration-fast) var(--ease-in-out),
        color var(--duration-fast) var(--ease-in-out);
    }

    .desktop-sidebar__trigger:hover {
      color: var(--text);
      background: color-mix(in srgb, var(--surface-container-high) 72%, transparent);
    }

    .desktop-sidebar__trigger :global(.icon) {
      transition: transform var(--duration-fast) var(--ease-in-out);
    }

    .desktop-sidebar__content {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
    }

    .desktop-sidebar__nav {
      min-height: 100%;
    }

    .desktop-sidebar__menu {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
      margin: 0;
      padding: 0;
    }

    .desktop-sidebar__menu-item {
      list-style: none;
    }

    .desktop-sidebar__item {
      position: relative;
      display: flex;
      align-items: center;
      gap: var(--space-3);
      min-height: calc(var(--space-10) + var(--space-1));
      padding: 0 var(--space-3);
      border-radius: var(--radius-md);
      color: var(--text-dim);
      text-decoration: none;
      font-size: var(--text-sm);
      font-weight: var(--weight-semibold);
      overflow: hidden;
      transition:
        background var(--duration-fast) var(--ease-in-out),
        color var(--duration-fast) var(--ease-in-out),
        transform var(--duration-fast) var(--ease-out);
    }

    .desktop-sidebar__item::before {
      content: "";
      position: absolute;
      inset-block: var(--space-2);
      inset-inline-start: var(--space-1);
      width: 3px;
      border-radius: var(--radius-full);
      background: transparent;
      opacity: 0;
      transition:
        background var(--duration-fast) var(--ease-in-out),
        opacity var(--duration-fast) var(--ease-in-out);
    }

    .desktop-sidebar__item:hover {
      color: var(--text);
      background: color-mix(in srgb, var(--surface-container-high) 82%, transparent);
    }

    .desktop-sidebar__item.active {
      color: var(--accent-text);
      background: color-mix(in srgb, var(--seg-active-bg) 64%, var(--surface-container-high));
    }

    .desktop-sidebar__item.active::before {
      background: var(--accent);
      opacity: 1;
    }

    .desktop-sidebar__item--footer {
      color: var(--text-secondary);
      background: color-mix(in srgb, var(--surface-container-high) 88%, transparent);
    }

    .desktop-sidebar__item--footer:hover,
    .desktop-sidebar__item--footer.active {
      color: var(--text);
      background: color-mix(in srgb, var(--seg-active-bg) 54%, var(--surface-container-high));
    }

    .desktop-sidebar__icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: var(--space-6);
      height: var(--space-6);
      flex-shrink: 0;
    }

    .desktop-sidebar__label {
      min-width: 0;
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
      transition:
        width var(--duration-fast) var(--ease-in-out),
        opacity var(--duration-fast) var(--ease-in-out);
    }

    .desktop-sidebar__footer {
      margin-top: auto;
      padding-top: var(--space-2);
    }

    .desktop-sidebar__sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      white-space: nowrap;
      border: 0;
    }

    .desktop-sidebar__brand:focus-visible,
    .desktop-sidebar__trigger:focus-visible,
    .desktop-sidebar__item:focus-visible {
      outline-color: var(--accent);
    }

    :global(.app-shell[data-sidebar-state="collapsed"]) .desktop-sidebar {
      width: var(--sidebar-width-collapsed);
    }

    :global(.app-shell[data-sidebar-state="collapsed"]) .desktop-sidebar__brand-copy,
    :global(.app-shell[data-sidebar-state="collapsed"]) .desktop-sidebar__label {
      width: 0;
      opacity: 0;
    }

    :global(.app-shell[data-sidebar-state="collapsed"]) .desktop-sidebar__brand {
      padding-inline: var(--space-1);
    }

    :global(.app-shell[data-sidebar-state="collapsed"]) .desktop-sidebar__item {
      justify-content: center;
      padding-inline: 0;
    }

    :global(.app-shell[data-sidebar-state="collapsed"]) .desktop-sidebar__item::before {
      opacity: 0;
    }

    :global(.app-shell[data-sidebar-state="collapsed"]) .desktop-sidebar__trigger :global(.icon) {
      transform: rotate(180deg);
    }

    @media (forced-colors: active) {
      .desktop-sidebar__panel {
        background: Canvas;
        box-shadow: none;
        border: 1px solid ButtonBorder;
      }

      .desktop-sidebar__brand-mark {
        background: ButtonFace;
        color: ButtonText;
      }

      .desktop-sidebar__item,
      .desktop-sidebar__trigger,
      .desktop-sidebar__brand {
        border: 1px solid transparent;
      }

      .desktop-sidebar__item:hover,
      .desktop-sidebar__trigger:hover,
      .desktop-sidebar__brand:hover {
        border-color: Highlight;
      }

      .desktop-sidebar__item.active {
        background: Highlight;
        color: HighlightText;
      }

      .desktop-sidebar__item.active::before {
        background: HighlightText;
      }

      .desktop-sidebar__brand:focus-visible,
      .desktop-sidebar__trigger:focus-visible,
      .desktop-sidebar__item:focus-visible {
        outline-color: Highlight;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .desktop-sidebar,
      .desktop-sidebar__brand-copy,
      .desktop-sidebar__label,
      .desktop-sidebar__trigger :global(.icon),
      .desktop-sidebar__item,
      .desktop-sidebar__item::before,
      .desktop-sidebar__brand,
      .desktop-sidebar__trigger {
        transition-duration: 0.01ms;
      }
    }
  }
</style>

<script>
  import "../../scripts/desktop-sidebar";
</script>