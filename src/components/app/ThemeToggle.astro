---
/**
 * ThemeToggle — three-state toggle for System / Light / Dark.
 * Uses a segmented control style that matches the design system.
 */
import Icon from "./Icon.astro";

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class:list={["theme-toggle", className]} id="themeToggle">
  <button class="theme-option" data-theme-value="system" aria-label="System theme" title="System">
    <Icon name="monitor" size={16} />
    <span>System</span>
  </button>
  <button class="theme-option" data-theme-value="light" aria-label="Light theme" title="Light">
    <Icon name="sun" size={16} />
    <span>Light</span>
  </button>
  <button class="theme-option" data-theme-value="dark" aria-label="Dark theme" title="Dark">
    <Icon name="moon" size={16} />
    <span>Dark</span>
  </button>
</div>

<style>
  .theme-toggle {
    display: inline-flex;
    background: var(--seg-bg);
    border-radius: var(--radius-md);
    padding: 3px;
    gap: 2px;
  }

  .theme-option {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.75rem;
    border-radius: calc(var(--radius-md) - 2px);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--text-dim);
    cursor: pointer;
    background: transparent;
    transition: color var(--duration-fast) var(--ease-in-out),
                background var(--duration-fast) var(--ease-in-out),
                border-color var(--duration-fast) var(--ease-in-out);
    white-space: nowrap;
    font-family: inherit;
  }

  .theme-option:hover:not(.active) {
    color: var(--text-secondary);
    background: var(--surface-hover);
  }

  .theme-option.active {
    color: var(--seg-active-text);
    background: var(--seg-active-bg);
    box-shadow: var(--shadow-sm);
  }

  .theme-option svg {
    flex-shrink: 0;
  }

  .theme-option span {
    display: none;
  }

  @media (min-width: 480px) {
    .theme-option span {
      display: inline;
    }
  }
</style>

<script>
  function initThemeToggle() {
    const toggle = document.getElementById("themeToggle");
    if (!toggle) return;

    const buttons = toggle.querySelectorAll<HTMLButtonElement>(".theme-option");

    function setActive(value: string) {
      buttons.forEach((btn) => {
        btn.classList.toggle("active", btn.dataset.themeValue === value);
      });
    }

    // Set initial state
    const current = (window as any).__getTheme?.() || "system";
    setActive(current);

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const value = btn.dataset.themeValue as "light" | "dark" | "system";
        (window as any).__setTheme?.(value);
        setActive(value);
      });
    });
  }

  // Support both initial load and view transitions
  initThemeToggle();
  document.addEventListener("astro:after-swap", initThemeToggle);
</script>
