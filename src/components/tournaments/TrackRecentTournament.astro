---
interface Props {
  tid: string;
  name?: string;
  type?: string;
  date?: string;
  location?: string;
  playerCount?: number;
}

const {
  tid,
  name: tournamentName = "",
  type: tournamentType = "",
  date: tournamentDate = "",
  location: tournamentLocation = "",
  playerCount = 0,
} = Astro.props;
---

<script is:inline define:vars={{ tid, tournamentName, tournamentType, tournamentDate, tournamentLocation, playerCount }}>
  (function () {
    try {
      if (!tid) return;
      var key = "recentTournaments";
      var stored = localStorage.getItem(key);
      var recent = stored ? JSON.parse(stored) : [];
      var existing = recent.find(function (r) { return r.id === tid; });
      recent = recent.filter(function (r) { return r.id !== tid; });
      recent.unshift({
        id: tid,
        name: tournamentName || (existing && existing.name) || ("Tournament " + tid),
        type: tournamentType || (existing && existing.type) || "",
        date: tournamentDate || (existing && existing.date) || "",
        location: tournamentLocation || (existing && existing.location) || "",
        playerCount: playerCount > 0
          ? playerCount
          : existing && typeof existing.playerCount === "number"
            ? existing.playerCount
            : undefined,
      });
      recent = recent.slice(0, 5);
      localStorage.setItem(key, JSON.stringify(recent));
    } catch (e) { /* localStorage unavailable */ }
  })();
</script>
