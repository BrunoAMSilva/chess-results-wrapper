---
interface Props {
  recentLabel: string;
  linkBase?: string;
}

const { recentLabel, linkBase = "/pairings" } = Astro.props;
---

<section class="recent-section hidden" id="recentTournaments" aria-label={recentLabel} data-link-base={linkBase}>
  <h2 class="recent-heading">{recentLabel}</h2>
  <ul class="recent-list" id="recentList"></ul>
</section>

<style>
  .recent-section {
    width: 100%;
    margin-top: var(--space-6);
  }

  .recent-heading {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-3);
  }

  .recent-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  /* Card styles matching TournamentCard component */
  .recent-list :global(.tournament-card) {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--surface-container-high);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--on-surface);
    transition: background var(--duration-fast) var(--ease-out);
  }

  .recent-list :global(.tournament-card:hover) {
    background: var(--surface-container-highest);
  }

  .recent-list :global(.tournament-card:focus-visible) {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .recent-list :global(.card-icon) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--space-12);
    height: var(--space-12);
    flex-shrink: 0;
    border-radius: var(--radius-md);
    background: var(--surface-container-highest);
    color: var(--primary-container);
  }

  .recent-list :global(.card-body) {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }

  .recent-list :global(.card-name) {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    color: var(--on-surface);
  }

  .recent-list :global(.card-meta) {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .recent-list :global(.card-meta-item) {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    color: var(--text-dim);
  }

  .recent-list :global(.meta-icon) {
    flex-shrink: 0;
    color: var(--text-muted);
  }
</style>

<script>
  const TOURNAMENT_ICONS: Record<string, string> = {
    swiss: `<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 4h6v6H5z"/><path d="M13 14h6v6h-6z"/><path d="M8 10v2a2 2 0 0 0 2 2h3"/><path d="M16 10V8a2 2 0 0 0-2-2h-3"/></svg>`,
    'round-robin': `<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 8a6 6 0 0 1 11.31-2.72"/><path d="M18 4v4h-4"/><path d="M18 16a6 6 0 0 1-11.31 2.72"/><path d="M6 20v-4h4"/></svg>`,
    'team-swiss': `<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/><circle cx="9.5" cy="7" r="3"/><path d="M21 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 4.13a4 4 0 0 1 0 7.75"/></svg>`,
    'team-round-robin': `<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 19a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4"/><circle cx="8" cy="9" r="3"/><path d="M14 7h6"/><path d="M17 4l3 3-3 3"/><path d="M20 17h-6"/><path d="M17 14l-3 3 3 3"/></svg>`,
  };
  const CALENDAR_SVG = `<svg class="meta-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`;
  const PLAYERS_SVG = `<svg class="meta-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="3"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`;
  const LOCATION_SVG = `<svg class="meta-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`;

  type RecentTournament = {
    id: string;
    name: string;
    date?: string;
    location?: string;
    type?: string;
    playerCount?: number;
  };

  function escapeHtml(text: string): string {
    const el = document.createElement('span');
    el.textContent = text;
    return el.innerHTML;
  }

  function buildCardHtml(tournament: RecentTournament, href: string): string {
    const iconSvg = TOURNAMENT_ICONS[tournament.type || ''] || TOURNAMENT_ICONS.swiss;
    const name = tournament.name || `Tournament ${tournament.id}`;
    const safeName = escapeHtml(name);
    const safeDate = tournament.date ? escapeHtml(tournament.date) : '';
    const safeLocation = tournament.location ? escapeHtml(tournament.location) : '';
    const safePlayerCount = typeof tournament.playerCount === 'number' && tournament.playerCount > 0
      ? escapeHtml(String(tournament.playerCount))
      : '';

    const metaParts = [
      safeDate ? `<span class="card-meta-item">${CALENDAR_SVG}${safeDate}</span>` : '',
      safePlayerCount ? `<span class="card-meta-item">${PLAYERS_SVG}${safePlayerCount} players</span>` : '',
      safeLocation ? `<span class="card-meta-item">${LOCATION_SVG}${safeLocation}</span>` : '',
    ].filter(Boolean);

    const metaHtml = metaParts.length > 0
      ? `<span class="card-meta">${metaParts.join('')}</span>`
      : '';

    return `<a class="tournament-card" href="${escapeHtml(href)}">` +
      `<span class="card-icon" aria-hidden="true">${iconSvg}</span>` +
      `<span class="card-body">` +
        `<span class="card-name">${safeName}</span>` +
        metaHtml +
      `</span>` +
    `</a>`;
  }

  function initRecentTournaments() {
    const section = document.getElementById('recentTournaments');
    const list = document.getElementById('recentList');
    if (!section || !list) return;

    try {
      const stored = localStorage.getItem('recentTournaments');
      if (!stored) return;
      const recent: RecentTournament[] = JSON.parse(stored);
      if (!Array.isArray(recent) || recent.length === 0) return;

      const base = section.getAttribute('data-link-base') || '/pairings';

      list.innerHTML = '';
      for (const t of recent.slice(0, 5)) {
        const href = base.includes('{id}')
          ? base.replace('{id}', encodeURIComponent(t.id))
          : `${base}?tid=${encodeURIComponent(t.id)}`;

        const li = document.createElement('li');
        li.innerHTML = buildCardHtml(t, href);
        list.appendChild(li);
      }

      section.classList.remove('hidden');
    } catch {
      // localStorage unavailable or corrupted data — just hide
    }
  }

  document.addEventListener('DOMContentLoaded', initRecentTournaments);
  document.addEventListener('astro:after-swap', initRecentTournaments);
</script>
