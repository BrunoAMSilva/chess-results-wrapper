---
interface Props {
  recentLabel: string;
  linkBase?: string;
}

const { recentLabel, linkBase = "/pairings" } = Astro.props;
---

<section class="recent-section hidden" id="recentTournaments" aria-label={recentLabel} data-link-base={linkBase}>
  <h2 class="recent-heading">{recentLabel}</h2>
  <ul class="recent-list" id="recentList"></ul>
</section>

<style>
  .recent-section {
    width: 100%;
    margin-top: var(--space-6);
  }

  .recent-heading {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-3);
  }

  .recent-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  /* ── Card base ─────────────────────────────────────────────── */
  .recent-list :global(.tournament-card) {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--text);
    overflow: hidden;
    transition:
      background 150ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 250ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 250ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 250ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Top gold shine on hover */
  .recent-list :global(.tournament-card::before) {
    content: "";
    position: absolute;
    top: 0;
    left: 15%;
    right: 15%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0;
    transition:
      opacity 250ms cubic-bezier(0.16, 1, 0.3, 1),
      left 250ms cubic-bezier(0.16, 1, 0.3, 1),
      right 250ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .recent-list :global(.tournament-card:hover) {
    background: var(--surface-hover);
    border-color: rgba(252, 211, 77, 0.18);
    transform: translateY(-2px);
    box-shadow:
      0 8px 28px rgba(0, 0, 0, 0.18),
      0 0 0 1px rgba(252, 211, 77, 0.06);
  }

  .recent-list :global(.tournament-card:hover::before) {
    opacity: 1;
    left: 0;
    right: 0;
  }

  .recent-list :global(.tournament-card:focus-visible) {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Watermark */
  .recent-list :global(.card-watermark) {
    position: absolute;
    top: -6px;
    right: -4px;
    color: var(--accent);
    opacity: 0.055;
    transform: rotate(14deg);
    pointer-events: none;
    transition:
      opacity 250ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 250ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .recent-list :global(.tournament-card:hover .card-watermark) {
    opacity: 0.09;
    transform: rotate(8deg) scale(1.06);
  }

  /* Header row */
  .recent-list :global(.card-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  /* Type chip */
  .recent-list :global(.card-type-chip) {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--accent-text);
    background: var(--accent-subtle);
    border: 1px solid rgba(252, 211, 77, 0.18);
    border-radius: 9999px;
    padding: 2px 8px;
    line-height: 1.6;
    flex-shrink: 0;
  }

  /* Date */
  .recent-list :global(.card-date) {
    font-size: var(--text-2xs);
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  /* Name */
  .recent-list :global(.card-name) {
    font-size: var(--text-sm);
    font-weight: 600;
    line-height: 1.45;
    color: var(--text);
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Footer */
  .recent-list :global(.card-footer) {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    padding-top: var(--space-2);
    border-top: 1px solid var(--border-light);
    margin-top: auto;
  }

  /* Player badge */
  .recent-list :global(.card-players) {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--surface-raised);
    border-radius: 9999px;
    padding: 2px 8px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Location */
  .recent-list :global(.card-location) {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-xs);
    color: var(--text-dim);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }
</style>

<script>
  const SPRITE = '/icons/sprite.svg';

  function mkIcon(name: string, size: number, cls = ''): string {
    return `<svg${cls ? ` class="${cls}"` : ''} viewBox="0 0 24 24" width="${size}" height="${size}" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><use href="${SPRITE}#${name}"></use></svg>`;
  }

  const TYPE_LABELS: Record<string, string> = {
    'swiss': 'Swiss',
    'round-robin': 'Round Robin',
    'team-swiss': 'Team Swiss',
    'team-round-robin': 'Team RR',
  };

  const ICON_NAMES = ['swiss', 'round-robin', 'team-swiss', 'team-round-robin'] as const;

  function escapeHtml(text: string): string {
    const el = document.createElement('span');
    el.textContent = text;
    return el.innerHTML;
  }

  type RecentTournament = {
    id: string;
    name: string;
    date?: string;
    location?: string;
    type?: string;
    playerCount?: number;
  };

  function buildCardHtml(tournament: RecentTournament, href: string): string {
    const iconName = ICON_NAMES.includes(tournament.type as typeof ICON_NAMES[number])
      ? tournament.type!
      : 'swiss';
    const typeLabel = TYPE_LABELS[iconName] ?? 'Swiss';
    const name = tournament.name || `Tournament ${tournament.id}`;

    // Watermark
    const watermark = `<span class="card-watermark" aria-hidden="true">${mkIcon(iconName, 72)}</span>`;

    // Header
    const typeChipIcon = mkIcon(iconName, 10);
    const typeChip = `<span class="card-type-chip">${typeChipIcon}${escapeHtml(typeLabel)}</span>`;
    const dateHtml = tournament.date
      ? `<span class="card-date">${escapeHtml(tournament.date)}</span>`
      : '';
    const header = `<div class="card-header">${typeChip}${dateHtml}</div>`;

    // Name
    const nameHtml = `<p class="card-name">${escapeHtml(name)}</p>`;

    // Footer
    const playersHtml = tournament.playerCount && tournament.playerCount > 0
      ? `<span class="card-players">${mkIcon('users', 11)}${escapeHtml(String(tournament.playerCount))}</span>`
      : '';
    const locationHtml = tournament.location
      ? `<span class="card-location">${mkIcon('map-pin', 11)}${escapeHtml(tournament.location)}</span>`
      : '';
    const footerContent = playersHtml + locationHtml;
    const footer = footerContent
      ? `<div class="card-footer">${footerContent}</div>`
      : '';

    return `<a class="tournament-card" href="${escapeHtml(href)}">${watermark}${header}${nameHtml}${footer}</a>`;
  }

  function initRecentTournaments() {
    const section = document.getElementById('recentTournaments');
    const list = document.getElementById('recentList');
    if (!section || !list) return;

    try {
      const stored = localStorage.getItem('recentTournaments');
      if (!stored) return;
      const recent: RecentTournament[] = JSON.parse(stored);
      if (!Array.isArray(recent) || recent.length === 0) return;

      const base = section.getAttribute('data-link-base') || '/pairings';

      list.innerHTML = '';
      for (const t of recent.slice(0, 5)) {
        const href = base.includes('{id}')
          ? base.replace('{id}', encodeURIComponent(t.id))
          : `${base}?tid=${encodeURIComponent(t.id)}`;

        const li = document.createElement('li');
        li.innerHTML = buildCardHtml(t, href);
        list.appendChild(li);
      }

      section.classList.remove('hidden');
    } catch {
      // localStorage unavailable or corrupted data — just hide
    }
  }

  document.addEventListener('DOMContentLoaded', initRecentTournaments);
  document.addEventListener('astro:after-swap', initRecentTournaments);
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) initRecentTournaments();
  });
</script>
