---
interface Props {
  label: string;
  placeholder: string;
  submitLabel?: string;
  hint?: string;
  invalidMessage?: string;
  loadingMessage: string;
  noResultsMessage: string;
  lang?: string;
  navigateBasePath?: string;
  navigatePathTemplate?: string;
  recentStorageKey?: string;
  searchLimit?: number;
  showSubmit?: boolean;
  resultLayout?: 'dropdown' | 'stacked';
  autofocus?: boolean;
  class?: string;
}

const {
  label,
  placeholder,
  submitLabel = '',
  hint = '',
  invalidMessage = '',
  loadingMessage,
  noResultsMessage,
  lang = '',
  navigateBasePath = '/pairings',
  navigatePathTemplate,
  recentStorageKey = 'recentTournaments',
  searchLimit = 0,
  showSubmit = true,
  resultLayout = 'dropdown',
  autofocus = false,
  class: className = '',
} = Astro.props;

const instanceId = `tournament-search-${crypto.randomUUID().replaceAll('-', '')}`;
const inputId = `${instanceId}-input`;
const resultsId = `${instanceId}-results`;
const loadingId = `${instanceId}-loading`;
const noResultsId = `${instanceId}-no-results`;
const announceId = `${instanceId}-announce`;
const hintId = `${instanceId}-hint`;
const errorId = `${instanceId}-error`;
const describedBy = [hint ? hintId : '', invalidMessage ? errorId : ''].filter(Boolean).join(' ');
---

<div
  class:list={["tournament-search", `tournament-search--${resultLayout}`, className]}
  data-tournament-search-root
  data-lang={lang}
  data-base-path={navigateBasePath}
  data-path-template={navigatePathTemplate}
  data-recent-key={recentStorageKey}
  data-search-limit={String(searchLimit)}
  data-result-layout={resultLayout}
>
  <form class="search-form" data-search-form>
    <label class="search-label" for={inputId}>{label}</label>
    <div class="input-wrapper">
      <svg class="input-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input
        type="search"
        id={inputId}
        class="search-input"
        placeholder={placeholder}
        autocomplete="off"
        required
        role="combobox"
        aria-expanded="false"
        aria-controls={resultsId}
        aria-autocomplete="list"
        aria-haspopup="listbox"
        aria-activedescendant=""
        aria-describedby={describedBy || undefined}
        autofocus={autofocus}
        data-search-input
      />
      <div class="search-results hidden" id={resultsId} role="listbox" aria-label={`${label} results`} data-search-results>
        <p class="search-loading hidden" id={loadingId} data-search-loading>{loadingMessage}</p>
        <p class="no-results hidden" id={noResultsId} data-no-results>{noResultsMessage}</p>
      </div>
      <div class="sr-only" aria-live="polite" aria-atomic="true" id={announceId} data-search-announce></div>
    </div>
    {showSubmit && (
      <button type="submit" class="search-btn">
        {submitLabel}
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </button>
    )}
  </form>

  {hint && <p class="home-hint" id={hintId}>{hint}</p>}
  {invalidMessage && <p class="error-hint hidden" id={errorId} data-error-hint>{invalidMessage}</p>}
</div>

<style>
  .tournament-search {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    width: 100%;
    margin-top: var(--space-3);
  }

  .search-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    width: 100%;
  }

  .search-label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--text);
    text-align: left;
  }

  .input-wrapper {
    position: relative;
    width: 100%;
  }

  .input-icon {
    position: absolute;
    left: var(--space-4);
    top: var(--space-4);
    color: var(--text-muted);
    pointer-events: none;
    z-index: 2;
  }

  .search-input {
    width: 100%;
    padding: var(--space-4) var(--space-4) var(--space-4) var(--space-12);
    font-size: var(--text-base);
    font-family: var(--font-sans);
    color: var(--text);
    background: var(--input-bg);
    border: 1px solid var(--outline-variant);
    border-radius: var(--radius-lg);
    outline: none;
    transition:
      border-color var(--duration-fast) var(--ease-in-out),
      box-shadow var(--duration-fast) var(--ease-in-out);
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-input:focus-visible {
    border-color: var(--input-focus);
    box-shadow: 0 0 0 3px var(--input-focus-ring);
  }

  .search-results {
    background: var(--surface);
    border-radius: var(--radius-lg);
    max-height: 360px;
    overflow-y: auto;
  }

  .tournament-search--dropdown .search-results {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: var(--space-2);
    box-shadow: var(--shadow-lg);
    z-index: 20;
    overflow: hidden;
  }

  .tournament-search--stacked .search-results {
    position: static;
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: transparent;
    box-shadow: none;
    max-height: none;
    overflow: visible;
  }

  .search-loading {
    padding: var(--space-4);
    text-align: center;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .search-results :global(.result-item) {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    text-decoration: none;
    color: var(--text);
    transition: background var(--duration-fast) var(--ease-in-out);
    cursor: pointer;
    text-align: left;
  }

  .tournament-search--stacked .search-results :global(.result-item) {
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-xl);
    background: var(--surface-container-high);
    color: var(--on-surface);
    transition:
      transform var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .search-results :global(.result-item:last-child) {
    border-bottom: none;
  }

  .search-results :global(.result-item:hover),
  .search-results :global(.result-item.active) {
    background: var(--surface-hover);
  }

  .tournament-search--stacked .search-results :global(.result-item:hover),
  .tournament-search--stacked .search-results :global(.result-item.active) {
    background: var(--surface-container-highest);
    transform: translateY(-1px);
    box-shadow: var(--shadow-ambient);
  }

  .tournament-search--stacked .search-results :global(.result-item:focus-visible) {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .search-results :global(.result-icon) {
    flex-shrink: 0;
    color: var(--accent);
  }

  .search-results :global(.result-info) {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .search-results :global(.result-name) {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tournament-search--stacked .search-results :global(.result-name) {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: var(--leading-tight);
    white-space: normal;
  }

  .search-results :global(.result-meta) {
    font-size: var(--text-xs);
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tournament-search--stacked .search-results :global(.result-meta) {
    margin-top: var(--space-2);
    color: var(--text-dim);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    white-space: normal;
  }

  .search-results :global(.event-pills) {
    display: flex;
    gap: var(--space-1);
    flex-wrap: wrap;
    margin-top: var(--space-1);
  }

  .search-results :global(.event-pill) {
    font-size: var(--text-xs);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    background: var(--surface-hover);
    color: var(--text-dim);
    cursor: pointer;
    transition:
      background var(--duration-fast) var(--ease-in-out),
      color var(--duration-fast) var(--ease-in-out);
  }

  .search-results :global(.event-pill:hover) {
    background: var(--accent-subtle);
    color: var(--accent-text);
  }

  .search-results :global(.event-pill.current) {
    background: var(--accent-subtle);
    color: var(--accent-text);
    font-weight: var(--weight-semibold);
  }

  .no-results {
    padding: var(--space-4);
    text-align: center;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .tournament-search--stacked .no-results,
  .tournament-search--stacked .search-loading {
    border-radius: var(--radius-xl);
    background: var(--surface-container-high);
    color: var(--text-dim);
  }

  .search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    width: 100%;
    padding: var(--space-4);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--on-accent);
    background: var(--accent);
    border: none;
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition:
      background var(--duration-fast) var(--ease-in-out),
      box-shadow var(--duration-fast) var(--ease-in-out);
  }

  .search-btn:hover {
    background: var(--accent-hover);
    box-shadow: 0 0 20px var(--accent-glow);
  }

  .search-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .home-hint {
    font-size: var(--text-sm);
    color: var(--text-dim);
    font-family: var(--font-mono);
  }

  .error-hint {
    font-size: var(--text-sm);
    color: var(--red-400);
    font-weight: var(--weight-medium);
  }

  .hidden {
    display: none;
  }

  @media (min-width: 640px) {
    .search-form {
      flex-direction: row;
      align-items: end;
    }

    .input-wrapper {
      flex: 1;
    }

    .search-btn {
      width: auto;
      white-space: nowrap;
      padding: var(--space-4) var(--space-6);
    }

    .tournament-search--stacked .search-form {
      flex-direction: column;
      align-items: stretch;
    }
  }

  @media (forced-colors: active) {
    .search-input,
    .search-results,
    .search-btn {
      border: 1px solid ButtonBorder;
      box-shadow: none;
    }

    .search-input,
    .search-results {
      background: Canvas;
      color: CanvasText;
    }

    .search-btn {
      background: ButtonFace;
      color: ButtonText;
    }

    .search-btn:focus-visible,
    .search-input:focus-visible,
    .search-results :global(.result-item:focus-visible) {
      outline: 2px solid Highlight;
      outline-offset: 2px;
    }
  }
</style>

<script>
  function initTournamentSearch(root: HTMLElement) {
    if (root.dataset.tournamentSearchBound === 'true') return;
    root.dataset.tournamentSearchBound = 'true';

    const form = root.querySelector('[data-search-form]') as HTMLFormElement | null;
    const input = root.querySelector('[data-search-input]') as HTMLInputElement | null;
    const errorHint = root.querySelector('[data-error-hint]') as HTMLElement | null;
    const searchResults = root.querySelector('[data-search-results]') as HTMLElement | null;
    const noResults = root.querySelector('[data-no-results]') as HTMLElement | null;
    const searchLoading = root.querySelector('[data-search-loading]') as HTMLElement | null;
    const announceEl = root.querySelector('[data-search-announce]') as HTMLElement | null;

    if (!form || !input || !errorHint || !searchResults || !noResults || !searchLoading || !announceEl) return;

    const resultsEl = searchResults;
    const noResultsEl = noResults;
    const loadingEl = searchLoading;
    const inputEl = input;
    const announceRegion = announceEl;
    const lang = root.dataset.lang || '';
    const navigateBasePath = root.dataset.basePath || '/pairings';
    const navigatePathTemplate = root.dataset.pathTemplate || '';
    const recentStorageKey = root.dataset.recentKey || 'recentTournaments';
    const searchLimit = Number(root.dataset.searchLimit || '0');

    let debounceTimer: ReturnType<typeof setTimeout>;
    let activeIndex = -1;
    let latestRequestId = 0;
    let currentResults: Array<{
      id: string;
      name: string;
      type?: string;
      date?: string;
      location?: string;
      player_count?: number;
    }> = [];

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const raw = inputEl.value.trim();
      if (!raw) return;

      if (activeIndex >= 0 && currentResults[activeIndex]) {
        navigateToTournament(currentResults[activeIndex].id);
        return;
      }

      const tid = extractTournamentId(raw);
      if (tid) {
        hideDropdown();
        errorHint?.classList.add('hidden');
        navigateToTournament(tid);
      } else {
        errorHint?.classList.remove('hidden');
      }
    });

    inputEl.addEventListener('input', () => {
      errorHint?.classList.add('hidden');
      const raw = inputEl.value.trim();

      if (!raw || /^\d+$/.test(raw) || raw.includes('chess-results.com')) {
        hideDropdown();
        return;
      }

      if (raw.length < 2) {
        hideDropdown();
        return;
      }

      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        void searchTournaments(raw);
      }, 300);
    });

    inputEl.addEventListener('keydown', (event) => {
      if (!currentResults.length) return;
      const items = resultsEl.querySelectorAll('.result-item');

      if (event.key === 'ArrowDown') {
        event.preventDefault();
        activeIndex = Math.min(activeIndex + 1, items.length - 1);
        updateActiveItem(items);
      } else if (event.key === 'ArrowUp') {
        event.preventDefault();
        activeIndex = Math.max(activeIndex - 1, -1);
        updateActiveItem(items);
      } else if (event.key === 'Enter' && activeIndex >= 0) {
        event.preventDefault();
        navigateToTournament(currentResults[activeIndex].id);
      } else if (event.key === 'Escape') {
        hideDropdown();
      }
    });

    document.addEventListener('click', (event) => {
      if (!resultsEl.contains(event.target as Node) && !root.contains(event.target as Node)) {
        hideDropdown();
      }
    });

    const existing = inputEl.value.trim();
    if (existing && existing.length >= 2 && !/^\d+$/.test(existing) && !existing.includes('chess-results.com')) {
      void searchTournaments(existing);
    }

    async function searchTournaments(query: string) {
      const requestId = ++latestRequestId;
      setLoading(true);

      try {
        const limitSuffix = searchLimit > 0 ? `&limit=${searchLimit}` : '';
        const response = await fetch(`/api/search?q=${encodeURIComponent(query)}${limitSuffix}`);
        if (requestId !== latestRequestId) return;
        if (!response.ok) {
          hideDropdown();
          return;
        }
        const data = await response.json();
        renderResults(data);
      } catch {
        hideDropdown();
      } finally {
        if (requestId === latestRequestId) {
          setLoading(false);
        }
      }
    }

    function renderResults(results: Array<{ id: string; name: string; type: string; total_rounds: number; date: string; location: string; event_label: string; linked_tournaments: string; player_count?: number }>) {
      currentResults = results;
      activeIndex = -1;

      resultsEl.querySelectorAll('.result-item').forEach((element) => element.remove());

      if (results.length === 0) {
        noResultsEl.classList.remove('hidden');
        resultsEl.classList.remove('hidden');
        inputEl.setAttribute('aria-expanded', 'true');
        announceRegion.textContent = noResultsEl.textContent || '';
        return;
      }

      noResultsEl.classList.add('hidden');
      for (const [index, tournament] of results.entries()) {
        const item = document.createElement('a');
        item.className = 'result-item';
        item.id = `${inputEl.id}-result-${index}`;
        item.setAttribute('role', 'option');
        item.setAttribute('aria-selected', 'false');
        item.href = buildTournamentHref(tournament.id);

        const meta = [tournament.date, tournament.location, `${tournament.total_rounds} rounds`]
          .filter(Boolean)
          .join(' · ');

        let linkedHtml = '';
        const linked: Array<{ id: string; name: string }> = (() => {
          try {
            return JSON.parse(tournament.linked_tournaments || '[]');
          } catch {
            return [];
          }
        })();

        if (linked.length > 0) {
          const pills = linked
            .sort((left, right) => left.name.localeCompare(right.name))
            .map((linkedTournament) => `<span class="event-pill" data-tid="${escapeHtml(linkedTournament.id)}">${escapeHtml(linkedTournament.name)}</span>`)
            .join('');
          linkedHtml = `<span class="event-pills">${pills}</span>`;
        }

        item.innerHTML = `
          <svg class="result-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 6v6l4 2"></path>
          </svg>
          <span class="result-info">
            <span class="result-name">${escapeHtml(tournament.name)}</span>
            ${linkedHtml}
            <span class="result-meta">${escapeHtml(meta)}</span>
          </span>
        `;

        item.querySelectorAll('.event-pill').forEach((pill) => {
          pill.addEventListener('click', (event) => {
            event.preventDefault();
            event.stopPropagation();
            const pillTid = (pill as HTMLElement).dataset.tid;
            if (pillTid) navigateToTournament(pillTid);
          });
        });

        item.addEventListener('click', (event) => {
          event.preventDefault();
          navigateToTournament(tournament.id);
        });

        resultsEl.appendChild(item);
      }

      resultsEl.classList.remove('hidden');
      inputEl.setAttribute('aria-expanded', 'true');
      announceRegion.textContent = String(results.length);
    }

    function updateActiveItem(items: NodeListOf<Element>) {
      items.forEach((element, index) => {
        const isActive = index === activeIndex;
        element.classList.toggle('active', isActive);
        element.setAttribute('aria-selected', String(isActive));
      });

      inputEl.setAttribute('aria-activedescendant', activeIndex >= 0 ? `${inputEl.id}-result-${activeIndex}` : '');
    }

    function hideDropdown() {
      resultsEl.classList.add('hidden');
      setLoading(false);
      inputEl.setAttribute('aria-expanded', 'false');
      inputEl.setAttribute('aria-activedescendant', '');
      currentResults = [];
      activeIndex = -1;
    }

    function setLoading(isLoading: boolean) {
      loadingEl.classList.toggle('hidden', !isLoading);
      noResultsEl.classList.add('hidden');
      if (isLoading) {
        resultsEl.querySelectorAll('.result-item').forEach((element) => element.remove());
        resultsEl.classList.remove('hidden');
        inputEl.setAttribute('aria-expanded', 'true');
        announceRegion.textContent = loadingEl.textContent || '';
      }
    }

    function navigateToTournament(tid: string) {
      const entry = currentResults.find((result) => result.id === tid);
      saveRecentTournament(entry || { id: tid, name: `Tournament ${tid}` });
      window.location.href = buildTournamentHref(tid);
    }

    function buildTournamentHref(tid: string) {
      if (navigatePathTemplate) {
        const href = navigatePathTemplate.replace('{id}', encodeURIComponent(tid));
        if (lang) {
          const separator = href.includes('?') ? '&' : '?';
          return `${href}${separator}lang=${encodeURIComponent(lang)}`;
        }
        return href;
      }

      const params = new URLSearchParams({ tid });
      if (lang) params.set('lang', lang);
      return `${navigateBasePath}?${params.toString()}`;
    }

    function saveRecentTournament(entry: { id: string; name?: string; type?: string; date?: string; location?: string; player_count?: number }) {
      try {
        const stored = localStorage.getItem(recentStorageKey);
        let recent: Array<{ id: string; name: string; type?: string; date?: string; location?: string; playerCount?: number }> = stored ? JSON.parse(stored) : [];
        const existing = recent.find((result) => result.id === entry.id);
        recent = recent.filter((result) => result.id !== entry.id);
        recent.unshift({
          id: entry.id,
          name: entry.name || existing?.name || `Tournament ${entry.id}`,
          type: entry.type || existing?.type || '',
          date: entry.date || existing?.date || '',
          location: entry.location || existing?.location || '',
          playerCount: typeof entry.player_count === 'number' && entry.player_count > 0
            ? entry.player_count
            : existing?.playerCount,
        });
        recent = recent.slice(0, 5);
        localStorage.setItem(recentStorageKey, JSON.stringify(recent));
      } catch {
        // localStorage unavailable.
      }
    }
  }

  function extractTournamentId(input: string): string | null {
    if (/^\d+$/.test(input)) return input;
    const urlMatch = input.match(/chess-results\.com\/tnr(\d+)\.aspx/i);
    if (urlMatch) return urlMatch[1];
    return null;
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function initTournamentSearchForms() {
    document.querySelectorAll<HTMLElement>('[data-tournament-search-root]').forEach((root) => {
      initTournamentSearch(root);
    });
  }

  document.addEventListener('DOMContentLoaded', initTournamentSearchForms);
  document.addEventListener('astro:after-swap', initTournamentSearchForms);
</script>