---
import { TournamentType } from "../../lib/types";

interface Props {
  name: string;
  href: string;
  date?: string;
  location?: string;
  type?: TournamentType;
  playerCount?: number;
}

const { name, href, date, location, type, playerCount } = Astro.props;

const TOURNAMENT_ICONS: Record<TournamentType, string> = {
  [TournamentType.Swiss]: '<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h6v6H5z" /><path d="M13 14h6v6h-6z" /><path d="M8 10v2a2 2 0 0 0 2 2h3" /><path d="M16 10V8a2 2 0 0 0-2-2h-3" /></svg>',
  [TournamentType.RoundRobin]: '<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 11.31-2.72" /><path d="M18 4v4h-4" /><path d="M18 16a6 6 0 0 1-11.31 2.72" /><path d="M6 20v-4h4" /></svg>',
  [TournamentType.TeamSwiss]: '<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2" /><circle cx="9.5" cy="7" r="3" /><path d="M21 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 4.13a4 4 0 0 1 0 7.75" /></svg>',
  [TournamentType.TeamRoundRobin]: '<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 19a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4" /><circle cx="8" cy="9" r="3" /><path d="M14 7h6" /><path d="M17 4l3 3-3 3" /><path d="M20 17h-6" /><path d="M17 14l-3 3 3 3" /></svg>',
};

const tournamentType = type ?? TournamentType.Swiss;
const tournamentIcon = TOURNAMENT_ICONS[tournamentType];
---

<a class="tournament-card" href={href}>
  <span
    class="card-icon"
    data-tournament-type={tournamentType}
    aria-hidden="true"
    set:html={tournamentIcon}
  />
  <span class="card-body">
    <span class="card-name">{name}</span>
    {(date || location || playerCount) && (
      <span class="card-meta">
        {date && (
          <span class="card-meta-item">
            <svg class="meta-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" />
            </svg>
            {date}
          </span>
        )}
        {playerCount && playerCount > 0 && (
          <span class="card-meta-item">
            <svg class="meta-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="3" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
            {playerCount} players
          </span>
        )}
        {location && (
          <span class="card-meta-item">
            <svg class="meta-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" />
            </svg>
            {location}
          </span>
        )}
      </span>
    )}
  </span>
</a>

<style>
  .tournament-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--surface-container-high);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--on-surface);
    transition: background var(--duration-fast) var(--ease-out);
  }

  .tournament-card:hover {
    background: var(--surface-container-highest);
  }

  .tournament-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--space-12);
    height: var(--space-12);
    flex-shrink: 0;
    border-radius: var(--radius-md);
    background: var(--surface-container-highest);
    color: var(--primary-container);
  }

  .card-icon[data-tournament-type="swiss"] {
    color: var(--primary-container);
  }

  .card-icon[data-tournament-type="round-robin"] {
    color: var(--primary-fixed-dim);
  }

  .card-icon[data-tournament-type="team-swiss"] {
    color: var(--secondary-fixed-dim);
  }

  .card-icon[data-tournament-type="team-round-robin"] {
    color: var(--tertiary-fixed-dim);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }

  .card-name {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    color: var(--on-surface);
    overflow-wrap: anywhere;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .card-meta-item {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    color: var(--text-dim);
  }

  .meta-icon {
    flex-shrink: 0;
    color: var(--text-muted);
  }
</style>
