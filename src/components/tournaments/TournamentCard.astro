---
import { TournamentType } from "../../lib/types";
import type { IconName } from "../../lib/ui/icons";
import Icon from "../app/Icon.astro";

interface Props {
  name: string;
  href: string;
  date?: string;
  location?: string;
  type?: TournamentType;
  playerCount?: number;
}

const { name, href, date, location, type, playerCount } = Astro.props;

const TOURNAMENT_TYPE_ICONS: Record<TournamentType, IconName> = {
  [TournamentType.Swiss]: "swiss",
  [TournamentType.RoundRobin]: "round-robin",
  [TournamentType.TeamSwiss]: "team-swiss",
  [TournamentType.TeamRoundRobin]: "team-round-robin",
};

const tournamentType = type ?? TournamentType.Swiss;
const iconName = TOURNAMENT_TYPE_ICONS[tournamentType];
---

<a class="tournament-card" href={href}>
  <span
    class="card-icon"
    data-tournament-type={tournamentType}
    aria-hidden="true"
  >
    <Icon name={iconName} size={24} />
  </span>
  <span class="card-body">
    <span class="card-name">{name}</span>
    {(date || location || playerCount) && (
      <span class="card-meta">
        {date && (
          <span class="card-meta-item">
            <Icon name="calendar" size={14} class="meta-icon" />
            {date}
          </span>
        )}
        {playerCount && playerCount > 0 && (
          <span class="card-meta-item">
            <Icon name="users" size={14} class="meta-icon" />
            {playerCount} players
          </span>
        )}
        {location && (
          <span class="card-meta-item">
            <Icon name="map-pin" size={14} class="meta-icon" />
            {location}
          </span>
        )}
      </span>
    )}
  </span>
</a>

<style>
  .tournament-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--surface-container-high);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--on-surface);
    transition: background var(--duration-fast) var(--ease-out);
  }

  .tournament-card:hover {
    background: var(--surface-container-highest);
  }

  .tournament-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--space-12);
    height: var(--space-12);
    flex-shrink: 0;
    border-radius: var(--radius-md);
    background: var(--surface-container-highest);
    color: var(--primary-container);
  }

  .card-icon[data-tournament-type="swiss"] {
    color: var(--primary-container);
  }

  .card-icon[data-tournament-type="round-robin"] {
    color: var(--primary-fixed-dim);
  }

  .card-icon[data-tournament-type="team-swiss"] {
    color: var(--secondary-fixed-dim);
  }

  .card-icon[data-tournament-type="team-round-robin"] {
    color: var(--tertiary-fixed-dim);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }

  .card-name {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    color: var(--on-surface);
    overflow-wrap: anywhere;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .card-meta-item {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    color: var(--text-dim);
  }

  .meta-icon {
    flex-shrink: 0;
    color: var(--text-muted);
  }
</style>
