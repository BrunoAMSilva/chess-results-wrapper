---
import type { Standing } from "../lib/scraper";
import { reverseName } from "../lib/utils";
import { useTranslations } from "../i18n/ui";
import TieBreaks from "./TieBreaks.astro";

interface Props {
  standing: Standing;
  index: number;
  lang: number;
  tid?: string;
}

const { standing, index, lang, tid } = Astro.props;
const t = useTranslations(lang);

const isTop3 = standing.rank <= 3;
const rankClass = standing.rank <= 3 ? `rank-${standing.rank}` : "";
const Tag = tid ? "a" : "div";
const delayStep = Math.max(0, Math.min(10, index));
const delayClass = `delay-${delayStep}`;
const attributes = tid
  ? {
      href: `/player?tid=${encodeURIComponent(tid)}&name=${encodeURIComponent(standing.name)}&lang=${lang}`,
    }
  : {};
---

<Tag
  {...attributes}
  class:list={["standing-row", delayClass, { "top-3": isTop3 }, rankClass]}
>
  <div class="rank-col">
    <span class="rank-num">{standing.rank}</span>
  </div>

  <div class="player-info">
    <span class="player-name">{reverseName(standing.name)}</span>
    <span class="player-fed">
      {standing.fed}
      {
        standing.rating && standing.rating !== "0" && (
          <Fragment> • {standing.rating}</Fragment>
        )
      }
      {standing.club && <Fragment> • {standing.club}</Fragment>}
    </span>
  </div>
  <div class="main-stat">
    <span class="points">{standing.points}</span>
    <span class="stat-label">{t("standings.pts")}</span>
  </div>

  <div class="stats-col">
    <TieBreaks
      values={[
        standing.tieBreak1,
        standing.tieBreak2,
        standing.tieBreak3,
        standing.tieBreak4,
        standing.tieBreak5,
        standing.tieBreak6,
      ]}
    />
  </div>
</Tag>

<style>
  .standing-row {
    --hover-opacity: 0;
    display: grid;
    grid-template-columns: var(--size-standing-rank-col-sm) minmax(0, 1fr) auto;
    align-items: center;
    background:
      linear-gradient(
        90deg,
        rgb(from var(--text-muted) r g b / 0),
        rgb(from var(--text-muted) r g b / var(--hover-opacity))
      ),
      linear-gradient(var(--surface), var(--surface));
    padding: 0 var(--space-2) 0 0;
    animation: fadeInUp var(--duration-slow) ease both;
    color: var(--text);
    gap: 0;
    flex: 1;
    min-height: var(--size-standing-row-min-height-sm);
  }

  .standing-row:last-child {
  }

  .standing-row.top-3 {
    background: linear-gradient(
      90deg,
      var(--accent-subtle) 0%,
      oklch(from var(--accent) l c h / var(--hover-opacity)) 100%
    );
    border-left: var(--space-1) solid var(--accent);
  }

  .standing-row.rank-1 {
    border-left-color: var(--medal-gold);
    background: linear-gradient(
      90deg,
      rgb(from var(--medal-gold) r g b / 0.15) 0%,
      oklch(from var(--accent) l c h / var(--hover-opacity)) 100%
    );
  }

  .standing-row.rank-2 {
    border-left-color: var(--medal-silver);
    background: linear-gradient(
      90deg,
      rgb(from var(--medal-silver) r g b / 0.15) 0%,
      rgb(from var(--medal-silver) r g b / var(--hover-opacity)) 100%
    );
  }

  .standing-row.rank-3 {
    border-left-color: var(--medal-bronze);
    background: linear-gradient(
      90deg,
      rgb(from var(--medal-bronze) r g b / 0.15) 0%,
      rgb(from var(--medal-bronze) r g b / var(--hover-opacity)) 100%
    );
  }

  .rank-col {
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: var(--text-2xl);
    font-weight: 900;
    font-family: var(--font-display);
    color: var(--text-dim);
    line-height: 1;
    grid-row: span 2;
  }

  .rank-1 .rank-col {
    color: var(--medal-gold);
  }

  .rank-2 .rank-col {
    color: var(--medal-silver);
  }

  .rank-3 .rank-col {
    color: var(--medal-bronze);
  }

  .rank-1 .points {
    color: var(--medal-gold);
  }

  .rank-2 .points {
    color: var(--medal-silver);
  }

  .rank-3 .points {
    color: var(--medal-bronze);
  }


  .player-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    min-width: 0;
    padding-block: var(--space-3) var(--space-2);
  }

  .player-name {
    font-size: var(--text-lg);
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--text);
    line-height: 1.1;
    margin-bottom: var(--space-1);
    text-decoration: none;
    display: block;
  }

  .player-name:active {
    opacity: 0.7;
  }

  .player-fed {
    font-size: 0.75rem;
    color: var(--text-dim);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: none;
  }

  .stats-col {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: var(--space-2);
    padding-right: var(--space-2);
    height: 100%;
  }

  .main-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: var(--size-standing-main-stat-sm);
    background: var(--surface-container-low);
    margin-right: 0;
    height: 100%;
    border-radius: 0;
    flex-shrink: 0;
    padding: var(--space-2) 0;
    grid-row: span 2;
  }

  .points {
    font-size: var(--text-2xl);
    font-weight: 800;

    color: var(--text);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .accent-text {
    color: var(--accent-text);
  }

  .stat-label {
    font-size: var(--text-2xs);
    font-weight: 700;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-top: var(--space-1);
  }

  .stats-col {
    grid-row: 2;
    grid-column: 2;
    font-size: 0.55rem;
    margin-block-end: var(--space-3);
  }


  @media (min-width: 1068px) {
    .standing-row {
      grid-template-columns: var(--size-standing-rank-col-lg) minmax(0, 1fr) auto auto;
      grid-template-rows: auto;
      padding: 0 var(--space-6) 0 0;
      min-height: var(--size-standing-row-min-height-lg);
    }
    .main-stat, .rank-col {
      grid-row: 1;
    }
    .rank-col,
    .points {
      font-size: var(--text-display-md);
    }
    .player-name {
      font-size: var(--text-display-sm);
    }
    .player-fed {
      font-size: 0.9rem;
    }
    .player-info {
      padding-left: var(--space-6);
    }
    .stats-col {
      gap: 1.5rem;
      grid-row: 1;
      grid-column: 4;
      font-size: .9rem;
      margin: 0;
    }
    .main-stat {
      width: var(--size-standing-main-stat-lg);
      margin-right: var(--space-2);
      padding: var(--space-4) 0;
      grid-column: 3;
    }
  }

  @media (hover: hover) {
    .standing-row:hover {
      --hover-opacity: 0.5;
    }
  }

  .delay-0 { animation-delay: 0ms; }
  .delay-1 { animation-delay: 40ms; }
  .delay-2 { animation-delay: 80ms; }
  .delay-3 { animation-delay: 120ms; }
  .delay-4 { animation-delay: 160ms; }
  .delay-5 { animation-delay: 200ms; }
  .delay-6 { animation-delay: 240ms; }
  .delay-7 { animation-delay: 280ms; }
  .delay-8 { animation-delay: 320ms; }
  .delay-9 { animation-delay: 360ms; }
  .delay-10 { animation-delay: 400ms; }
</style>
