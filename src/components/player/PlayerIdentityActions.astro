---
import ActionButton from "../controls/ActionButton.astro";
import { useTranslations } from "../../i18n/ui";

interface Props {
  playerName: string;
  federation?: string;
  lang: number;
}

const { playerName, federation = "", lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  class="identity-actions"
  data-selected-player-control
  data-player-name={playerName}
  data-player-federation={federation}
  aria-label={t("player.identity.region")}
>
  <p
    class="identity-copy"
    data-selected-player-status
    data-selected-label={t("player.identity.selected")}
    data-idle-label={t("player.identity.idle")}
  >
    {t("player.identity.idle")}
  </p>

  <div class="identity-actions-row">
    <ActionButton
      variant="primary"
      size="compact"
      class="identity-button"
      data-selected-player-set
      ariaLabel={t("player.identity.set")}
    >
      {t("player.identity.set")}
    </ActionButton>

    <ActionButton
      variant="secondary"
      size="compact"
      class="identity-button"
      data-selected-player-clear
      ariaLabel={t("player.identity.clear")}
      hidden
    >
      {t("player.identity.clear")}
    </ActionButton>
  </div>
</section>

<style is:global>
  .identity-actions {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .identity-copy {
    margin: 0;
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    flex: 1;
    min-width: 0;
  }

  .identity-actions.is-selected-player-control .identity-copy {
    display: none;
  }

  .identity-actions-row {
    display: flex;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .identity-button[hidden] {
    display: none !important;
  }
</style>