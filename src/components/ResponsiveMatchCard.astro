---
import type { Pairing } from "../lib/types";
import { reverseName } from "../lib/utils";
import { useTranslations } from "../i18n/ui";

interface Props {
  match: Pairing;
  delay?: number;
  tid?: string;
  lang?: number;
}

const { match, delay = 0, tid, lang = 1 } = Astro.props;
const t = useTranslations(lang);

// Process the match.result (e.g., '1 - 0', '0 - 1', '½ - ½')
let whiteScoreText = "-";
let blackScoreText = "-";
let whiteWins = false;
let blackWins = false;
let whiteScoreClass = "score-neutral";
let blackScoreClass = "score-neutral";

if (match.result) {
  const normalize = match.result.replace(/\s+/g, "");
  if (normalize.includes("1-0") || normalize.includes("1:0")) {
    whiteScoreText = "1";
    blackScoreText = "0";
    whiteScoreClass = "score-win";
    blackScoreClass = "score-loss";
    whiteWins = true;
  } else if (normalize.includes("0-1") || normalize.includes("0:1")) {
    whiteScoreText = "0";
    blackScoreText = "1";
    whiteScoreClass = "score-loss";
    blackScoreClass = "score-win";
    blackWins = true;
  } else if (
    normalize.includes("½") ||
    normalize.includes("1/2") ||
    normalize.includes("0.5")
  ) {
    whiteScoreText = "½";
    blackScoreText = "½";
    whiteScoreClass = "score-draw";
    blackScoreClass = "score-draw";
  } else {
    // Other results like empty string
  }
}

const normalizedResult = match.result.trim();
const isBye = !match.black && (/bye|spielfrei/i.test(match.unpairedLabel || "") || normalizedResult === "1");
const unpairedLabel = !match.black
  ? (match.unpairedLabel?.trim() || (normalizedResult === "1" ? "BYE" : t("match.notPaired")))
  : "";
const wName = match.white ? match.white.name : "---";
const bName = match.black ? match.black.name : "---";
const delayStep = Math.max(0, Math.min(10, Math.round(delay / 40)));
const delayClass = `delay-${delayStep}`;
---

<div class:list={["match-card", "animate-enter", delayClass]}>
  <div class="board-number-column">
    <div class="board-number">{match.table}</div>
  </div>

  <div class="players-column">
    {
      tid ? (
        <a
          href={`/player?tid=${encodeURIComponent(tid)}&name=${encodeURIComponent(match.white?.name || "")}&lang=${lang}`}
          class={`player-row white-player ${whiteWins ? "winner-row" : ""}`}
        >
          <div class="player-info">
            <span class="piece-icon white-piece" />
            <div class="name-wrapper">
              <span class="player-name">{reverseName(wName)}</span>
            </div>
          </div>
          <div class:list={["player-score", whiteScoreClass]}>
            {whiteScoreText}
          </div>
        </a>
      ) : (
        <div class={`player-row white-player ${whiteWins ? "winner-row" : ""}`}>
          <div class="player-info">
            <span class="piece-icon white-piece" />
            <div class="name-wrapper">
              <span class="player-name">{reverseName(wName)}</span>
            </div>
          </div>
          <div class:list={["player-score", whiteScoreClass]}>
            {whiteScoreText}
          </div>
        </div>
      )
    }

    <div class="score-divider"></div>

    {
      tid ? (
        <a
          href={`/player?tid=${encodeURIComponent(tid)}&name=${encodeURIComponent(match.black?.name || "")}&lang=${lang}`}
          class={`player-row black-player ${blackWins ? "winner-row" : ""}`}
        >
          <div class="player-info">
            <span class="piece-icon black-piece" />
            <div class="name-wrapper">
              {isBye ? (
                <span class="player-name bye-text">BYE</span>
              ) : !match.black ? (
                <span class="player-name bye-text">{unpairedLabel}</span>
              ) : (
                <span class="player-name">{reverseName(bName)}</span>
              )}
            </div>
          </div>
          <div class:list={["player-score", blackScoreClass]}>
            {blackScoreText}
          </div>
        </a>
      ) : (
        <div class={`player-row black-player ${blackWins ? "winner-row" : ""}`}>
          <div class="player-info">
            <span class="piece-icon black-piece" />
            <div class="name-wrapper">
              {isBye ? (
                <span class="player-name bye-text">BYE</span>
              ) : !match.black ? (
                <span class="player-name bye-text">{unpairedLabel}</span>
              ) : (
                <span class="player-name">{reverseName(bName)}</span>
              )}
            </div>
          </div>
          <div class:list={["player-score", blackScoreClass]}>
            {blackScoreText}
          </div>
        </div>
      )
    }
  </div>

  <style>
    .match-card {
      display: flex;
      background: var(--surface);
      border-radius: var(--radius-xl);
      overflow: hidden;
      box-shadow: var(--shadow-card);
      margin-bottom: 0px;
      transition:
        transform var(--duration-normal) var(--ease-out),
        box-shadow var(--duration-normal) var(--ease-out),
        border-color var(--duration-fast) ease;
    }

    .board-number-column {
      display: flex;
      align-items: center;
      justify-content: center;
      width: var(--space-12);
      background: linear-gradient(
        180deg,
        var(--surface-container-low),
        transparent
      );
      position: relative;
      overflow: hidden;
      flex-shrink: 0;
    }

    .board-number {
      font-size: var(--text-xl);
      font-weight: var(--weight-medium);
      font-family: var(--font-display);
      color: var(--text-dim);
      opacity: 1;
    }

    .players-column {
      min-width: 0;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .player-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--space-2) var(--space-3);
      min-height: var(--size-match-row-min-height);
      transition: background-color var(--duration-fast) var(--ease-in-out);
    }

    .player-row:first-child {
      background: var(--surface-container-low);
    }

    .winner-row .player-name,
    .winner-row .player-score {
      color: var(--accent-text);
    }

    .winner-row.player-row {
      background: linear-gradient(90deg, var(--accent-subtle), transparent 65%);
    }

    .player-row:hover {
      background-color: var(--surface-container-low);
    }

    .score-divider {
      height: 1px;
      background: linear-gradient(
        90deg,
        transparent,
        var(--border-light) 10%,
        var(--border-light) 90%,
        transparent
      );
      margin: 0;
    }

    .player-info {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      flex: 1;
      min-width: 0;
      overflow: hidden;
    }

    .piece-icon {
      width: var(--size-icon-sm);
      height: var(--size-icon-sm);
      border-radius: 50%;
      flex-shrink: 0;
    }

    .white-piece {
      background: linear-gradient(135deg, var(--white-piece) 0%, var(--neutral-200) 100%);
    }

    .black-piece {
      background: linear-gradient(135deg, var(--black-piece) 0%, var(--neutral-800) 100%);
    }

    .name-wrapper {
      display: flex;
      flex-direction: column;
      min-width: 0;
    }

    .player-name {
      display: block;
      font-size: var(--text-sm);
      font-weight: var(--weight-medium);
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      letter-spacing: -0.01em;
      text-decoration: none;
    }

    a.player-name:active {
      opacity: 0.7;
    }

    .bye-text {
      color: var(--text-dim);
      font-style: italic;
      opacity: 0.7;
    }

    .player-score {
      font-size: var(--text-base);
      font-weight: var(--weight-bold);
      padding-left: var(--space-2);
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
      flex-shrink: 0;
    }

    .player-score.score-win {
      color: var(--win);
    }

    .player-score.score-loss {
      color: var(--loss);
    }

    .player-score.score-draw {
      color: var(--draw);
    }

    .player-score.score-neutral {
      color: var(--text-dim);
    }

    .delay-0 { animation-delay: 0ms; }
    .delay-1 { animation-delay: 40ms; }
    .delay-2 { animation-delay: 80ms; }
    .delay-3 { animation-delay: 120ms; }
    .delay-4 { animation-delay: 160ms; }
    .delay-5 { animation-delay: 200ms; }
    .delay-6 { animation-delay: 240ms; }
    .delay-7 { animation-delay: 280ms; }
    .delay-8 { animation-delay: 320ms; }
    .delay-9 { animation-delay: 360ms; }
    .delay-10 { animation-delay: 400ms; }
  </style>
</div>
