---
import type { LinkedTournament } from "../lib/types";
import SegmentedControl from "./SegmentedControl.astro";

interface Props {
  currentId: string;
  currentLabel: string;
  linkedTournaments: LinkedTournament[];
  lang: number;
}

const { currentId, currentLabel, linkedTournaments, lang } = Astro.props;
const currentPath = Astro.url.pathname;

const allTournaments = [
  { id: currentId, name: currentLabel },
  ...linkedTournaments,
].sort((a, b) => a.name.localeCompare(b.name));

const segments = allTournaments.map((t) => ({
  value: t.id,
  label: t.name,
  href: t.id === currentId ? undefined : `${currentPath}?tid=${t.id}&lang=${lang}`,
}));
---

<div class="tournament-selector-wrapper">
  <div class="tournament-selector-scroll">
    <SegmentedControl
      name="tournament"
      segments={segments}
      active={currentId}
    />
  </div>
</div>

<style>
  .tournament-selector-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-4);
    padding: 0 var(--space-4);
  }

  .tournament-selector-scroll {
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--border-light) transparent;
  }

  .tournament-selector-scroll::-webkit-scrollbar {
    height: 6px;
  }

  .tournament-selector-scroll::-webkit-scrollbar-track {
    background: transparent;
  }

  .tournament-selector-scroll::-webkit-scrollbar-thumb {
    background: var(--border-light);
    border-radius: var(--radius-full);
  }

  .tournament-selector-wrapper :global(.seg-control) {
    width: max-content;
    max-width: none;
  }

  .tournament-selector-wrapper :global(.seg-item) {
    flex: 0 0 auto;
  }
</style>
