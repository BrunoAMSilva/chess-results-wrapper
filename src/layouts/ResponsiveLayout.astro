---
import { languages, useTranslations } from "../i18n/ui";
import BaseHead from "../components/app/BaseHead.astro";
import DesktopSidebarNav from "../components/app/DesktopSidebarNav.astro";
import Icon from "../components/app/Icon.astro";
import type { IconName } from "../lib/ui/icons";
import "../styles/global.css";

interface Props {
  title: string;
  eyebrow?: string;
  lang?: number;
  navMode?: "default" | "referee" | "none";
}

interface DesktopSidebarItem {
  href?: string;
  label: string;
  icon: IconName;
  active?: boolean;
  hidden?: boolean;
  profileNav?: boolean;
}

const { title, eyebrow, lang = 1, navMode = "default" } = Astro.props;
const t = useTranslations(lang);
const langCode = languages[lang as keyof typeof languages] || "en";
const documentTitle = eyebrow ? `${eyebrow} - ${title} | ViteChess` : `${title} | ViteChess`;
const currentPath = Astro.url.pathname;
const authUser = Astro.locals.user;
let tid = Astro.url.searchParams.get("tid") || "";
// Extract tournament id from any /referee/[id]/* path
const refereeIdMatch = currentPath.match(/^\/referee\/([^\/]+)/);
const refereeTid = refereeIdMatch ? refereeIdMatch[1] : "";
if (refereeTid) tid = refereeTid;
const isPairings = currentPath === "/pairings" || currentPath === "/present";
const isStandings = currentPath === "/standings";
const isSearch = currentPath === "/" || currentPath === "/discover";
const isProfile = currentPath === "/player-profile";
const isOptions = currentPath === "/options";
const isReferee = currentPath.startsWith("/referee") || navMode === "referee";
const isRefereeResults = /^\/referee\/[^\/]+\/results$/.test(currentPath);
const isRefereeSettings = /^\/referee\/[^\/]+\/settings$/.test(currentPath);
const isRefereePlayers = /^\/referee\/[^\/]+\/players$/.test(currentPath);
const isRefereeTables = !!refereeTid && !isRefereeResults && !isRefereeSettings && !isRefereePlayers && !isOptions;

// Contextual back URL for referee pages: go one path level up
const round = Astro.url.searchParams.get("round");
let refereeBackUrl = `/referee?lang=${lang}`;
if (isReferee && refereeTid) {
  const segments = currentPath.split('/').filter(Boolean);
  if (segments.length > 2) {
    const parentPath = '/' + segments.slice(0, -1).join('/');
    const params = [`lang=${lang}`];
    if (round) params.push(`round=${round}`);
    refereeBackUrl = `${parentPath}?${params.join('&')}`;
  }
}
if (isOptions && navMode === "referee" && tid) {
  const params = [`lang=${lang}`];
  if (round) params.push(`round=${round}`);
  refereeBackUrl = `/referee/${tid}?${params.join('&')}`;
}

const defaultSidebarItems: DesktopSidebarItem[] = [
  {
    href: `/?lang=${lang}`,
    label: t('nav.search'),
    icon: "search",
    active: isSearch,
  },
  {
    href: `/pairings?tid=${tid}&lang=${lang}`,
    label: t('nav.pairings'),
    icon: "table",
    active: isPairings,
  },
  {
    href: `/standings?tid=${tid}&lang=${lang}`,
    label: t('nav.standings'),
    icon: "bar-chart",
    active: isStandings,
  },
  {
    href: `/options?tid=${tid}&lang=${lang}`,
    label: t('nav.settings'),
    icon: "settings",
    active: isOptions,
  },
  {
    label: t('nav.profile'),
    icon: "user",
    active: isProfile,
    hidden: true,
    profileNav: true,
  },
];

const refereeSidebarItems: DesktopSidebarItem[] = [
  {
    href: refereeTid ? refereeBackUrl : `/referee?lang=${lang}`,
    label: refereeTid ? t('referee.back') : t('nav.search'),
    icon: refereeTid ? "arrow-left" : "search",
  },
  {
    href: tid ? `/referee/${tid}?lang=${lang}` : `/referee?lang=${lang}`,
    label: t('referee.tables'),
    icon: "table",
    active: isRefereeTables,
  },
  {
    href: tid ? `/referee/${tid}/results?lang=${lang}` : `/referee?lang=${lang}`,
    label: t('referee.results'),
    icon: "file-text",
    active: isRefereeResults,
  },
  {
    href: tid ? `/referee/${tid}/players?lang=${lang}` : `/referee?lang=${lang}`,
    label: t('referee.players'),
    icon: "users",
    active: isRefereePlayers,
  },
  {
    href: tid ? `/referee/${tid}/settings?lang=${lang}` : `/referee?lang=${lang}`,
    label: t('referee.upload'),
    icon: "lock",
    active: isRefereeSettings,
  },
  {
    href: `/options?${tid ? `tid=${tid}&` : ''}lang=${lang}&mode=referee`,
    label: t('nav.settings'),
    icon: "settings",
    active: isOptions,
  },
];

const desktopSidebarItems = navMode === "referee" ? refereeSidebarItems : defaultSidebarItems;
const desktopSidebarActions: DesktopSidebarItem[] = navMode === "default" && tid
  ? [
      {
        href: `/present?tid=${tid}&lang=${lang}`,
        label: t('presenter.title'),
        icon: "monitor",
      },
    ]
  : [];
---

<!doctype html>
<html lang={langCode} data-app-lang={lang}>
  <head>
    <BaseHead title={documentTitle} manifest={navMode === "referee" || navMode === "none" ? "/referee-manifest.json" : "/manifest.json"} />
  </head>
  <body>
    <a class="skip-link" href="#maincontent">{t('a11y.skipToMain')}</a>
    <div class="app-shell" data-sidebar-shell data-sidebar-state="expanded">
      <div class="ambient ambient-a"></div>
      <div class="ambient ambient-b"></div>

      {navMode !== "none" && (
        <DesktopSidebarNav
          brand={t('site.title')}
          brandHref={navMode === "referee" ? (tid ? `/referee/${tid}?lang=${lang}` : `/referee?lang=${lang}`) : `/?lang=${lang}`}
          navLabel={t('sidebar.navigation')}
          collapseLabel={t('sidebar.collapse')}
          expandLabel={t('sidebar.expand')}
          items={desktopSidebarItems}
          footerActions={desktopSidebarActions}
        />
      )}

      <div class="app-stage">

      <header class="topbar" transition:name="topbar" transition:animate="none">
        {navMode !== "none" && (
          <a href={isReferee ? refereeBackUrl : `/?lang=${lang}`} class:list={["topbar-home", { "referee-back": isReferee && !!tid }]} aria-label={isReferee && tid ? t('referee.back') : t('nav.search')}>
            {isReferee && tid ? (
              <Icon name="arrow-left" size={20} />
            ) : (
              <Icon name="search" size={20} />
            )}
          </a>
        )}
        <div class="page-heading">
          {eyebrow && <p class="page-eyebrow">{eyebrow}</p>}
          <h1 class="page-title">{title}</h1>
        </div>
        {navMode === "default" && tid && (
          <a href={`/present?tid=${tid}&lang=${lang}`} class="presenter-link presenter-link--mobile" aria-label={t('presenter.title')} title={t('presenter.title')}>
            <Icon name="monitor" size={18} />
          </a>
        )}
        {authUser && (
          <div class="auth-badge">
            {authUser.picture ? (
              <img src={authUser.picture} alt="" class="auth-avatar" width="28" height="28" referrerpolicy="no-referrer" />
            ) : (
              <span class="auth-avatar-fallback" aria-hidden="true">
                <Icon name="user" size={16} />
              </span>
            )}
            <button class="auth-signout" type="button" data-auth-signout aria-label={t('auth.signOut')} title={t('auth.signOut')}>
              <Icon name="log-out" size={16} />
            </button>
          </div>
        )}
      </header>

      <main id="maincontent" class="mobile-main" tabindex="-1">
        <slot />
      </main>

      {navMode === "none" ? null : navMode === "referee" ? (
        <nav class="mobile-nav referee-nav" transition:name="mobile-nav" transition:animate="none">
          <a
            href={tid ? `/referee/${tid}?lang=${lang}` : `/referee?lang=${lang}`}
            class:list={["nav-item", { active: isRefereeTables }]}
            aria-current={isRefereeTables ? "page" : undefined}
          >
            <Icon name="table" size={22} />
            <span>{t('referee.tables')}</span>
          </a>
          <a
            href={tid ? `/referee/${tid}/results?lang=${lang}` : `/referee?lang=${lang}`}
            class:list={["nav-item", { active: isRefereeResults }]}
            aria-current={isRefereeResults ? "page" : undefined}
          >
            <Icon name="file-text" size={22} />
            <span>{t('referee.results')}</span>
          </a>
          <a
            href={tid ? `/referee/${tid}/players?lang=${lang}` : `/referee?lang=${lang}`}
            class:list={["nav-item", { active: isRefereePlayers }]}
            aria-current={isRefereePlayers ? "page" : undefined}
          >
            <Icon name="users" size={22} />
            <span>{t('referee.players')}</span>
          </a>
          <a
            href={tid ? `/referee/${tid}/settings?lang=${lang}` : `/referee?lang=${lang}`}
            class:list={["nav-item", { active: isRefereeSettings }]}
            aria-current={isRefereeSettings ? "page" : undefined}
          >
            <Icon name="lock" size={22} />
            <span>{t('referee.upload')}</span>
          </a>
          <a
            href={`/options?${tid ? `tid=${tid}&` : ''}lang=${lang}&mode=referee`}
            class:list={["nav-item", { active: isOptions }]}
            aria-current={isOptions ? "page" : undefined}
          >
            <Icon name="settings" size={22} />
            <span>{t('nav.settings')}</span>
          </a>
        </nav>
      ) : (
        <nav class="mobile-nav" transition:name="mobile-nav" transition:animate="none">
          <a
            href={`/?lang=${lang}`}
            class:list={["nav-item", { active: isSearch }]}
            aria-current={isSearch ? "page" : undefined}
          >
            <Icon name="search" size={22} />
            <span>{t('nav.search')}</span>
          </a>
          <a
            href={`/pairings?tid=${tid}&lang=${lang}`}
            class:list={["nav-item", { active: isPairings }]}
            aria-current={isPairings ? "page" : undefined}
          >
            <Icon name="table" size={22} />
            <span>{t('nav.pairings')}</span>
          </a>
          <a
            href={`/standings?tid=${tid}&lang=${lang}`}
            class:list={["nav-item", { active: isStandings }]}
            aria-current={isStandings ? "page" : undefined}
          >
            <Icon name="bar-chart" size={22} />
            <span>{t('nav.standings')}</span>
          </a>
          <a
            href={`/options?tid=${tid}&lang=${lang}`}
            class:list={["nav-item", { active: isOptions }]}
            aria-current={isOptions ? "page" : undefined}
          >
            <Icon name="settings" size={22} />
            <span>{t('nav.settings')}</span>
          </a>
          <a
            hidden
            data-profile-nav
            class:list={["nav-item", { active: isProfile }]}
            aria-current={isProfile ? "page" : undefined}
          >
            <Icon name="user" size={22} />
            <span>{t('nav.profile')}</span>
          </a>
        </nav>
      )}
      </div>
    </div>
  </body>
</html>

<script>
  import { initSelectedPlayerUi } from "../scripts/player-identity";
  import { getFirebaseAnalytics } from "../lib/firebase-client";

  let firebaseAuthModulePromise: Promise<typeof import("../lib/firebase-auth-client")> | null = null;

  function loadFirebaseAuthModule() {
    if (!firebaseAuthModulePromise) {
      firebaseAuthModulePromise = import("../lib/firebase-auth-client");
    }

    return firebaseAuthModulePromise;
  }

  const pageLang = Number.parseInt(document.documentElement.dataset.appLang || "1", 10);
  initSelectedPlayerUi(Number.isFinite(pageLang) && pageLang > 0 ? pageLang : 1);

  getFirebaseAnalytics();

  // Auth sign-out handler
  document.querySelectorAll("[data-auth-signout]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      try {
        const response = await fetch("/api/auth", { method: "DELETE" });
        if (!response.ok) {
          throw new Error("Sign-out failed");
        }

        const { signOutFirebaseAuth } = await loadFirebaseAuthModule();
        await signOutFirebaseAuth();

        window.location.href = "/login";
      } catch (error) {
        console.error("[auth] Sign-out failed:", error);
      }
    });
  });
</script>

<style is:global>
  body {
    background:
      radial-gradient(
        900px 500px at -10% -20%,
        var(--ambient-a),
        transparent
      ),
      radial-gradient(
        700px 500px at 120% 120%,
        var(--ambient-b),
        transparent
      ),
      var(--bg);
    height: 100dvh;
    overflow: hidden;
  }

  .app-shell {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    position: relative;
  }

  .app-stage {
    display: flex;
    flex: 1;
    min-height: 0;
    min-width: 0;
    flex-direction: column;
  }

  .ambient {
    position: fixed;
    pointer-events: none;
    border-radius: 999px;
    filter: blur(80px);
    opacity: 0.35;
    z-index: 0;
  }

  .ambient-a {
    width: 420px;
    height: 420px;
    left: -120px;
    top: -140px;
    background: var(--ambient-a);
  }

  .ambient-b {
    width: 380px;
    height: 380px;
    right: -80px;
    bottom: -140px;
    background: var(--ambient-b);
  }

  .topbar {
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0 1rem;
    padding-top: env(safe-area-inset-top, 0px);
    position: sticky;
    top: 0;
    z-index: 5;
  }

  .topbar-home {
    display: none;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    text-decoration: none;
    padding: var(--space-2);
    border-radius: var(--radius-md);
    transition: color var(--duration-fast) var(--ease-in-out),
                background var(--duration-fast) var(--ease-in-out);
  }

  .topbar-home.referee-back {
    display: inline-flex;
  }

  .topbar-home:hover {
    color: var(--accent-text);
    background: var(--accent-subtle);
  }

  .presenter-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    text-decoration: none;
    padding: var(--space-2);
    border-radius: var(--radius-md);
    margin-left: var(--space-3);
    transition: color var(--duration-fast) var(--ease-in-out),
                background var(--duration-fast) var(--ease-in-out);
  }

  .presenter-link:hover {
    color: var(--accent-text);
    background: var(--accent-subtle);
  }

  .presenter-link--mobile {
    display: inline-flex;
  }

  .page-heading {
    display: flex;
    flex: 1;
    flex-direction: column;
    align-items: flex-start;
    min-width: 0;
    gap: var(--space-1);
    text-align: left;
  }

  .page-eyebrow {
    max-width: 100%;
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin: 0;
  }

  .page-title {
    display: block;
    font-size: var(--text-lg);
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--text);
    min-width: 0;
    max-width: 100%;
    margin: 0;
  }

  .topbar-right {
    display: none;
    align-items: center;
    gap: 0.6rem;
  }

  .mobile-main {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    -webkit-overflow-scrolling: touch;
    position: relative;
    z-index: 2;
  }

  .mobile-nav {
    display: flex;
    background: var(--nav-bg);
    padding: 0.5rem 1rem;
    padding-bottom: max(0.5rem, env(safe-area-inset-bottom, 0px));
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    position: relative;
    z-index: 5;
  }

  .nav-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    color: var(--text-dim);
    text-decoration: none;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    transition: color var(--duration-fast) var(--ease-in-out);
  }

  .nav-item.active {
    color: var(--nav-active);
  }

  @media (min-width: 768px) {
    .app-shell {
      padding: 0.9rem;
      gap: 0;
    }

    .topbar {
      padding: 0 1.5rem;
      height: 68px;
    }

    .topbar-right,
    .topbar-search,
    .topbar-home {
      display: inline-flex;
    }

    .page-eyebrow {
      font-size: var(--text-sm);
      letter-spacing: 0.16em;
    }
    .mobile-main {
      padding: 1.4rem 1.5rem;
      border-top: none;
    }

    .mobile-nav {
      display: none;
    }

    .mobile-nav.referee-nav {
      display: flex;
    }
  }

  @media (min-width: 1024px) {
    .app-shell {
      flex-direction: row;
      gap: var(--space-4);
      align-items: stretch;
    }

    .topbar {
      padding-inline: var(--space-6);
    }

    .topbar-home,
    .topbar-home.referee-back,
    .presenter-link--mobile,
    .mobile-nav,
    .mobile-nav.referee-nav {
      display: none;
    }

    .mobile-main {
      padding-inline: var(--space-6);
    }
  }

  @media (min-width: 1200px) {
    .mobile-main {
      padding: 1.8rem 2rem;
    }

    .topbar {
      padding: 0 2rem;
    }

    .page-title {
      font-size: var(--text-2xl);
    }
  }

  /* Auth badge */
  .auth-badge {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .auth-avatar {
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full);
    border: 2px solid var(--border-strong);
    object-fit: cover;
  }

  .auth-avatar-fallback {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full);
    background: var(--surface-hover);
    border: 2px solid var(--border-strong);
    color: var(--text-dim);
  }

  .auth-signout {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-1);
    color: var(--text-dim);
    background: none;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-in-out),
                background var(--duration-fast) var(--ease-in-out);
  }
  .auth-signout:hover {
    color: var(--danger);
    background: rgba(239, 68, 68, 0.1);
  }
  .auth-signout:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
