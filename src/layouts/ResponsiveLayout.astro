---
import { languages, useTranslations } from "../i18n/ui";
import BaseHead from "../components/BaseHead.astro";
import "../styles/global.css";

interface Props {
  title: string;
  lang?: number;
  navMode?: "default" | "referee" | "none";
}

const { title, lang = 1, navMode = "default" } = Astro.props;
const t = useTranslations(lang);
const langCode = languages[lang as keyof typeof languages] || "en";
const currentPath = Astro.url.pathname;
let tid = Astro.url.searchParams.get("tid") || "";
const refereeMatch = currentPath.match(/^\/referee\/([^\/]+)\/(tables|results)$/);
const refereeTid = refereeMatch ? refereeMatch[1] : "";
if (refereeTid) tid = refereeTid;
const isPairings = currentPath === "/pairings" || currentPath === "/present";
const isStandings = currentPath === "/standings";
const isOptions = currentPath === "/options";
const isReferee = currentPath.startsWith("/referee");
const isRefereeTables = refereeMatch?.[2] === "tables";
const isRefereeResults = refereeMatch?.[2] === "results";
---

<!doctype html>
<html lang={langCode}>
  <head>
    <BaseHead title={title} manifest={navMode === "referee" || navMode === "none" ? "/referee-manifest.json" : "/manifest.json"} />
  </head>
  <body>
    <div class="app-shell">
      <div class="ambient ambient-a"></div>
      <div class="ambient ambient-b"></div>

      <header class="topbar" transition:name="topbar" transition:animate="none">
        <a href={isReferee ? `/referee?lang=${lang}` : `/?lang=${lang}`} class="topbar-home" aria-label={isReferee && tid ? t('referee.back') : 'Search'}>
          {isReferee && tid ? (
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
          ) : (
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          )}
        </a>
        <h1 class="page-title">{title}</h1>
        <div class="topbar-left">
          {navMode === "default" && (
            <nav class="desktop-nav" aria-label="Main" transition:name="desktop-nav" transition:animate="none">
              <a
                href={`/pairings?tid=${tid}&lang=${lang}`}
                class={`desktop-nav-item ${isPairings ? "active" : ""}`}
                >{t('nav.pairings')}</a
              >
              <a
                href={`/standings?tid=${tid}&lang=${lang}`}
                class={`desktop-nav-item ${isStandings ? "active" : ""}`}
                >{t('nav.standings')}</a
              >
              <a
                href={`/options?tid=${tid}&lang=${lang}`}
                class={`desktop-nav-item ${isOptions ? "active" : ""}`}
                >{t('nav.settings')}</a
              >
            </nav>
          )}
          {navMode === "default" && tid && (
            <a href={`/present?tid=${tid}&lang=${lang}`} class="presenter-link" aria-label={t('presenter.title')} title={t('presenter.title')}>
              <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                <line x1="8" y1="21" x2="16" y2="21"></line>
                <line x1="12" y1="17" x2="12" y2="21"></line>
              </svg>
            </a>
          )}
        </div>
      </header>

      <main class="mobile-main">
        <slot />
      </main>

      {navMode === "none" ? null : navMode === "referee" ? (
        <nav class="mobile-nav" transition:name="mobile-nav" transition:animate="none">
          <a
            href={tid ? `/referee/${tid}/tables?lang=${lang}` : `/referee?lang=${lang}`}
            class={`nav-item ${isRefereeTables ? "active" : ""}`}
          >
            <svg
              viewBox="0 0 24 24"
              width="22"
              height="22"
              stroke="currentColor"
              stroke-width="2"
              fill="none"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="3" y1="9" x2="21" y2="9"></line>
              <line x1="9" y1="21" x2="9" y2="9"></line>
            </svg>
            <span>{t('referee.tables')}</span>
          </a>
          <a
            href={tid ? `/referee/${tid}/results?lang=${lang}` : `/referee?lang=${lang}`}
            class={`nav-item ${isRefereeResults ? "active" : ""}`}
          >
            <svg
              viewBox="0 0 24 24"
              width="22"
              height="22"
              stroke="currentColor"
              stroke-width="2"
              fill="none"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
            <span>{t('referee.results')}</span>
          </a>
          <a
            href={`/options?${tid ? `tid=${tid}&` : ''}lang=${lang}&mode=referee`}
            class={`nav-item ${isOptions ? "active" : ""}`}
          >
            <svg
              viewBox="0 0 24 24"
              width="22"
              height="22"
              stroke="currentColor"
              stroke-width="2"
              fill="none"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="3"></circle>
              <path
                d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"
              ></path>
            </svg>
            <span>{t('nav.settings')}</span>
          </a>
        </nav>
      ) : (
        <nav class="mobile-nav" transition:name="mobile-nav" transition:animate="none">
          <a
            href={`/?lang=${lang}`}
            class="nav-item"
          >
            <svg
              viewBox="0 0 24 24"
              width="22"
              height="22"
              stroke="currentColor"
              stroke-width="2"
              fill="none"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <span>{t('nav.search')}</span>
          </a>
          <a
            href={`/pairings?tid=${tid}&lang=${lang}`}
            class={`nav-item ${isPairings ? "active" : ""}`}
          >
            <svg
              viewBox="0 0 24 24"
              width="22"
              height="22"
              stroke="currentColor"
              stroke-width="2"
              fill="none"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="3" y1="9" x2="21" y2="9"></line>
              <line x1="9" y1="21" x2="9" y2="9"></line>
            </svg>
            <span>{t('nav.pairings')}</span>
          </a>
          <a
            href={`/standings?tid=${tid}&lang=${lang}`}
            class={`nav-item ${isStandings ? "active" : ""}`}
          >
            <svg
              viewBox="0 0 24 24"
              width="22"
              height="22"
              stroke="currentColor"
              stroke-width="2"
              fill="none"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="18" y1="20" x2="18" y2="10"></line>
              <line x1="12" y1="20" x2="12" y2="4"></line>
              <line x1="6" y1="20" x2="6" y2="14"></line>
            </svg>
            <span>{t('nav.standings')}</span>
          </a>
          <a
            href={`/options?tid=${tid}&lang=${lang}`}
            class={`nav-item ${isOptions ? "active" : ""}`}
          >
            <svg
              viewBox="0 0 24 24"
              width="22"
              height="22"
              stroke="currentColor"
              stroke-width="2"
              fill="none"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="3"></circle>
              <path
                d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"
              ></path>
            </svg>
            <span>{t('nav.settings')}</span>
          </a>
        </nav>
      )}
    </div>
  </body>
</html>

<style is:global>
  body {
    background:
      radial-gradient(
        900px 500px at -10% -20%,
        var(--ambient-a),
        transparent
      ),
      radial-gradient(
        700px 500px at 120% 120%,
        var(--ambient-b),
        transparent
      ),
      var(--bg);
    height: 100dvh;
    overflow: hidden;
  }

  .app-shell {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    position: relative;
  }

  .ambient {
    position: fixed;
    pointer-events: none;
    border-radius: 999px;
    filter: blur(80px);
    opacity: 0.35;
    z-index: 0;
  }

  .ambient-a {
    width: 420px;
    height: 420px;
    left: -120px;
    top: -140px;
    background: var(--ambient-a);
  }

  .ambient-b {
    width: 380px;
    height: 380px;
    right: -80px;
    bottom: -140px;
    background: var(--ambient-b);
  }

  .topbar {
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0 1rem;
    padding-top: env(safe-area-inset-top, 0px);
    position: sticky;
    top: 0;
    z-index: 5;
  }

  .topbar-left {
    display: flex;
    align-items: center;
    min-width: 0;
  }

  .desktop-nav {
    display: none;
    align-items: center;
    gap: 0.45rem;
    margin-left: 1rem;
    padding: 0.28rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--seg-bg);
  }

  .desktop-nav-item {
    text-decoration: none;
    color: var(--text-dim);
    padding: 0.45rem 0.78rem;
    border-radius: calc(var(--radius-lg) - 3px);
    border: 1px solid transparent;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    transition:
      background var(--duration-fast) var(--ease-in-out),
      border-color var(--duration-fast) var(--ease-in-out),
      color var(--duration-fast) var(--ease-in-out);
  }

  .desktop-nav-item:hover {
    background: var(--surface-hover);
    color: var(--text);
  }

  .desktop-nav-item.active {
    color: var(--seg-active-text);
    border-color: var(--seg-active-border);
    background: var(--seg-active-bg);
  }

  .topbar-home {
    display: none;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    text-decoration: none;
    padding: var(--space-2);
    border-radius: var(--radius-md);
    transition: color var(--duration-fast) var(--ease-in-out),
                background var(--duration-fast) var(--ease-in-out);
  }

  .topbar-home:hover {
    color: var(--accent-text);
    background: var(--accent-subtle);
  }

  .presenter-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    text-decoration: none;
    padding: var(--space-2);
    border-radius: var(--radius-md);
    margin-left: var(--space-3);
    transition: color var(--duration-fast) var(--ease-in-out),
                background var(--duration-fast) var(--ease-in-out);
  }

  .presenter-link:hover {
    color: var(--accent-text);
    background: var(--accent-subtle);
  }

  .page-title {
    display: block;
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--text);
    min-width: 0;
    flex: 1;
  }

  .topbar-right {
    display: none;
    align-items: center;
    gap: 0.6rem;
  }

  .mobile-main {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    -webkit-overflow-scrolling: touch;
    position: relative;
    z-index: 2;
  }

  .mobile-nav {
    display: flex;
    background: var(--nav-bg);
    border-top: 1px solid var(--border);
    padding: 0.5rem 1rem;
    padding-bottom: max(0.5rem, env(safe-area-inset-bottom, 0px));
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    position: relative;
    z-index: 5;
  }

  .nav-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    color: var(--text-dim);
    text-decoration: none;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    transition: color var(--duration-fast) var(--ease-in-out);
  }

  .nav-item.active {
    color: var(--nav-active);
  }

  @media (min-width: 768px) {
    .app-shell {
      padding: 0.9rem;
      gap: 0;
    }

    .topbar {
      padding: 0 1.5rem;
      height: 68px;
    }

    .desktop-nav,
    .topbar-right,
    .topbar-search,
    .topbar-home {
      display: inline-flex;
    }

    .page-title {
      font-size: var(--text-xl);
      text-align: center;
      max-width: 42vw;
    }

    .mobile-main {
      padding: 1.4rem 1.5rem;
      border-top: none;
    }

    .mobile-nav {
      display: none;
    }
  }

  @media (min-width: 1200px) {
    .mobile-main {
      padding: 1.8rem 2rem;
    }

    .topbar {
      padding: 0 2rem;
    }

    .page-title {
      font-size: var(--text-2xl);
      max-width: 52vw;
    }
  }
</style>
