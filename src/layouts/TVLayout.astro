---
import { languages } from "../i18n/ui";
import BaseHead from "../components/app/BaseHead.astro";
import "../styles/global.css";

interface Props {
  title: string;
  eyebrow?: string;
  lang?: number;
  autoRefresh?: boolean;
}

const { title, eyebrow, lang = 1, autoRefresh = true } = Astro.props;
const langCode = languages[lang as keyof typeof languages] || 'en';
const documentTitle = eyebrow ? `${eyebrow} - ${title}` : title;
---

<!doctype html>
<html lang={langCode}>
  <head>
    <BaseHead title={documentTitle} />
  </head>
  <body>
    <slot />
    {autoRefresh && (
      <script>
        setInterval(() => {
          if (document.hasFocus()) location.reload();
        }, 30_000);
      </script>
    )}
  </body>
</html>

<style is:global>
  body {
    height: 100vh;
    overflow: hidden;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateX(-10px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }

  /* Shared layout styles */
  .container {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    padding: 0.6rem 2.5rem 0.4rem;
  }

  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 0.5rem;
    flex-shrink: 0;
    animation: fadeInUp 0.5s ease both;
    padding: 0.5rem 0;
  }

  .header-left {
    display: flex;
    align-items: center;
    min-width: 0;
    overflow: hidden;
  }

  .title-row {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    overflow: hidden;
  }

  .title-stack {
    display: flex;
    flex-direction: column;
    min-width: 0;
    gap: var(--space-1);
  }

  .eyebrow {
    font-size: clamp(var(--text-xs), 0.9vw, var(--text-base));
    font-weight: var(--weight-bold);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin: 0;
  }

  .icon-logo {
    width: 28px;
    height: 28px;
    color: var(--accent-text);
    flex-shrink: 0;
  }

  .title {
    font-size: clamp(var(--text-2xl), 2.4vw, var(--text-4xl));
    font-family: var(--font-display);
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  /* Carousel */
  .carousel {
    flex: 1;
    position: relative;
    min-height: 0;
    overflow: hidden;
  }

  .carousel-page {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateX(40px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    pointer-events: none;
  }

  .carousel-page.active {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
    position: relative;
    height: 100%;
  }

  .carousel-page.exit {
    opacity: 0;
    transform: translateX(-40px);
  }

  .carousel-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.35rem 2rem;
    background: var(--surface-container-low);
    flex-shrink: 0;
  }

  .page-dots {
    display: flex;
    gap: 0.4rem;
  }

  .page-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid var(--text-dim);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 0.2s ease;
  }

  .page-dot.active {
    background: var(--accent-text);
    border-color: var(--accent-text);
  }

  .page-dot:hover {
    border-color: var(--accent-text);
  }

  .progress-bar {
    flex: 1;
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    width: 0%;
    background: var(--accent-text);
    border-radius: 2px;
  }

  /* Matches section */
  .matches-section {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: var(--surface-container-low);
    border-radius: var(--radius-lg);
    overflow: hidden;
    min-height: 0;
  }

  .col-label {
    font-size: var(--text-base);
    font-weight: var(--weight-extrabold);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text);
    opacity: 0.7;
  }

</style>
