---
import { ViewTransitions } from "astro:transitions";
import { languages } from "../i18n/ui";
import "../styles/global.css";

interface Props {
  title: string;
  lang?: number;
  autoRefresh?: boolean;
}

const { title, lang = 1, autoRefresh = true } = Astro.props;
const langCode = languages[lang as keyof typeof languages] || 'en';
---

<!doctype html>
<html lang={langCode}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#fcd34d" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <title>{title}</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script>
      // Inline theme script to prevent FOUC
      (function() {
        const stored = (() => { try { return localStorage.getItem('theme'); } catch { return null; } })();
        if (stored === 'light' || stored === 'dark') {
          document.documentElement.setAttribute('data-theme', stored);
        }
      })();
    </script>
    <script src="../scripts/theme.ts"></script>
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>
  </head>
  <body>
    <slot />
    {autoRefresh && (
      <script>
        setInterval(() => {
          if (document.hasFocus()) location.reload();
        }, 30_000);
      </script>
    )}
  </body>
</html>

<style is:global>
  body {
    height: 100vh;
    overflow: hidden;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateX(-10px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }

  /* Shared layout styles */
  .container {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    padding: 0.6rem 2.5rem 0.4rem;
  }

  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 0.5rem;
    flex-shrink: 0;
    animation: fadeInUp 0.5s ease both;
    padding: 0.5rem 0;
  }

  .header-left {
    display: flex;
    align-items: center;
    min-width: 0;
    overflow: hidden;
  }

  .title-row {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    overflow: hidden;
  }

  .icon-logo {
    width: 28px;
    height: 28px;
    color: var(--accent-text);
    flex-shrink: 0;
  }

  .title {
    font-size: var(--text-3xl);
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-transform: uppercase;
    letter-spacing: var(--tracking-tight);
  }

  /* Carousel */
  .carousel {
    flex: 1;
    position: relative;
    min-height: 0;
    overflow: hidden;
  }

  .carousel-page {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateX(40px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    pointer-events: none;
  }

  .carousel-page.active {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
    position: relative;
    height: 100%;
  }

  .carousel-page.exit {
    opacity: 0;
    transform: translateX(-40px);
  }

  .carousel-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.35rem 2rem;
    background: var(--bg);
    border-top: 1px solid var(--border);
    flex-shrink: 0;
  }

  .page-dots {
    display: flex;
    gap: 0.4rem;
  }

  .page-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid var(--text-dim);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 0.2s ease;
  }

  .page-dot.active {
    background: var(--accent-text);
    border-color: var(--accent-text);
  }

  .page-dot:hover {
    border-color: var(--accent-text);
  }

  .progress-bar {
    flex: 1;
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    width: 0%;
    background: var(--accent-text);
    border-radius: 2px;
  }

  /* Matches section */
  .matches-section {
    flex: 1;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    min-height: 0;
  }

  .col-label {
    font-size: var(--text-base);
    font-weight: var(--weight-extrabold);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text);
    opacity: 0.7;
  }

  /* Error */
  .error-card {
    background: rgba(248, 113, 113, 0.1);
    border: 1px solid rgba(248, 113, 113, 0.3);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    text-align: center;
  }

  .error-hint {
    font-size: 1rem;
    color: var(--text-dim);
    margin-top: 0.5rem;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    color: var(--text-dim);
    text-align: center;
    gap: 1rem;
  }

  .empty-icon {
    width: 48px;
    height: 48px;
    opacity: 0.4;
  }

  .empty-state p {
    font-size: 1.2rem;
    opacity: 0.7;
  }

  /* Config panel */
  .config-panel {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 100;
  }

  .config-toggle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .config-toggle:hover {
    border-color: var(--accent-text);
    transform: rotate(90deg);
  }

  .config-body {
    position: absolute;
    bottom: 50px;
    right: 0;
    width: 260px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    display: none;
    flex-direction: column;
    gap: var(--space-3);
    box-shadow: var(--shadow-elevated);
    animation: fadeInUp 0.3s ease both;
  }

  .config-body.open {
    display: flex;
  }

  .view-switch-panel {
    display: flex;
    background: var(--bg);
    border-radius: 6px;
    padding: 4px;
    gap: 4px;
    margin-bottom: 0.5rem;
  }

  .switch-btn {
    flex: 1;
    text-align: center;
    padding: 6px 0;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-dim);
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .switch-btn:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.05);
  }

  .switch-btn.active {
    background: var(--accent);
    color: var(--on-accent);
    box-shadow: var(--shadow-sm);
  }

  .config-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-dim);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .config-input {
    padding: 0.5rem 0.6rem;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text);
    font-size: 0.85rem;
    font-family: var(--font);
  }

  .config-input:focus {
    outline: none;
    border-color: var(--input-focus);
    box-shadow: 0 0 0 3px var(--input-focus-ring);
  }

  .config-btn {
    padding: 0.5rem;
    border-radius: var(--radius-sm);
    border: none;
    background: var(--accent);
    color: var(--on-accent);
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    font-family: var(--font);
    transition: opacity 0.2s ease;
  }

  .config-btn:hover {
    opacity: 0.9;
  }
</style>
