{
  "name": "chess-results-wrapper",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "node dist/server/entry.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "test": "DATABASE_PATH=:memory: vitest run --config vitest.config.ts",
    "test:unit": "DATABASE_PATH=:memory: SKIP_LIVE=1 vitest run --config vitest.config.ts",
    "test:live": "DATABASE_PATH=:memory: vitest run --config vitest.config.ts",
    "test:browser": "playwright test",
    "test:browser:screenshots": "SCREENSHOT_OUTPUT_DIR=.artifacts/page-screenshots playwright test tests/browser/page-screenshots.pw.spec.ts",
    "compare:browser:screenshots": "node scripts/compare-page-screenshots.mjs",
    "test:watch": "DATABASE_PATH=:memory: SKIP_LIVE=1 vitest --config vitest.config.ts",
    "precommit": "bun run test:unit",
    "seed:por2026": "tsx scripts/import-federation-year.ts --fed POR --year 2026 --lang 10",
    "seed:por2026:server": "./scripts/import-por2026-server.sh"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.1",
    "astro": "^6.3.3",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "chess.js": "^1.4.0",
    "cm-chessboard": "^8.12.7",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "iconify": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "playwright": "^1.60.0",
    "shadcn": "^4.7.0",
    "tsx": "^4.22.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.6"
  }
}
