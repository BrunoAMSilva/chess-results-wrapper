{
  "name": "chess-results-wrapper",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "node dist/server/entry.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "test": "DATABASE_PATH=:memory: vitest run --config vitest.config.ts",
    "test:unit": "DATABASE_PATH=:memory: SKIP_LIVE=1 vitest run --config vitest.config.ts",
    "test:live": "DATABASE_PATH=:memory: vitest run --config vitest.config.ts",
    "test:watch": "DATABASE_PATH=:memory: SKIP_LIVE=1 vitest --config vitest.config.ts",
    "precommit": "npm run test:unit",
    "seed:por2026": "tsx scripts/import-federation-year.ts --fed POR --year 2026 --lang 10",
    "seed:por2026:server": "./scripts/import-por2026-server.sh"
  },
  "dependencies": {
    "@astrojs/node": "^9.5.4",
    "astro": "^5.18.0",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "iconify": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "tsx": "^4.20.5",
    "vitest": "^4.0.18"
  }
}
